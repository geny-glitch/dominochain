<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ds_bg">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/ds_page_padding"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Wallpaper"
        style="@style/DsTitle"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open this link to upload an image:"
        style="@style/DsBody"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <TextView
        android:id="@+id/web_url_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        style="@style/DsBody"
        android:textColor="@color/ds_teal"
        android:padding="@dimen/ds_space_md"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <Button
        android:id="@+id/copy_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copy Link"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <Button
        android:id="@+id/refresh_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh Wallpaper"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <Button
        android:id="@+id/tasks_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tâches"
        style="@style/DsButtonSecondary" />

</LinearLayout>
</ScrollView>
