<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ds_bg">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/ds_page_padding"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Wallpaper"
        style="@style/DsTitle"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nom du device"
        style="@style/DsSmall"
        android:layout_marginBottom="@dimen/ds_space_xs" />

    <EditText
        android:id="@+id/device_name_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ex: Mon téléphone"
        android:inputType="text"
        android:maxLines="1"
        android:imeOptions="actionDone"
        style="@style/DsEditText"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <Button
        android:id="@+id/save_name_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enregistrer le nom"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_xl" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open this link to upload an image:"
        style="@style/DsBody"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <TextView
        android:id="@+id/web_url_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        style="@style/DsBody"
        android:textColor="@color/ds_teal"
        android:padding="@dimen/ds_space_md"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <Button
        android:id="@+id/copy_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copy Link"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <Button
        android:id="@+id/refresh_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh Wallpaper"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <Button
        android:id="@+id/tasks_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tâches"
        style="@style/DsButtonSecondary"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/ds_space_sm">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Activer les captures d'écran (le boss peut prendre un screenshot à tout moment)"
            style="@style/DsBody" />
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/screenshot_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:id="@+id/battery_optimization_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/battery_optimization_link"
        style="@style/DsSmall"
        android:textColor="@color/ds_teal"
        android:padding="@dimen/ds_space_xs"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="@dimen/ds_space_lg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Demander à être contrôlé par un boss"
        style="@style/DsSmall"
        android:layout_marginBottom="@dimen/ds_space_xs" />

    <EditText
        android:id="@+id/boss_nickname_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Pseudo du boss"
        android:inputType="text"
        android:maxLines="1"
        style="@style/DsEditText"
        android:layout_marginBottom="@dimen/ds_space_sm" />

    <Button
        android:id="@+id/send_control_request_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Envoyer la demande"
        style="@style/DsButton"
        android:layout_marginBottom="@dimen/ds_space_xl" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device ID"
        style="@style/DsSmall"
        android:layout_marginBottom="@dimen/ds_space_xs" />

    <TextView
        android:id="@+id/device_id_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/DsSmall"
        android:fontFamily="monospace" />

</LinearLayout>
</ScrollView>
