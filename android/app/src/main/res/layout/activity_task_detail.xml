<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ds_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ds_page_padding">

        <TextView
            android:id="@+id/task_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/DsTitleSmall"
            android:layout_marginBottom="@dimen/ds_space_sm" />

        <TextView
            android:id="@+id/task_deadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/DsSmall"
            android:layout_marginBottom="@dimen/ds_space_lg" />

        <TextView
            android:id="@+id/task_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/DsSmall"
            android:padding="@dimen/ds_space_xs"
            android:layout_marginBottom="@dimen/ds_space_lg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            style="@style/DsSectionTitle"
            android:layout_marginBottom="@dimen/ds_space_xs" />

        <TextView
            android:id="@+id/task_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DsBody"
            android:layout_marginBottom="@dimen/ds_space_lg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preuve attendue"
            style="@style/DsSectionTitle"
            android:layout_marginBottom="@dimen/ds_space_xs" />

        <TextView
            android:id="@+id/task_expected_proof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DsBody"
            android:layout_marginBottom="@dimen/ds_space_xl" />

        <LinearLayout
            android:id="@+id/proof_form_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/ds_card_background"
            android:padding="@dimen/ds_space_lg"
            android:layout_marginBottom="@dimen/ds_space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soumettre une preuve"
                style="@style/DsTitleSmall"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <EditText
                android:id="@+id/proof_text_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:hint="Texte de la preuve..."
                android:inputType="textMultiLine"
                style="@style/DsEditText"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <Button
                android:id="@+id/proof_media_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ajouter image/vidéo"
                style="@style/DsButtonSecondary"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <TextView
                android:id="@+id/proof_media_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/DsSmall"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <Button
                android:id="@+id/proof_submit_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Envoyer la preuve"
                style="@style/DsButton" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/proof_submitted_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/ds_card_background"
            android:padding="@dimen/ds_space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preuve soumise"
                style="@style/DsTitleSmall"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <TextView
                android:id="@+id/proof_submitted_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/DsBody"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <TextView
                android:id="@+id/proof_submitted_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/DsSmall"
                android:layout_marginBottom="@dimen/ds_space_sm" />

            <TextView
                android:id="@+id/proof_submitted_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/DsBody"
                android:textColor="@color/ds_text_muted"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/ds_space_sm" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
