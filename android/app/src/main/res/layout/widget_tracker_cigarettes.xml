<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_cigarettes_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_chaster_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/ds_space_sm">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_cigarettes_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="@string/tracker_cigarettes_title"
            android:textColor="@color/ds_text_muted"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_cigarettes_count"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:text="0"
                android:textColor="@color/ds_teal"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_cigarettes_unit"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/ds_space_xs"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:text="@string/tracker_cigarettes_unit"
                android:textColor="@color/ds_text_muted"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_cigarettes_increment"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/widget_tracker_increment_background"
        android:contentDescription="@string/tracker_widget_increment_description"
        android:gravity="center"
        android:text="@string/tracker_increment"
        android:textColor="@color/ds_bg"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>
