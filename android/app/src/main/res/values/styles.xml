<?xml version="1.0" encoding="utf-8"?>
<!-- Domino Chain Design System — component styles -->
<resources>
    <!-- Typography -->
    <style name="DsTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/ds_text</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
    <style name="DsTitleSmall" parent="DsTitle">
        <item name="android:textSize">20sp</item>
    </style>
    <style name="DsSubtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/ds_text_muted</item>
        <item name="android:textSize">13sp</item>
    </style>
    <style name="DsBody" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/ds_text</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="DsSmall" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/ds_text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="DsSectionTitle" parent="DsSmall">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Buttons -->
    <style name="DsButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/ds_amber</item>
        <item name="cornerRadius">@dimen/ds_radius_sm</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">@dimen/ds_space_lg</item>
        <item name="android:paddingEnd">@dimen/ds_space_lg</item>
        <item name="android:paddingTop">@dimen/ds_space_sm</item>
        <item name="android:paddingBottom">@dimen/ds_space_sm</item>
    </style>
    <style name="DsButtonSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/ds_magenta</item>
        <item name="strokeColor">@color/ds_magenta</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">@dimen/ds_radius_sm</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="DsButtonGhost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/ds_blue</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Inputs -->
    <style name="DsEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/ds_text</item>
        <item name="android:textColorHint">@color/ds_text_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/ds_input_background</item>
        <item name="android:padding">@dimen/ds_space_md</item>
    </style>

    <!-- Cards (use as theme for LinearLayout/FrameLayout) -->
    <style name="DsCard" parent="android:Widget">
        <item name="android:background">@drawable/ds_card_background</item>
        <item name="android:padding">@dimen/ds_space_lg</item>
    </style>
</resources>
