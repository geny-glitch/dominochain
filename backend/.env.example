# Sentry error tracking
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Chaster API (OAuth 2)
# Request developer access: https://forms.gle/U1tdM8U3w8Wdeqrz5
# Create app: https://chaster.app/developers/applications
# Add redirect URI: https://your-domain.com/chaster/callback
CHASTER_CLIENT_ID=
CHASTER_CLIENT_SECRET=

PURYFI_WS_PUBLIC_BASE=wss://bg-puryfi-ws.fly.dev

# Solid Queue (`bin/jobs` sur Fly) — nombre de processus Ruby par worker (défaut 1 ; voir config/queue.yml)
# JOB_CONCURRENCY=1

# Strava API (OAuth 2)
# Create app: https://www.strava.com/settings/api
# Add redirect URI: https://your-domain.com/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
