# Sentry error tracking
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Chaster API (OAuth 2)
# Request developer access: https://forms.gle/U1tdM8U3w8Wdeqrz5
# Create app: https://chaster.app/developers/applications
# Add redirect URI: https://your-domain.com/chaster/callback
CHASTER_CLIENT_ID=
CHASTER_CLIENT_SECRET=

APP_PUBLIC_BASE_URL=https://dominochain.app
BG_ALLOWED_HOSTS=dominochain.app,beta.dominochain.app
PURYFI_WS_PUBLIC_BASE=wss://puryfi.dominochain.app

# Resend transactional email API
# Verify the sending domain in Resend, then set these secrets in Fly.
RESEND_API_KEY=
RESEND_FROM_EMAIL="DominoChain <noreply@mail.dominochain.app>"
RESEND_REPLYTO_EMAIL=support@dominochain.app

# Solid Queue — production/staging run `bin/jobs` on a dedicated Fly worker process.
# Local: run `bin/jobs` in another terminal, or set SOLID_QUEUE_IN_PUMA=1 for Puma (see config/puma.rb).
# JOB_CONCURRENCY=1

# Tigris object storage (Fly). Required in production/staging when ACTIVE_STORAGE_SERVICE=tigris.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
# AWS_REGION=auto
# BUCKET_NAME=bg-shared
# ACTIVE_STORAGE_KEY_PREFIX=staging/
# ACTIVE_STORAGE_SERVICE=tigris

# Strava API (OAuth 2)
# Create app: https://www.strava.com/settings/api
# Add redirect URI: https://your-domain.com/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
