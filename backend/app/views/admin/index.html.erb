<% content_for :title, t("admin.index_title") %>

<div class="ds-page">
  <div class="ds-container ds-admin-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: t("layouts.application.logo_alt"), class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title"><%= t("admin.heading") %></h1>
        <p class="ds-subtitle"><%= t("admin.users_subtitle") %></p>
      </div>
      <div class="ds-header-actions">
        <%= link_to t("admin.review_link"), admin_review_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <%= link_to t("admin.wallpaper_pairs_link"), admin_wallpaper_pairs_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <%= link_to t("admin.settings_link"), admin_settings_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <%= link_to t("admin.jobs_link"), "/admin/jobs", class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      </div>
    </header>

    <% if @controls&.any? %>
      <section class="ds-admin-list">
        <h2><%= t("admin.active_controls_title") %></h2>
        <ul class="ds-device-list">
          <% @controls.each do |control| %>
            <li class="ds-device-list-item">
              <span><%= control.boss.nickname %> → <%= control.beta.nickname %></span>
              <%= button_to t("admin.release_short"), admin_release_control_path(control.id), method: :post, form: { data: { turbo_confirm: t("admin.release_control_confirm") } }, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <section class="ds-admin-list">
      <h2><%= t("admin.cache_title") %></h2>
      <p class="ds-admin-empty"><%= t("admin.cache_subtitle") %></p>
      <%= button_to t("admin.invalidate_feature_flags_cache"),
        admin_invalidate_feature_flags_cache_path,
        method: :post,
        form: { data: { turbo_confirm: t("admin.invalidate_feature_flags_cache_confirm") } },
        class: "ds-btn ds-btn--ghost ds-btn--sm" %>
    </section>

    <section class="ds-admin-list">
      <h2><%= t("admin.users_heading") %></h2>
      <% if @users.any? %>
        <ul class="ds-device-list">
          <% @users.each do |user| %>
            <li class="ds-device-list-item">
              <div class="ds-device-list-info">
                <span class="ds-device-name"><%= user.nickname %></span>
                <span class="ds-sep">·</span>
                <span class="ds-device-id"><%= user.role %></span>
              </div>
              <% if user.beta? %>
                <%= link_to t("admin.view_wallpaper_page"), wallpaper_upload_path(user.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
              <% elsif user.boss? %>
                <% controlled = user.controls.accepted %>
                <% if controlled.any? %>
                  <% controlled.each do |c| %>
                    <%= link_to c.beta.nickname, wallpaper_upload_path(c.beta.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
                  <% end %>
                <% else %>
                  <span class="ds-text-muted"><%= t("admin.no_beta") %></span>
                <% end %>
              <% else %>
                <span class="ds-text-muted">—</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="ds-admin-empty"><%= t("admin.no_users") %></p>
      <% end %>
    </section>
  </div>
</div>
