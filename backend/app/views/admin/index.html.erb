<% content_for :title, "Admin — Domino Chain" %>

<div class="ds-page">
  <div class="ds-container ds-admin-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: "Domino Chain", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Admin</h1>
        <p class="ds-subtitle">Utilisateurs</p>
      </div>
      <div class="ds-header-actions">
        <%= link_to "Review", admin_review_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <%= link_to "Paramètres", admin_settings_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      </div>
    </header>

    <% if @controls&.any? %>
      <section class="ds-admin-list">
        <h2>Controls actifs</h2>
        <ul class="ds-device-list">
          <% @controls.each do |control| %>
            <li class="ds-device-list-item">
              <span><%= control.boss.nickname %> → <%= control.beta.nickname %></span>
              <%= button_to "Libérer", admin_release_control_path(control.id), method: :post, form: { data: { turbo_confirm: "Libérer ce beta ?" } }, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <section class="ds-admin-list">
      <h2>Utilisateurs</h2>
      <% if @users.any? %>
        <ul class="ds-device-list">
          <% @users.each do |user| %>
            <li class="ds-device-list-item">
              <div class="ds-device-list-info">
                <span class="ds-device-name"><%= user.nickname %></span>
                <span class="ds-sep">·</span>
                <span class="ds-device-id"><%= user.role %></span>
              </div>
              <% if user.beta? %>
                <%= link_to "Voir la page", wallpaper_upload_path(user.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
              <% elsif user.boss? %>
                <% controlled = user.controls.accepted %>
                <% if controlled.any? %>
                  <% controlled.each do |c| %>
                    <%= link_to c.beta.nickname, wallpaper_upload_path(c.beta.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
                  <% end %>
                <% else %>
                  <span class="ds-text-muted">Aucun beta</span>
                <% end %>
              <% else %>
                <span class="ds-text-muted">—</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="ds-admin-empty">Aucun utilisateur.</p>
      <% end %>
    </section>
  </div>
</div>
