<% content_for :title, "Admin - OTB" %>

<div class="ds-page">
  <div class="ds-container ds-admin-container">
    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Admin</h1>
        <p class="ds-subtitle">Devices actifs</p>
      </div>
      <div class="ds-header-actions">
        <%= link_to "Review", admin_review_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <%= link_to "Paramètres", admin_settings_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      </div>
    </header>

    <% if @controls&.any? %>
      <section class="ds-admin-list">
        <h2>Controls actifs</h2>
        <ul class="ds-device-list">
          <% @controls.each do |control| %>
            <li class="ds-device-list-item">
              <span><%= control.boss.nickname %> → <%= control.beta.nickname %></span>
              <%= button_to "Libérer", admin_release_control_path(control.id), method: :post, form: { data: { turbo_confirm: "Libérer ce beta ?" } }, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <section class="ds-admin-list">
      <% if @devices.any? %>
        <ul class="ds-device-list">
          <% @devices.each do |device| %>
            <li class="ds-device-list-item">
              <div class="ds-device-list-info">
                <span class="ds-device-name"><%= device.display_name %></span>
                <% if device.user %>
                  <span class="ds-sep">·</span>
                  <span class="ds-device-id"><%= device.user.nickname %></span>
                <% elsif device.name.present? %>
                  <span class="ds-sep">·</span>
                  <span class="ds-device-id"><%= device.device_id %></span>
                <% end %>
                <% if device.screen_width.present? && device.screen_height.present? %>
                  <span class="ds-sep">·</span>
                  <span><%= device.screen_width %>×<%= device.screen_height %></span>
                <% end %>
                <% if device.fcm_token.present? %>
                  <span class="ds-sep">·</span>
                  <span class="ds-status ds-status--on">Push</span>
                <% else %>
                  <span class="ds-sep">·</span>
                  <span class="ds-status ds-status--off">Push off</span>
                <% end %>
              </div>
              <% if device.user %>
                <%= link_to "Ouvrir", wallpaper_upload_path(device.user.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
              <% else %>
                <span class="ds-text-muted">(pas de compte lié)</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="ds-admin-empty">Aucun device enregistré. Ouvre l'app pour t'enregistrer.</p>
      <% end %>
    </section>
  </div>
</div>
