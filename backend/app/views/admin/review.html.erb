<% content_for :title, t("admin_review.page_title") %>

<div class="ds-review">
  <div class="ds-review__bg" aria-hidden="true"></div>

  <div class="ds-review__content">
    <header class="ds-review__header">
      <%= link_to t("admin_review.back_admin"), admin_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      <h1 class="ds-review__title"><%= t("admin_review.title") %></h1>
      <div class="ds-header-trailing">
        <%= render "shared/discord_link", variant: :icon %>
      </div>
    </header>

    <div id="review-grid" class="ds-review__grid">
      <% if @images&.any? %>
        <%= render partial: "admin/review_image", collection: @images || [], as: :image %>
      <% else %>
        <p class="ds-review__empty">
          <%= t("admin_review.empty_prefix") %>
          <code><%= t("admin_review.empty_code") %></code>
          <%= t("admin_review.empty_suffix") %>
        </p>
      <% end %>
    </div>

    <div id="review-sentinel" class="ds-review__sentinel"></div>
    <div id="review-loading" class="ds-review__loading" style="display: none;"><%= t("admin_review.loading") %></div>
  </div>
</div>

<%= javascript_tag do %>
(function() {
  const grid = document.getElementById('review-grid');
  const sentinel = document.getElementById('review-sentinel');
  const loading = document.getElementById('review-loading');
  if (!grid || !sentinel) return;

  let nextPage = 2;
  let loadingMore = false;

  function loadMore() {
    if (loadingMore) return;
    loadingMore = true;
    loading.style.display = 'block';

    fetch('/admin/review/images?page=' + nextPage, {
      headers: { 'Accept': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
      if (data.html) {
        const beforeCount = grid.children.length;
        grid.insertAdjacentHTML('beforeend', data.html);
        const newCards = Array.from(grid.children).slice(beforeCount);
        bindButtons(newCards);
      }
      nextPage = data.next_page || null;
      loadingMore = false;
      loading.style.display = 'none';
    })
    .catch(() => {
      loadingMore = false;
      loading.style.display = 'none';
    });
  }

  function bindButtons(cards) {
    cards.forEach(card => {
      if (card.dataset.bound) return;
      card.dataset.bound = '1';
      if (!card.dataset.id) return;

      const likeBtn = card.querySelector('[data-action="like"]');
      const dislikeBtn = card.querySelector('[data-action="dislike"]');

      if (likeBtn) {
        likeBtn.addEventListener('click', function() {
          const id = card.dataset.id;
          fetch('/admin/review/images/' + id + '/like', { method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '', 'Accept': 'application/json' } })
            .then(r => r.json())
            .then(data => {
              const countEl = likeBtn.querySelector('.ds-review-card__like-count');
              if (countEl) countEl.textContent = data.likes_count;
            });
        });
      }

      if (dislikeBtn) {
        dislikeBtn.addEventListener('click', function() {
          const id = card.dataset.id;
          fetch('/admin/review/images/' + id + '/dislike', { method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '', 'Accept': 'application/json' } })
            .then(r => r.json())
            .then(data => {
              const countEl = dislikeBtn.querySelector('.ds-review-card__dislike-count');
              if (countEl) countEl.textContent = -data.dislikes_count;
            });
        });
      }
    });
  }

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && nextPage) loadMore();
  }, { rootMargin: '200px' });
  observer.observe(sentinel);

  bindButtons(grid.querySelectorAll('[data-id]'));
})();
<% end %>
