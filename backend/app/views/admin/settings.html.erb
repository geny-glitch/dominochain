<% content_for :title, t("admin_settings.title") %>

<div class="ds-page">
  <div class="ds-container ds-admin-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: t("layouts.application.logo_alt"), class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title"><%= t("admin_settings.heading") %></h1>
        <p class="ds-subtitle"><%= t("admin_settings.subtitle") %></p>
      </div>
      <div class="ds-header-trailing">
        <%= render "shared/discord_link", variant: :icon %>
      </div>
    </header>

    <p class="ds-admin-hint"><%= t("admin_settings.hint") %></p>

    <%= form_with url: admin_update_settings_path, method: :patch, local: true, class: "ds-admin-form" do |f| %>
      <% if flash[:notice] %>
        <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
      <% end %>

      <div class="ds-form-group">
        <%= label_tag :influencer_names, t("admin_settings.influencer_names_label"), class: "ds-form-label" %>
        <%= text_area_tag :influencer_names, @app_setting&.influencer_names, rows: 25, class: "ds-form-textarea", placeholder: t("admin_settings.influencer_names_placeholder") %>
      </div>

      <div class="ds-form-group">
        <%= label_tag :wallpaper_verification_algorithm, t("admin_settings.wallpaper_algorithm_label"), class: "ds-form-label" %>
        <%= select_tag :wallpaper_verification_algorithm,
          options_for_select(
            AppSetting::WALLPAPER_VERIFICATION_ALGORITHMS.map { |value, label| [label, value] },
            @app_setting&.wallpaper_verification_algorithm || AppSetting::DEFAULT_WALLPAPER_VERIFICATION_ALGORITHM
          ),
          class: "ds-form-select" %>
        <p class="ds-admin-hint"><%= t("admin_settings.wallpaper_algorithm_hint") %></p>
      </div>

      <div class="ds-form-actions">
        <%= submit_tag t("admin_settings.save"), class: "ds-btn ds-btn--primary" %>
        <%= link_to t("admin_settings.back"), admin_path, class: "ds-btn ds-btn--secondary" %>
      </div>
    <% end %>
  </div>
</div>
