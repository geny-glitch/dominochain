<% content_for :title, "Paramètres - Admin OTB" %>

<div class="ds-page">
  <div class="ds-container ds-admin-container">
    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Paramètres</h1>
        <p class="ds-subtitle">Liste des influenceurs (home page)</p>
      </div>
    </header>

    <p class="ds-admin-hint">Une ligne = Prénom Nom. Utilisé pour le collage sur la home.</p>

    <%= form_with url: admin_update_settings_path, method: :patch, local: true, class: "ds-admin-form" do |f| %>
      <% if flash[:notice] %>
        <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
      <% end %>

      <div class="ds-form-group">
        <%= label_tag :influencer_names, "Noms (un par ligne)", class: "ds-form-label" %>
        <%= text_area_tag :influencer_names, @app_setting.influencer_names, rows: 25, class: "ds-form-textarea", placeholder: "Selena Gomez\nKylie Jenner\n..." %>
      </div>

      <div class="ds-form-actions">
        <%= submit_tag "Enregistrer", class: "ds-btn ds-btn--primary" %>
        <%= link_to "Retour admin", admin_path, class: "ds-btn ds-btn--secondary" %>
      </div>
    <% end %>
  </div>
</div>
