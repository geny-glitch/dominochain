<% content_for :title, t("admin_wallpaper_pairs.page_title") %>

<div class="ds-review ds-wallpaper-pairs-page">
  <div class="ds-review__bg" aria-hidden="true"></div>

  <div class="ds-review__content">
    <header class="ds-review__header ds-wallpaper-pairs-page__header">
      <div>
        <%= link_to t("admin_wallpaper_pairs.back_admin"), admin_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        <h1 class="ds-review__title"><%= t("admin_wallpaper_pairs.title") %></h1>
        <p class="ds-review__subtitle"><%= t("admin_wallpaper_pairs.subtitle", algorithm: AppSetting::WALLPAPER_VERIFICATION_ALGORITHMS.fetch(@active_verification_algorithm)) %></p>
      </div>
    </header>

    <nav class="ds-review__filters" aria-label="<%= t("admin_wallpaper_pairs.title") %>">
      <%= link_to t("admin_wallpaper_pairs.filter_unreviewed"),
        admin_wallpaper_pairs_path(filter: "unreviewed"),
        class: "ds-btn ds-btn--sm #{@filter == 'unreviewed' ? 'ds-btn--primary' : 'ds-btn--ghost'}" %>
      <%= link_to t("admin_wallpaper_pairs.filter_disagreements"),
        admin_wallpaper_pairs_path(filter: "disagreements"),
        class: "ds-btn ds-btn--sm #{@filter == 'disagreements' ? 'ds-btn--primary' : 'ds-btn--ghost'}" %>
      <%= link_to t("admin_wallpaper_pairs.filter_all"),
        admin_wallpaper_pairs_path(filter: "all"),
        class: "ds-btn ds-btn--sm #{@filter == 'all' ? 'ds-btn--primary' : 'ds-btn--ghost'}" %>
    </nav>

    <% if @filter == "disagreements" %>
      <div class="ds-wallpaper-pairs-export">
        <p class="ds-wallpaper-pairs-export__text">
          <%= t("admin_wallpaper_pairs.disagreements_help", count: @total_count) %>
        </p>
        <div class="ds-wallpaper-pairs-export__actions">
          <%= button_to t("admin_wallpaper_pairs.export_disagreements"),
            admin_wallpaper_pairs_export_disagreements_path(filter: @filter, page: @page),
            method: :post,
            class: "ds-btn ds-btn--primary ds-btn--sm",
            form: { data: { turbo: false } } %>
          <code class="ds-wallpaper-pairs-export__command">bin/fetch-wallpaper-disagreements</code>
        </div>
      </div>
    <% end %>

    <% if @pairs.any? %>
      <div class="ds-wallpaper-pairs-table-wrap">
        <table class="ds-wallpaper-pairs-table">
          <thead>
            <tr>
              <th scope="col"><%= t("admin_wallpaper_pairs.screenshot_label") %></th>
              <th scope="col"><%= t("admin_wallpaper_pairs.reference_label") %></th>
              <th scope="col"><%= t("admin_wallpaper_pairs.column_pair") %></th>
              <th scope="col"><%= t("admin_wallpaper_pairs.column_production") %></th>
              <% AppSetting::WALLPAPER_VERIFICATION_ALGORITHMS.each_value do |algorithm_label| %>
                <th scope="col"><%= algorithm_label %></th>
              <% end %>
              <th scope="col"><%= t("admin_wallpaper_pairs.column_review") %></th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "admin/wallpaper_pair_row",
              collection: @pairs,
              as: :screenshot,
              locals: {
                comparisons_by_screenshot_and_algorithm: @comparisons_by_screenshot_and_algorithm,
                filter: @filter,
                page: @page
              } %>
          </tbody>
        </table>
      </div>

      <% if @total_pages > 1 %>
        <nav class="ds-wallpaper-pairs__pagination" aria-label="<%= t("admin_wallpaper_pairs.pagination", page: @page, total: @total_pages) %>">
          <span class="ds-wallpaper-pairs__pagination-label">
            <%= t("admin_wallpaper_pairs.pagination", page: @page, total: @total_pages) %>
          </span>
          <div class="ds-wallpaper-pairs__pagination-actions">
            <% if @page > 1 %>
              <%= link_to t("admin_wallpaper_pairs.prev_page"),
                admin_wallpaper_pairs_path(filter: @filter, page: @page - 1),
                class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            <% end %>
            <% if @page < @total_pages %>
              <%= link_to t("admin_wallpaper_pairs.next_page"),
                admin_wallpaper_pairs_path(filter: @filter, page: @page + 1),
                class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            <% end %>
          </div>
        </nav>
      <% end %>
    <% else %>
      <p class="ds-review__empty"><%= t("admin_wallpaper_pairs.empty") %></p>
    <% end %>
  </div>
</div>
