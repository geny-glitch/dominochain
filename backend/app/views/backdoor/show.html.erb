<% content_for :title, "Backdoor" %>

<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Backdoor</h1>
        <p class="ds-subtitle">Ajout de temps Chaster (lien secret)</p>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <section class="ds-beta-section">
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">Capacité restante sur 5 minutes : <strong id="backdoor-remaining"><%= @remaining_seconds %></strong> s (max <%= ShowcaseAddTimeLimiter::MAX_SECONDS_PER_WINDOW %> s).</p>
        <%= form_with url: showcase_backdoor_add_time_path(@beta.nickname, params[:token]), method: :post, local: true, id: "backdoor-form", class: "ds-form", data: { turbo: false } do %>
          <div class="ds-form-group">
            <%= label_tag :seconds, "Secondes à ajouter (1–86400)", class: "ds-form-label" %>
            <%= number_field_tag :seconds, 300, min: 1, max: 86_400, step: 1, class: "ds-input", id: "backdoor-seconds" %>
          </div>
          <%= submit_tag "Ajouter au lock", class: "ds-btn ds-btn--primary ds-btn--sm", id: "backdoor-submit" %>
        <% end %>
        <p class="ds-beta-control-hint" id="backdoor-msg" style="margin-top: 0.75rem;"></p>
      </div>
    </section>
  </div>
</div>

<script>
(function() {
  var form = document.getElementById('backdoor-form');
  var msg = document.getElementById('backdoor-msg');
  var remainingEl = document.getElementById('backdoor-remaining');
  var submitBtn = document.getElementById('backdoor-submit');
  if (!form) return;

  form.addEventListener('submit', function(ev) {
    ev.preventDefault();
    var seconds = parseInt(document.getElementById('backdoor-seconds').value, 10);
    if (!seconds || seconds < 1 || seconds > 86400) {
      msg.textContent = 'Indique un nombre entre 1 et 86400.';
      msg.className = 'ds-beta-control-hint ds-flash--error';
      return;
    }
    submitBtn.disabled = true;
    msg.textContent = '';
    msg.className = 'ds-beta-control-hint';

    fetch(form.action, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: JSON.stringify({ seconds: seconds })
    })
    .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); })
    .then(function(res) {
      if (res.ok && res.body.ok) {
        msg.textContent = 'Temps ajouté.';
        msg.className = 'ds-beta-control-hint ds-flash--success';
        if (typeof res.body.remaining_seconds === 'number') {
          remainingEl.textContent = res.body.remaining_seconds;
        }
      } else {
        msg.textContent = res.body.error || ('Erreur (' + res.status + ')');
        msg.className = 'ds-beta-control-hint ds-flash--error';
        if (typeof res.body.remaining_seconds === 'number') {
          remainingEl.textContent = res.body.remaining_seconds;
        }
      }
    })
    .catch(function() {
      msg.textContent = 'Erreur réseau.';
      msg.className = 'ds-beta-control-hint ds-flash--error';
    })
    .finally(function() { submitBtn.disabled = false; });
  });
})();
</script>
