    <%# Contrôle — qui contrôle ou lien d'invitation %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title"><%= t("beta.control.title") %></h2>
      <% if @control&.accepted? %>
        <div class="ds-beta-control-card">
          <p class="ds-beta-control-text"><%= t("beta.control.controlled_prefix") %> <strong><%= @control.boss.nickname %></strong></p>
          <p class="ds-beta-control-hint"><%= t("beta.control.hint_boss") %></p>
        </div>
      <% else %>
        <div class="ds-beta-control-card ds-beta-control-card--invite">
          <p class="ds-beta-control-text"><%= t("beta.control.nobody") %></p>
          <p class="ds-beta-control-hint"><%= t("beta.control.invite_lead") %></p>
          <div class="ds-beta-invite-link">
            <code id="invite-url"><%= @invite_url %></code>
            <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="invite-url" title="<%= t("beta.control.copy") %>">
              <%= t("beta.control.copy") %>
            </button>
          </div>
          <p class="ds-beta-control-hint ds-beta-control-hint--small"><%= t("beta.control.invite_footer") %></p>
        </div>
      <% end %>
    </section>
