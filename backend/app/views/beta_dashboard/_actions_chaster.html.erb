<% chaster_connected = current_user.chaster_access_token.present? %>

<section class="ds-beta-section ds-beta-section--first">
  <h2 class="ds-section-title"><%= t("beta.integration_sections.installation") %></h2>
  <% if chaster_connected %>
    <div class="ds-beta-control-card">
      <details class="ds-chaster-install-drawer">
        <summary class="ds-chaster-install-summary">
          <span class="ds-beta-control-text"><%= t("beta.actions_chaster.connected") %></span>
          <span class="ds-chaster-toggle-icon" aria-hidden="true">▾</span>
        </summary>
        <div class="ds-chaster-install-body">
          <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.installation_connected_hint") %></p>
          <%= button_to t("beta.actions_chaster.disconnect"), chaster_disconnect_path, method: :delete, form: { data: { turbo_confirm: t("beta.actions_chaster.disconnect_confirm") } }, class: "ds-btn ds-btn--secondary ds-btn--sm ds-chaster-card-action" %>
        </div>
      </details>
    </div>
  <% elsif ChasterService.configured? %>
    <div class="ds-beta-control-card ds-beta-control-card--invite">
      <p class="ds-beta-control-text"><%= t("beta.actions_chaster.installation_disconnected_hint") %></p>
      <%= link_to t("beta.actions_chaster.connect"), chaster_connect_path, class: "ds-btn ds-btn--primary ds-btn--sm ds-chaster-card-action" %>
    </div>
  <% else %>
    <div class="ds-beta-control-card">
      <p class="ds-text-muted"><%= t("beta.actions_chaster.not_configured") %></p>
    </div>
  <% end %>
</section>

<% if chaster_connected %>
  <section class="ds-beta-section ds-beta-section--tight-top">
    <div class="ds-section-header ds-section-header--split ds-section-header--with-action">
      <h2 class="ds-section-title"><%= t("beta.integration_sections.logs_tracking") %></h2>
      <%= link_to beta_actions_chaster_path, class: "ds-btn ds-btn--icon ds-btn--ghost ds-section-header-action", title: t("beta.actions_chaster.refresh_title"), "aria-label": t("beta.actions_chaster.refresh_title") do %>
        <svg class="ds-icon-refresh" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      <% end %>
    </div>
    <div class="ds-beta-control-card">
      <% if @chaster_lock %>
        <p class="ds-beta-control-text"><%= @chaster_lock[:title].presence || t("beta.actions_chaster.active_lock_fallback") %></p>
        <p class="ds-chaster-countdown" id="chaster-countdown"
           data-end-date="<%= @chaster_lock[:end_date] %>"
           data-is-frozen="<%= @chaster_lock[:is_frozen] %>">
          <%= @chaster_lock[:is_frozen] ? t("beta.actions_chaster.frozen") : format_chaster_remaining(@chaster_lock[:remaining_seconds]) %>
        </p>
        <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.logs_lock_hint") %></p>
      <% else %>
        <p class="ds-beta-control-text"><%= t("beta.actions_chaster.connected") %></p>
        <p class="ds-beta-control-hint"><%= t("beta.hints.chaster_no_lock") %></p>
      <% end %>
    </div>
  </section>

  <section class="ds-beta-section ds-beta-section--tight-top">
    <h2 class="ds-section-title"><%= t("beta.integration_sections.notifications") %></h2>
    <div class="ds-beta-control-card">
      <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.notifications_hint") %></p>
    </div>
  </section>
<% end %>
