<section class="ds-beta-section">
  <% if current_user.chaster_access_token.present? %>
    <div class="ds-beta-toolbar">
      <%= link_to beta_actions_chaster_path, class: "ds-btn ds-btn--icon ds-btn--ghost", title: t("beta.actions_chaster.refresh_title") do %>
        <svg class="ds-icon-refresh" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      <% end %>
    </div>
  <% end %>
  <% if current_user.chaster_access_token.present? %>
    <div class="ds-beta-control-card">
      <h3 class="ds-section-title" style="margin-bottom: 0.5rem; font-size: 1rem;"><%= t("beta.integration_sections.installation") %></h3>
      <details>
        <summary class="ds-beta-control-text"><%= t("beta.actions_chaster.connected") %></summary>
        <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.installation_connected_hint") %></p>
        <%= button_to t("beta.actions_chaster.disconnect"), chaster_disconnect_path, method: :delete, form: { data: { turbo_confirm: t("beta.actions_chaster.disconnect_confirm") } }, class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-top: 0.5rem;" %>
      </details>
    </div>

    <div class="ds-beta-control-card">
      <h3 class="ds-section-title" style="margin-bottom: 0.5rem; font-size: 1rem;"><%= t("beta.integration_sections.logs_tracking") %></h3>
      <% if @chaster_lock %>
        <p class="ds-beta-control-text"><%= @chaster_lock[:title].presence || t("beta.actions_chaster.active_lock_fallback") %></p>
        <p class="ds-chaster-countdown" id="chaster-countdown"
           data-end-date="<%= @chaster_lock[:end_date] %>"
           data-is-frozen="<%= @chaster_lock[:is_frozen] %>">
          <%= @chaster_lock[:is_frozen] ? t("beta.actions_chaster.frozen") : format_chaster_remaining(@chaster_lock[:remaining_seconds]) %>
        </p>
        <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.logs_lock_hint") %></p>
      <% else %>
        <p class="ds-beta-control-text"><%= t("beta.actions_chaster.connected") %></p>
        <p class="ds-beta-control-hint"><%= t("beta.hints.chaster_no_lock") %></p>
      <% end %>
    </div>

    <div class="ds-beta-control-card">
      <h3 class="ds-section-title" style="margin-bottom: 0.5rem; font-size: 1rem;"><%= t("beta.integration_sections.notifications") %></h3>
      <p class="ds-beta-control-hint"><%= t("beta.actions_chaster.notifications_hint") %></p>
    </div>
  <% elsif ChasterService.configured? %>
    <div class="ds-beta-control-card ds-beta-control-card--invite">
      <h3 class="ds-section-title" style="margin-bottom: 0.5rem; font-size: 1rem;"><%= t("beta.integration_sections.installation") %></h3>
      <p class="ds-beta-control-text"><%= t("beta.actions_chaster.installation_disconnected_hint") %></p>
      <%= link_to t("beta.actions_chaster.connect"), chaster_connect_path, class: "ds-btn ds-btn--primary ds-btn--sm", style: "margin-top: 0.5rem;" %>
    </div>
  <% else %>
    <p class="ds-text-muted"><%= t("beta.actions_chaster.not_configured") %></p>
  <% end %>
</section>
