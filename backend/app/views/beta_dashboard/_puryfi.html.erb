    <%# PuryFi WebSocket %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">PuryFi + Chaster</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">
          Colle cette URL dans ton plugin PuryFi (WebSocket). Elle identifie ton compte — pas besoin de token API BG sur le serveur Fly.
        </p>
        <% if @puryfi_ws_url.present? %>
          <p class="ds-beta-control-hint" style="word-break: break-all; font-family: ui-monospace, monospace;">
            <span id="puryfi-ws-url"><%= @puryfi_ws_url %></span>
          </p>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="puryfi-ws-url">Copier l’URL</button>
          <%= button_to "Régénérer l’URL (révoque l’ancienne)", beta_puryfi_regenerate_token_path, method: :post, form: { data: { turbo_confirm: "Les plugins qui utilisent l’ancienne URL cesseront de fonctionner. Continuer ?" } }, class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-left: 0.5rem;" %>
        <% end %>
        <%= form_with url: beta_puryfi_path, method: :patch, local: true, class: "ds-form", style: "margin-top: 1rem;" do %>
          <div class="ds-form-group">
            <%= label_tag :puryfi_min_score, "Score minimum de détection (0–1)", class: "ds-form-label" %>
            <%= number_field_tag :puryfi_min_score, current_user.puryfi_min_score, min: 0, max: 1, step: 0.05, class: "ds-input" %>
          </div>
          <p class="ds-beta-control-hint" style="margin-bottom: 0.5rem;">Secondes ajoutées au lock par étiquette détectée (0 = ignorée).</p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr)); gap: 0.5rem 1rem; max-height: 18rem; overflow-y: auto; padding: 0.25rem 0;">
            <% @puryfi_label_ids.each do |id| %>
              <div class="ds-form-group" style="margin: 0;">
                <%= label_tag "puryfi_seconds_#{id}", "#{id} — #{PuryfiLabel.name_for(id)}", class: "ds-form-label", style: "font-size: 0.8rem;" %>
                <%= number_field_tag "puryfi_seconds_per_label[#{id}]", (current_user.puryfi_seconds_per_label[id.to_s] || 0), min: 0, max: 86_400, class: "ds-input" %>
              </div>
            <% end %>
          </div>
          <%= submit_tag "Enregistrer PuryFi", class: "ds-btn ds-btn--primary ds-btn--sm", style: "margin-top: 0.75rem;" %>
        <% end %>
      </div>
    </section>
