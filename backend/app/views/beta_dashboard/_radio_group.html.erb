<%# locals: (name:, options:, selected:, legend: nil, group_data: {}) %>
<fieldset class="ds-radio-group" <%= tag.attributes(group_data) if group_data.present? %>>
  <% if legend.present? %>
    <legend class="ds-radio-group__legend"><%= legend %></legend>
  <% end %>
  <% options.each do |value, label| %>
    <% input_id = "#{name}_#{value}" %>
    <label class="ds-radio-option" for="<%= input_id %>">
      <%= radio_button_tag name, value, selected.to_s == value.to_s,
            id: input_id,
            class: "ds-radio-option__input",
            data: { mismatch_mode_radio: true } %>
      <span class="ds-radio-option__label"><%= label %></span>
    </label>
  <% end %>
</fieldset>
