    <%# PiShock %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title"><%= t("beta.integration_sections.installation") %></h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-hint">
          <%= t("beta.pishock.setup_hint_prefix_html") %>
          <a href="https://pishock.com" target="_blank" rel="noopener noreferrer" class="ds-inline-link">pishock.com</a>
          <%= t("beta.pishock.setup_hint_middle_html") %>
          <a href="https://apidocs.pishock.com/" target="_blank" rel="noopener noreferrer" class="ds-inline-link"><%= t("beta.pishock.api_docs_label") %></a>
          <%= t("beta.pishock.setup_hint_and") %>
          <a href="https://docs.pishock.com/pishock/api-documentation/pishock-api-documentation.html" target="_blank" rel="noopener noreferrer" class="ds-inline-link"><%= t("beta.pishock.auth_docs_label") %></a>.
        </p>

        <%= form_with url: beta_pishock_path, method: :patch, local: true, class: "ds-form ds-pishock-form" do %>
          <div class="ds-form-group">
            <%= label_tag :pishock_username, t("beta.pishock.username_label"), class: "ds-form-label" %>
            <%= text_field_tag :pishock_username, current_user.pishock_username, class: "ds-input", autocomplete: "username" %>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_share_code, t("beta.pishock.share_code_label"), class: "ds-form-label" %>
            <%= text_field_tag :pishock_share_code, current_user.pishock_share_code, class: "ds-input", autocomplete: "off" %>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_api_key, t("beta.pishock.api_key_label"), class: "ds-form-label" %>
            <%= password_field_tag :pishock_api_key, nil, class: "ds-input", autocomplete: "new-password", placeholder: current_user.pishock_api_key.present? ? t("beta.pishock.api_key_placeholder") : "" %>
          </div>
          <%= submit_tag t("beta.pishock.save"), class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>

        <div class="ds-pishock-install-test">
          <p class="ds-beta-control-hint"><%= t("beta.pishock.test_hint_html") %></p>
          <%= button_to t("beta.pishock.test_button"), beta_pishock_test_path, method: :post, form: { data: { turbo_confirm: t("beta.pishock.test_confirm") } }, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
        </div>
      </div>
    </section>

    <section class="ds-beta-section">
      <h2 class="ds-section-title"><%= t("beta.integration_sections.configuration") %></h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text"><%= t("beta.pishock.description") %></p>
        <%= form_with url: beta_pishock_path, method: :patch, local: true, class: "ds-form ds-pishock-form" do %>
          <div class="ds-form-group">
            <%= label_tag :pishock_intensity_factor, t("beta.pishock.intensity_factor_label"), class: "ds-form-label" %>
            <% pif = current_user.pishock_intensity_factor.to_f; pif_display = pif % 1 == 0 ? pif.to_i : pif %>
            <%= number_field_tag :pishock_intensity_factor, pif_display, min: 0.01, max: 100, step: "any", class: "ds-input" %>
            <p class="ds-beta-control-hint ds-pishock-intensity-hint"><%= t("beta.pishock.intensity_hint") %></p>
          </div>
          <%= submit_tag t("beta.pishock.save"), class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>
      </div>
    </section>
