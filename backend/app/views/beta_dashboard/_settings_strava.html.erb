<% if current_user.strava_access_token.present? %>
  <% athlete = current_user.strava_athlete_id.present? ? t("beta.strava.athlete_suffix", id: current_user.strava_athlete_id) : "" %>

  <section class="ds-beta-section ds-beta-section--first">
    <h2 class="ds-section-title"><%= t("beta.integration_sections.installation") %></h2>
    <div class="ds-beta-control-card">
      <details class="ds-strava-install-drawer">
        <summary class="ds-strava-install-summary">
          <span class="ds-beta-control-text"><%= t("beta.strava.connected_line", athlete: athlete) %></span>
          <span class="ds-strava-toggle-icon" aria-hidden="true">▾</span>
        </summary>
        <div class="ds-strava-install-body">
          <p class="ds-beta-control-hint"><%= t("beta.strava.installation_connected_hint") %></p>
          <%= button_to t("beta.strava.disconnect"), strava_disconnect_path, method: :delete, form: { data: { turbo_confirm: t("beta.strava.disconnect_confirm") } }, class: "ds-btn ds-btn--secondary ds-btn--sm ds-strava-inline-action" %>
        </div>
      </details>
    </div>
  </section>

  <section class="ds-beta-section ds-beta-section--tight-top">
    <h2 class="ds-section-title"><%= t("beta.integration_sections.configuration") %></h2>
    <div class="ds-beta-control-card ds-strava-goals-intro">
      <p class="ds-beta-control-hint"><%= t("beta.strava.goals_hint") %></p>
    </div>

    <div class="ds-strava-goals" data-strava-goals>
      <% if @strava_goals.any? %>
        <% @strava_goals.each do |goal| %>
          <%= render "strava_goal_card", goal: goal %>
        <% end %>
      <% else %>
        <div class="ds-beta-control-card ds-strava-goals-empty">
          <p class="ds-beta-control-hint"><%= t("beta.strava.no_goals") %></p>
        </div>
      <% end %>

      <div class="ds-strava-goals-toolbar">
        <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-strava-show-new-goal>
          <%= t("beta.strava.add_goal") %>
        </button>
      </div>

      <div class="ds-beta-control-card ds-strava-new-goal-panel" data-strava-new-goal-panel hidden>
        <p class="ds-beta-control-text"><%= t("beta.strava.new_goal_title") %></p>
        <%= render "strava_goal_form",
              goal: nil,
              form_url: beta_strava_goals_path,
              form_method: :post,
              id_prefix: "new_strava_goal" %>
        <div class="ds-beta-control-actions">
          <button type="button" class="ds-btn ds-btn--ghost ds-btn--sm" data-strava-cancel-new-goal>
            <%= t("beta.strava.cancel") %>
          </button>
        </div>
      </div>
    </div>

    <%= render "strava_goals_script" %>

    <div class="ds-beta-control-card">
      <p class="ds-beta-control-text"><%= t("beta.strava.consequences_lead") %></p>
      <%= form_with url: beta_strava_config_path, method: :patch, local: true, class: "ds-form", data: { turbo: false, scenarios_form: true } do %>
        <%= render "scenarios_list",
              source: :strava,
              scenario_set: @strava_config.scenario_set,
              photos: @leverage_photos,
              strava_goals: @strava_goals,
              uid: "strava_config",
              section_title: t("beta.strava.consequences_title") %>
        <div class="ds-beta-control-actions">
          <%= submit_tag t("beta.strava.save_consequences"), class: "ds-btn ds-btn--primary ds-btn--sm" %>
        </div>
      <% end %>
      <%= render "scenarios_form_script" %>
    </div>
  </section>
<% elsif StravaService.configured? %>
  <section class="ds-beta-section ds-beta-section--first">
    <h2 class="ds-section-title"><%= t("beta.integration_sections.installation") %></h2>
    <div class="ds-beta-control-card">
      <p class="ds-beta-control-hint"><%= t("beta.strava.installation_disconnected_hint") %></p>
      <p class="ds-beta-control-text"><%= t("beta.strava.connect_pitch") %></p>
      <%= link_to t("beta.strava.connect_strava"), strava_connect_path, class: "ds-btn ds-btn--primary ds-btn--sm ds-strava-inline-action" %>
    </div>
  </section>
<% else %>
  <section class="ds-beta-section ds-beta-section--first">
    <h2 class="ds-section-title"><%= t("beta.integration_sections.installation") %></h2>
    <div class="ds-beta-control-card">
      <p class="ds-text-muted"><%= t("beta.strava.not_configured") %></p>
    </div>
  </section>
<% end %>
