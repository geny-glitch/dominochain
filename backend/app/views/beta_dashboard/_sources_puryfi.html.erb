<section class="ds-beta-section ds-beta-section--first">
  <h2 class="ds-section-title"><%= t("beta.puryfi.install_title") %></h2>
  <details class="ds-puryfi-install-drawer" <%= "open" unless @puryfi_installation_collapsed %>>
    <summary class="ds-puryfi-install-summary">
      <span class="ds-puryfi-install-summary-title"><%= t("beta.puryfi.drawer_url_title") %></span>
      <span class="ds-puryfi-install-summary-status">
        <% if @puryfi_events_count.to_i.positive? %>
          <span class="ds-beta-home-pill ds-beta-home-pill--on">
            <span class="ds-puryfi-inline-icon" aria-hidden="true">✓</span>
            <%= t("beta.puryfi.status_ready", count: @puryfi_events_count) %>
          </span>
        <% else %>
          <span class="ds-beta-home-pill"><%= t("beta.puryfi.status_waiting") %></span>
        <% end %>
        <span class="ds-puryfi-toggle-icon" aria-hidden="true">▾</span>
      </span>
    </summary>

    <div class="ds-puryfi-install-body">
      <p class="ds-beta-control-text ds-puryfi-ws-hint"><%= t("beta.puryfi.ws_hint") %></p>

      <% if @puryfi_ws_url.present? %>
        <p class="ds-beta-control-hint ds-puryfi-ws-url">
          <span id="puryfi-ws-url"><%= @puryfi_ws_url %></span>
        </p>

        <div class="ds-puryfi-install-actions">
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="puryfi-ws-url"><%= t("beta.puryfi.copy_url") %></button>
          <%= button_to t("beta.puryfi.regenerate"), beta_puryfi_regenerate_token_path, method: :post, form: { data: { turbo_confirm: t("beta.puryfi.regenerate_confirm") } }, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
        </div>
      <% end %>

      <% if @puryfi_last_event_at.present? %>
        <p class="ds-beta-control-hint"><%= t("beta.puryfi.last_event", time: l(@puryfi_last_event_at, format: :short)) %></p>
      <% end %>
    </div>
  </details>
</section>

<section class="ds-beta-section ds-beta-section--tight-top">
  <h2 class="ds-section-title"><%= t("beta.puryfi.config_title") %></h2>
  <div class="ds-beta-control-card ds-puryfi-config-card">
    <div class="ds-puryfi-save-toast" data-puryfi-save-toast hidden aria-live="polite"></div>
    <%= form_with url: beta_puryfi_path, method: :patch, local: true, html: { class: "ds-form", id: "puryfi-config-form", data: { puryfi_autosave: true } } do %>
      <div class="ds-form-group ds-puryfi-score-group">
        <%= label_tag :puryfi_min_score, t("beta.puryfi.min_score_label"), class: "ds-form-label" %>
        <%= number_field_tag :puryfi_min_score, (current_user.puryfi_min_score * 100).round, min: 0, max: 100, step: 1, class: "ds-input", data: { puryfi_autosave_min_score: true } %>
        <p class="ds-beta-control-hint ds-puryfi-score-hint">
          <%= t("beta.puryfi.min_score_hint") %>
        </p>
      </div>

      <p class="ds-beta-control-hint ds-puryfi-config-hint"><%= t("beta.puryfi.seconds_hint") %></p>
      <% if @puryfi_pishock_enabled %>
        <p class="ds-beta-control-hint ds-puryfi-config-hint"><%= t("beta.puryfi.shock_hint") %></p>
      <% end %>

      <div class="ds-puryfi-label-grid">
        <% @puryfi_label_ids.each do |id| %>
          <% image_url = PuryfiLabel.image_url_for(id) %>
          <% shock_level = PuryfiConfig.shock_level_for_label(current_user, id) %>
          <div class="ds-puryfi-label-card" data-puryfi-label-id="<%= id %>">
            <div class="ds-puryfi-label-visual">
              <% if image_url.present? %>
                <%= image_tag image_url, alt: "", class: "ds-puryfi-label-icon", loading: "lazy", decoding: "async" %>
              <% else %>
                <span class="ds-puryfi-label-fallback"><%= PuryfiLabel.name_for(id).first.upcase %></span>
              <% end %>
            </div>
            <div class="ds-form-group ds-puryfi-label-form-group">
              <%= label_tag "puryfi_seconds_#{id}", PuryfiLabel.name_for(id), class: "ds-form-label ds-puryfi-label-title" %>
              <div class="ds-puryfi-seconds-row">
                <div class="ds-puryfi-seconds-field">
                  <%= number_field_tag "puryfi_seconds_per_label[#{id}]", (current_user.puryfi_seconds_per_label[id.to_s] || 0), min: 0, max: 86_400, class: "ds-input ds-puryfi-seconds-input", data: { puryfi_autosave_seconds: id } %>
                  <span class="ds-puryfi-seconds-unit"><%= t("beta.puryfi.seconds_unit") %></span>
                </div>
                <% if @puryfi_pishock_enabled %>
                  <div class="ds-puryfi-shock-rating" data-puryfi-shock-rating data-shock-value="<%= shock_level %>">
                    <%= hidden_field_tag "puryfi_shock_level_per_label[#{id}]", shock_level, id: "puryfi_shock_level_#{id}", class: "ds-puryfi-shock-input" %>
                    <div class="ds-puryfi-shock-bolts" role="group" aria-label="<%= t("beta.puryfi.shock_aria", label: PuryfiLabel.name_for(id)) %>">
                      <% (1..3).each do |bolt| %>
                        <button type="button" class="ds-puryfi-shock-bolt<%= shock_level >= bolt ? " is-active" : "" %>" data-shock-bolt="<%= bolt %>" aria-pressed="<%= shock_level >= bolt ? "true" : "false" %>">
                          <svg class="ds-puryfi-shock-bolt-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path fill="currentColor" d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/>
                          </svg>
                          <span class="visually-hidden"><%= t("beta.puryfi.shock_level_label", count: bolt) %></span>
                        </button>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @puryfi_pishock_enabled %>
        <section class="ds-puryfi-pishock-levels">
          <h3 class="ds-puryfi-pishock-levels-title"><%= t("beta.puryfi.pishock_levels_title") %></h3>
          <p class="ds-beta-control-hint ds-puryfi-pishock-levels-hint"><%= t("beta.puryfi.pishock_levels_hint") %></p>
          <div class="ds-puryfi-pishock-levels-grid">
            <% (1..3).each do |level| %>
              <% settings = @puryfi_pishock_level_settings[level.to_s] || {} %>
              <div class="ds-puryfi-pishock-level-row">
                <div class="ds-puryfi-pishock-level-label">
                  <% level.times do %>
                    <svg class="ds-puryfi-shock-bolt-icon ds-puryfi-shock-bolt-icon--active" width="14" height="14" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path fill="currentColor" d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/>
                    </svg>
                  <% end %>
                  <span class="visually-hidden"><%= t("beta.puryfi.shock_level_label", count: level) %></span>
                </div>
                <div class="ds-puryfi-pishock-level-fields">
                  <div class="ds-form-group ds-puryfi-pishock-level-field">
                    <%= label_tag "puryfi_pishock_level_#{level}_intensity", t("beta.puryfi.pishock_intensity_label"), class: "ds-form-label" %>
                    <%= number_field_tag "puryfi_pishock_level_settings[#{level}][intensity]", settings["intensity"], min: 1, max: 100, class: "ds-input ds-puryfi-pishock-level-input", data: { puryfi_autosave_pishock_level: level, puryfi_autosave_pishock_field: "intensity" } %>
                  </div>
                  <div class="ds-form-group ds-puryfi-pishock-level-field">
                    <%= label_tag "puryfi_pishock_level_#{level}_duration", t("beta.puryfi.pishock_duration_label"), class: "ds-form-label" %>
                    <%= number_field_tag "puryfi_pishock_level_settings[#{level}][duration]", settings["duration"], min: 1, max: 15, class: "ds-input ds-puryfi-pishock-level-input", data: { puryfi_autosave_pishock_level: level, puryfi_autosave_pishock_field: "duration" } %>
                    <span class="ds-puryfi-seconds-unit"><%= t("beta.puryfi.seconds_unit") %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </div>
</section>

<script>
(function () {
  var form = document.getElementById("puryfi-config-form");
  if (!form || form.getAttribute("data-puryfi-autosave-ready") === "true") return;
  form.setAttribute("data-puryfi-autosave-ready", "true");

  var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || "";
  var toast = document.querySelector("[data-puryfi-save-toast]");
  var toastTimer = null;
  var pendingRequests = 0;
  var loginPath = "<%= j new_user_session_path %>";

  function rememberInitialValue(input) {
    if (!input || input.getAttribute("data-puryfi-initial-value") != null) return;
    input.setAttribute("data-puryfi-initial-value", input.value);
  }

  function valueChanged(input) {
    rememberInitialValue(input);
    return input.value !== input.getAttribute("data-puryfi-initial-value");
  }

  function markSaved(input) {
    if (!input) return;
    input.setAttribute("data-puryfi-initial-value", input.value);
  }

  form.querySelectorAll("input").forEach(rememberInitialValue);

  function debounce(fn, delay) {
    var timer = null;
    return function () {
      var args = arguments;
      var context = this;
      clearTimeout(timer);
      timer = setTimeout(function () {
        fn.apply(context, args);
      }, delay);
    };
  }

  function setToast(message, isError) {
    if (!toast) return;
    toast.textContent = message;
    toast.hidden = false;
    toast.classList.toggle("ds-puryfi-save-toast--error", !!isError);
    toast.classList.add("is-visible");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      toast.classList.remove("is-visible");
      toast.hidden = true;
    }, 2400);
  }

  function savePuryfi(params) {
    pendingRequests += 1;
    form.classList.add("is-saving");

    return fetch(form.action, {
      method: "PATCH",
      credentials: "same-origin",
      headers: {
        "X-CSRF-Token": csrfToken,
        "Accept": "application/json",
        "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8"
      },
      body: params.toString()
    })
      .then(function (response) {
        if (response.status === 401) {
          window.location.href = loginPath + "?return_to=" + encodeURIComponent(window.location.pathname);
          return Promise.reject(new Error("session_expired"));
        }
        return response.json().catch(function () { return {}; }).then(function (payload) {
          if (!response.ok) throw new Error(payload.error || "request_failed");
          return payload;
        });
      })
      .then(function (payload) {
        setToast(payload.message || "<%= j t("flash.beta.puryfi_saved") %>", false);
      })
      .catch(function (error) {
        if (error.message === "session_expired") return;
        setToast(error.message || "<%= j t("flash.beta.puryfi_save_failed") %>", true);
        throw error;
      })
      .finally(function () {
        pendingRequests = Math.max(0, pendingRequests - 1);
        if (pendingRequests === 0) form.classList.remove("is-saving");
      });
  }

  function saveMinScore(input) {
    if (!valueChanged(input)) return;
    var value = parseInt(input.value, 10);
    if (!Number.isFinite(value)) return;
    value = Math.max(0, Math.min(100, value));
    input.value = String(value);
    var params = new URLSearchParams();
    params.set("puryfi_min_score", String(value));
    return savePuryfi(params).then(function () { markSaved(input); });
  }

  function saveSeconds(input) {
    if (!valueChanged(input)) return;
    var labelId = input.getAttribute("data-puryfi-autosave-seconds");
    if (!labelId) return;
    var value = parseInt(input.value, 10);
    if (!Number.isFinite(value)) value = 0;
    value = Math.max(0, Math.min(86400, value));
    input.value = String(value);
    var params = new URLSearchParams();
    params.set("puryfi_seconds_per_label[" + labelId + "]", String(value));
    return savePuryfi(params).then(function () { markSaved(input); });
  }

  function saveShockLevel(rating) {
    var labelId = rating.closest("[data-puryfi-label-id]")?.getAttribute("data-puryfi-label-id");
    if (!labelId) return;
    var value = parseInt(rating.getAttribute("data-shock-value") || "0", 10);
    if (!Number.isFinite(value)) value = 0;
    value = Math.max(0, Math.min(3, value));
    var params = new URLSearchParams();
    params.set("puryfi_shock_level_per_label[" + labelId + "]", String(value));
    return savePuryfi(params);
  }

  function savePishockLevel(level) {
    var intensityInput = form.querySelector('[data-puryfi-autosave-pishock-level="' + level + '"][data-puryfi-autosave-pishock-field="intensity"]');
    var durationInput = form.querySelector('[data-puryfi-autosave-pishock-level="' + level + '"][data-puryfi-autosave-pishock-field="duration"]');
    if (!intensityInput || !durationInput) return;
    if (!valueChanged(intensityInput) && !valueChanged(durationInput)) return;

    var intensity = parseInt(intensityInput.value, 10);
    var duration = parseInt(durationInput.value, 10);
    if (!Number.isFinite(intensity)) intensity = 1;
    if (!Number.isFinite(duration)) duration = 1;
    intensity = Math.max(1, Math.min(100, intensity));
    duration = Math.max(1, Math.min(15, duration));
    intensityInput.value = String(intensity);
    durationInput.value = String(duration);

    var params = new URLSearchParams();
    params.set("puryfi_pishock_level_settings[" + level + "][intensity]", String(intensity));
    params.set("puryfi_pishock_level_settings[" + level + "][duration]", String(duration));
    return savePuryfi(params).then(function () {
      markSaved(intensityInput);
      markSaved(durationInput);
    });
  }

  function syncShockRating(rating) {
    if (!rating) return;
    var value = parseInt(rating.getAttribute("data-shock-value") || "0", 10);
    if (!Number.isFinite(value)) value = 0;
    value = Math.max(0, Math.min(3, value));
    rating.setAttribute("data-shock-value", String(value));
    var input = rating.querySelector(".ds-puryfi-shock-input");
    if (input) input.value = String(value);
    rating.querySelectorAll("[data-shock-bolt]").forEach(function (bolt) {
      var boltValue = parseInt(bolt.getAttribute("data-shock-bolt"), 10);
      var active = value >= boltValue;
      bolt.classList.toggle("is-active", active);
      bolt.setAttribute("aria-pressed", active ? "true" : "false");
    });
  }

  function previewShockRating(rating, hoverValue) {
    if (!rating) return;
    rating.querySelectorAll("[data-shock-bolt]").forEach(function (bolt) {
      var boltValue = parseInt(bolt.getAttribute("data-shock-bolt"), 10);
      bolt.classList.toggle("is-hover", hoverValue >= boltValue);
    });
  }

  var debouncedSaveMinScore = debounce(function (input) {
    saveMinScore(input);
  }, 450);

  var debouncedSaveSeconds = debounce(function (input) {
    saveSeconds(input);
  }, 450);

  var debouncedSavePishockLevel = debounce(function (level) {
    savePishockLevel(level);
  }, 450);

  form.addEventListener("submit", function (event) {
    event.preventDefault();
  });

  var minScoreInput = form.querySelector("[data-puryfi-autosave-min-score]");
  if (minScoreInput) {
    minScoreInput.addEventListener("change", function () {
      debouncedSaveMinScore(minScoreInput);
    });
  }

  form.querySelectorAll("[data-puryfi-autosave-seconds]").forEach(function (input) {
    input.addEventListener("change", function () {
      debouncedSaveSeconds(input);
    });
  });

  form.querySelectorAll("[data-puryfi-autosave-pishock-level]").forEach(function (input) {
    input.addEventListener("change", function () {
      var level = input.getAttribute("data-puryfi-autosave-pishock-level");
      if (level) debouncedSavePishockLevel(level);
    });
  });

  form.querySelectorAll("[data-puryfi-shock-rating]").forEach(function (rating) {
    syncShockRating(rating);

    rating.addEventListener("click", function (event) {
      var bolt = event.target.closest("[data-shock-bolt]");
      if (!bolt || !rating.contains(bolt)) return;
      event.preventDefault();
      var boltValue = parseInt(bolt.getAttribute("data-shock-bolt"), 10);
      var current = parseInt(rating.getAttribute("data-shock-value") || "0", 10);
      var next = current === boltValue ? 0 : boltValue;
      rating.setAttribute("data-shock-value", String(next));
      syncShockRating(rating);
      saveShockLevel(rating)?.catch(function () {
        rating.setAttribute("data-shock-value", String(current));
        syncShockRating(rating);
      });
    });

    rating.addEventListener("mousemove", function (event) {
      var bolt = event.target.closest("[data-shock-bolt]");
      if (!bolt || !rating.contains(bolt)) {
        previewShockRating(rating, 0);
        return;
      }
      previewShockRating(rating, parseInt(bolt.getAttribute("data-shock-bolt"), 10));
    });

    rating.addEventListener("mouseleave", function () {
      previewShockRating(rating, 0);
    });
  });
})();
</script>
