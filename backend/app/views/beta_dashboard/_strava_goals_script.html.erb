<script>
(function () {
  var root = document.querySelector("[data-strava-goals]");
  if (!root) return;

  function closeAllEdits(exceptCard) {
    root.querySelectorAll("[data-strava-goal-card]").forEach(function (card) {
      if (exceptCard && card === exceptCard) return;
      var recap = card.querySelector("[data-strava-goal-recap]");
      var form = card.querySelector("[data-strava-goal-form]");
      if (recap) recap.hidden = false;
      if (form) form.hidden = true;
    });
  }

  function hideNewGoalPanel() {
    var panel = root.querySelector("[data-strava-new-goal-panel]");
    var showBtn = root.querySelector("[data-strava-show-new-goal]");
    if (panel) panel.hidden = true;
    if (showBtn) showBtn.hidden = false;
  }

  function showNewGoalPanel() {
    closeAllEdits(null);
    var panel = root.querySelector("[data-strava-new-goal-panel]");
    var showBtn = root.querySelector("[data-strava-show-new-goal]");
    if (panel) {
      panel.hidden = false;
      var nameInput = panel.querySelector("input[name='name']");
      if (nameInput) nameInput.focus();
    }
    if (showBtn) showBtn.hidden = true;
  }

  root.addEventListener("click", function (event) {
    var editBtn = event.target.closest("[data-strava-goal-edit]");
    if (editBtn && root.contains(editBtn)) {
      var card = editBtn.closest("[data-strava-goal-card]");
      if (!card) return;
      hideNewGoalPanel();
      closeAllEdits(card);
      var recap = card.querySelector("[data-strava-goal-recap]");
      var form = card.querySelector("[data-strava-goal-form]");
      if (recap) recap.hidden = true;
      if (form) form.hidden = false;
      return;
    }

    var cancelEditBtn = event.target.closest("[data-strava-goal-cancel-edit]");
    if (cancelEditBtn && root.contains(cancelEditBtn)) {
      var card = cancelEditBtn.closest("[data-strava-goal-card]");
      if (!card) return;
      var recap = card.querySelector("[data-strava-goal-recap]");
      var form = card.querySelector("[data-strava-goal-form]");
      if (recap) recap.hidden = false;
      if (form) form.hidden = true;
      return;
    }

    if (event.target.closest("[data-strava-show-new-goal]")) {
      showNewGoalPanel();
      return;
    }

    if (event.target.closest("[data-strava-cancel-new-goal]")) {
      hideNewGoalPanel();
    }
  });
})();
</script>
