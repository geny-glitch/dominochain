<%# locals: (verification_session: nil, device: nil) %>
<% verification_session = local_assigns[:verification_session] %>
<% device = local_assigns[:device] %>
<% locked = verification_session.present? %>

<section class="ds-beta-section ds-beta-section--tight-top">
  <h2 class="ds-section-title"><%= t("beta.wallpaper_source.verification_session_title") %></h2>
  <div class="ds-beta-control-card">
    <% if locked %>
      <p class="ds-beta-control-text"><%= t("beta.wallpaper_source.verification_session_active_lead") %></p>
      <ul class="ds-beta-bullet-list">
        <li>
          <%= t("beta.wallpaper_source.verification_session_ends_at", time: l(verification_session.ends_at, format: :short)) %>
        </li>
        <li>
          <%= t("beta.wallpaper_source.verification_session_duration", hours: verification_session.duration_hours) %>
        </li>
        <% if verification_session.wallpaper.image.attached? %>
          <li><%= t("beta.wallpaper_source.verification_session_locked_wallpaper") %></li>
        <% end %>
      </ul>
      <p class="ds-beta-control-hint"><%= t("beta.wallpaper_source.verification_session_locked_hint") %></p>
    <% else %>
      <p class="ds-beta-control-text"><%= t("beta.wallpaper_source.verification_session_lead") %></p>
      <% if device&.current_wallpaper&.image&.attached? %>
        <%= form_with url: beta_wallpaper_verification_sessions_path, method: :post, local: true, class: "ds-form", data: { turbo: false } do %>
          <div class="ds-form-group">
            <%= label_tag :duration_hours, t("beta.wallpaper_source.verification_session_duration_label"), class: "ds-form-label" %>
            <%= select_tag :duration_hours,
                  options_for_select(
                    WallpaperVerificationSession::ALLOWED_DURATION_HOURS.map { |hours|
                      [t("beta.wallpaper_source.verification_session_durations.#{hours}"), hours]
                    }
                  ),
                  class: "ds-input",
                  required: true %>
            <p class="ds-beta-control-hint"><%= t("beta.wallpaper_source.verification_session_duration_hint") %></p>
          </div>
          <div class="ds-beta-control-actions">
            <%= submit_tag t("beta.wallpaper_source.verification_session_start"),
                  class: "ds-btn ds-btn--primary ds-btn--sm",
                  data: { turbo_confirm: t("beta.wallpaper_source.verification_session_start_confirm") } %>
          </div>
        <% end %>
      <% else %>
        <p class="ds-beta-control-hint"><%= t("beta.wallpaper_source.verification_session_no_wallpaper") %></p>
      <% end %>
    <% end %>
  </div>
</section>

<% if @verification_sessions&.any? %>
  <section class="ds-beta-section ds-beta-section--tight-top">
    <h2 class="ds-section-title"><%= t("beta.wallpaper_source.verification_session_history_title") %></h2>
    <div class="ds-beta-control-card">
      <ul class="ds-beta-bullet-list">
        <% @verification_sessions.each do |session| %>
          <li>
            <strong><%= t("beta.wallpaper_source.verification_session_status.#{session.status}") %></strong>
            — <%= l(session.started_at, format: :short) %>
            <% if session.ends_at.present? %>
              · <%= t("beta.wallpaper_source.verification_session_duration", hours: session.duration_hours) %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </section>
<% end %>
