<% content_for :title, t("beta.chess.goal_page.title", name: @goal.name) %>

<header class="ds-beta-page-head">
  <p class="ds-beta-page-lead" style="margin-bottom:0.35rem;">
    <%= link_to t("beta.chess.goal_page.back"), beta_sources_chess_path, class: "ds-beta-home-muted" %>
  </p>
  <h1 class="ds-beta-page-title"><%= @goal.name %></h1>
  <p class="ds-beta-page-lead"><%= t("beta.chess.goal_page.lead") %></p>
</header>

<% if @preview_result.present? %>
  <section class="ds-beta-section ds-beta-section--first">
    <div class="ds-beta-control-card ds-chess-preview-result">
      <p class="ds-beta-control-text"><%= chess_preview_result_notice(@preview_result, goal: @goal) %></p>
      <p class="ds-beta-control-hint"><%= t("beta.chess.goal_page.preview_hint") %></p>
    </div>
  </section>
<% end %>

<section class="ds-beta-section <%= @preview_result.present? ? "ds-beta-section--tight-top" : "ds-beta-section--first" %>">
  <h2 class="ds-section-title"><%= t("beta.chess.goal_page.recap_title") %></h2>
  <%= render "chess_goal_recap_panel", goal: @goal %>
</section>

<section class="ds-beta-section ds-beta-section--tight-top">
  <h2 class="ds-section-title"><%= t("beta.chess.goal_page.checks_title") %></h2>
  <div class="ds-beta-control-card">
    <div class="ds-chess-goal-check-actions">
      <%= button_to t("beta.chess.goal_page.preview_check"),
            beta_chess_goal_preview_check_path(@goal),
            method: :post,
            class: "ds-btn ds-btn--secondary ds-btn--sm",
            form: { data: { turbo: false } } %>
      <%= button_to t("beta.chess.goal_page.run_check"),
            beta_chess_goal_check_path(@goal),
            method: :post,
            class: "ds-btn ds-btn--primary ds-btn--sm",
            form: { data: { turbo: false, turbo_confirm: t("beta.chess.goal_page.check_confirm") } } %>
    </div>
    <p class="ds-beta-control-hint"><%= t("beta.chess.goal_page.preview_check_hint") %></p>
    <p class="ds-beta-control-hint"><%= chess_goal_deadline_line(@goal) %></p>
  </div>
  <%= render "chess_goal_checks_list", checks: @checks, goal: @goal %>
</section>

<%= render "chess_goals_script" %>
