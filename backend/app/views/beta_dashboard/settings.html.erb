<% content_for :title, "Catalogue — #{current_user.nickname}" %>

<header class="ds-beta-page-head">
  <h1 class="ds-beta-page-title">Catalogue</h1>
  <p class="ds-beta-page-lead">
    Tes sources et actions installées, avec des raccourcis directs vers leur configuration.
  </p>
</header>

<section class="ds-beta-section ds-beta-section--first">
  <div class="ds-section-header">
    <h2 class="ds-section-title">Sources installées</h2>
    <span class="ds-beta-control-hint">4</span>
  </div>
  <div class="ds-beta-catalog-grid">
    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">Purify (PuryFi)</h3>
      <p class="ds-beta-catalog-sub">Extension navigateur · détections par étiquette</p>
      <p class="ds-beta-catalog-events">Événement: <code class="ds-code-inline">detection.label</code></p>
      <%= link_to "Configurer", beta_sources_puryfi_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>

    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">Cigarettes</h3>
      <p class="ds-beta-catalog-sub">App Android · déclarations manuelles</p>
      <p class="ds-beta-catalog-events">Événement: <code class="ds-code-inline">cigarette.created</code></p>
      <%= link_to "Configurer", beta_sources_cigarettes_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>

    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">Strava</h3>
      <p class="ds-beta-catalog-sub">Objectifs glissants (1, 7 ou X jours)</p>
      <p class="ds-beta-catalog-events">Événement: <code class="ds-code-inline">goal.failed</code></p>
      <%= link_to "Configurer", beta_sources_strava_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>

    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">Vitrine</h3>
      <p class="ds-beta-catalog-sub">Page publique, QR, jeux, backdoor</p>
      <p class="ds-beta-catalog-events">Événements: Snake, Quiz, Tétris, Dino, backdoor</p>
      <%= link_to "Configurer", beta_sources_showcase_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>
  </div>
</section>

<section class="ds-beta-section">
  <div class="ds-section-header">
    <h2 class="ds-section-title">Actions installées</h2>
    <span class="ds-beta-control-hint">2</span>
  </div>
  <div class="ds-beta-catalog-grid ds-beta-catalog-grid--actions">
    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">Chaster</h3>
      <p class="ds-beta-catalog-sub">Lock principal · temps restant</p>
      <p class="ds-beta-catalog-events">Consomme le temps envoyé par les sources</p>
      <%= link_to "Configurer", beta_actions_chaster_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>

    <article class="ds-beta-catalog-card">
      <h3 class="ds-beta-catalog-title">PiShock</h3>
      <p class="ds-beta-catalog-sub">Collier / shocker · réactions physiques</p>
      <p class="ds-beta-catalog-events">Actions: zap, intensité multipliée par facteur Z</p>
      <%= link_to "Configurer", beta_actions_pishock_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </article>
  </div>
</section>

