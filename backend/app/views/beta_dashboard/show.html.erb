<% content_for :title, "Dashboard Beta - #{current_user.nickname}" %>

<div class="ds-page">
  <div class="ds-container">
    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Dashboard Beta</h1>
        <p class="ds-subtitle"><%= current_user.nickname %></p>
      </div>
    </header>

    <details class="ds-beta-section" style="margin-bottom: 0.5rem;">
      <summary class="ds-section-title" style="cursor: pointer;">Sections affichées</summary>
      <p class="ds-beta-control-hint" style="margin: 0.5rem 0;">Décoche pour masquer une zone (contrôle, vitrine, PiShock, etc.).</p>
      <%= form_with url: beta_dashboard_sections_path, method: :patch, local: true, class: "ds-form" do %>
        <% BetaCapabilities::SECTION_IDS.each do |sid| %>
          <div class="ds-form-group" style="margin-bottom: 0.35rem;">
            <label class="ds-form-label" style="font-weight: normal;">
              <%= check_box_tag "visible_sections[]", sid, @capabilities.visible?(sid), id: "dashboard_vis_#{sid}" %>
              <%= sid.humanize %>
            </label>
          </div>
        <% end %>
        <%= submit_tag "Enregistrer les sections", class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-top: 0.5rem;" %>
      <% end %>
    </details>

    <%= render "chaster" if @capabilities.visible?(:chaster) %>
    <%= render "strava" if @capabilities.visible?(:strava) %>
    <%= render "puryfi" if @capabilities.visible?(:puryfi) %>
    <%= render "pishock" if @capabilities.visible?(:pishock) %>
    <%= render "showcase" if @capabilities.visible?(:showcase) %>
    <%= render "control" if @capabilities.visible?(:control) %>
    <%= render "tasks" if @capabilities.visible?(:tasks) %>
    <%= render "devices" if @capabilities.visible?(:devices) %>

    <p class="ds-beta-footer">
      <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "ds-btn ds-btn--ghost" %>
    </p>
  </div>
</div>

<script>
(function() {
  document.querySelectorAll('[data-copy-target]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const id = btn.dataset.copyTarget;
      const el = document.getElementById(id);
      if (!el) return;
      const text = el.textContent;
      navigator.clipboard.writeText(text).then(function() {
        var orig = btn.textContent;
        btn.textContent = 'Copié !';
        setTimeout(function() { btn.textContent = orig; }, 1500);
      });
    });
  });

  var countdownEl = document.getElementById('chaster-countdown');
  if (countdownEl && countdownEl.dataset.isFrozen !== 'true') {
    var endDateStr = countdownEl.dataset.endDate;
    if (endDateStr) {
      var endTime = new Date(endDateStr).getTime();
      function formatRemaining(sec) {
        if (sec <= 0) return 'Terminé';
        var d = Math.floor(sec / 86400);
        var h = Math.floor((sec % 86400) / 3600);
        var m = Math.floor((sec % 3600) / 60);
        var s = sec % 60;
        if (d > 0) return d + 'j ' + h + 'h ' + m + 'min ' + s + 's';
        if (h > 0) return h + 'h ' + m + 'min ' + s + 's';
        if (m > 0) return m + 'min ' + s + 's';
        return s + 's';
      }
      function tick() {
        var remaining = Math.floor((endTime - Date.now()) / 1000);
        if (remaining <= 0) {
          countdownEl.textContent = 'Terminé';
          return;
        }
        countdownEl.textContent = formatRemaining(remaining);
        setTimeout(tick, 1000);
      }
      tick();
    }
  }
})();
</script>
