<% content_for :title, "Dashboard Beta - #{current_user.nickname}" %>

<div class="ds-page">
  <div class="ds-container">
    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Dashboard Beta</h1>
        <p class="ds-subtitle"><%= current_user.nickname %></p>
      </div>
    </header>

    <%# Chaster %>
    <section class="ds-beta-section">
      <div class="ds-section-header">
        <h2 class="ds-section-title">Chaster</h2>
        <% if current_user.chaster_access_token.present? %>
          <%= link_to beta_dashboard_path, class: "ds-btn ds-btn--icon ds-btn--ghost", title: "Actualiser" do %>
            <svg class="ds-icon-refresh" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          <% end %>
        <% end %>
      </div>
      <% if current_user.chaster_access_token.present? %>
        <div class="ds-beta-control-card">
          <% if @chaster_lock %>
            <p class="ds-beta-control-text"><%= @chaster_lock[:title].presence || "Lock en cours" %></p>
            <p class="ds-chaster-countdown" id="chaster-countdown"
               data-end-date="<%= @chaster_lock[:end_date] %>"
               data-is-frozen="<%= @chaster_lock[:is_frozen] %>">
              <%= @chaster_lock[:is_frozen] ? "Gelé" : format_chaster_remaining(@chaster_lock[:remaining_seconds]) %>
            </p>
            <p class="ds-beta-control-hint">Le temps restant s'affiche aussi sur l'app et le widget.</p>
          <% else %>
            <p class="ds-beta-control-text">Chaster connecté</p>
            <p class="ds-beta-control-hint">Aucun lock en cours. Le temps restant s'affiche sur l'app et le widget.</p>
          <% end %>
          <%= button_to "Déconnecter Chaster", chaster_disconnect_path, method: :delete, form: { data: { turbo_confirm: "Déconnecter ton compte Chaster ? Tu devras te reconnecter pour voir le lock." } }, class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-top: 0.5rem;" %>
        </div>
      <% elsif ChasterService.configured? %>
        <div class="ds-beta-control-card ds-beta-control-card--invite">
          <p class="ds-beta-control-text">Connecte ton compte Chaster pour afficher le temps restant sur l'app.</p>
          <%= link_to "Connecter Chaster", chaster_connect_path, class: "ds-btn ds-btn--primary ds-btn--sm", style: "margin-top: 0.5rem;" %>
        </div>
      <% else %>
        <p class="ds-text-muted">Chaster n'est pas configuré sur ce serveur.</p>
      <% end %>
    </section>

    <%# PuryFi WebSocket %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">PuryFi + Chaster</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">
          Colle cette URL dans ton plugin PuryFi (WebSocket). Elle identifie ton compte — pas besoin de token API BG sur le serveur Fly.
        </p>
        <% if @puryfi_ws_url.present? %>
          <p class="ds-beta-control-hint" style="word-break: break-all; font-family: ui-monospace, monospace;">
            <span id="puryfi-ws-url"><%= @puryfi_ws_url %></span>
          </p>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="puryfi-ws-url">Copier l’URL</button>
          <%= button_to "Régénérer l’URL (révoque l’ancienne)", beta_puryfi_regenerate_token_path, method: :post, form: { data: { turbo_confirm: "Les plugins qui utilisent l’ancienne URL cesseront de fonctionner. Continuer ?" } }, class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-left: 0.5rem;" %>
        <% end %>
        <%= form_with url: beta_puryfi_path, method: :patch, local: true, class: "ds-form", style: "margin-top: 1rem;" do %>
          <div class="ds-form-group">
            <%= label_tag :puryfi_min_score, "Score minimum de détection (0–1)", class: "ds-form-label" %>
            <%= number_field_tag :puryfi_min_score, current_user.puryfi_min_score, min: 0, max: 1, step: 0.05, class: "ds-input" %>
          </div>
          <p class="ds-beta-control-hint" style="margin-bottom: 0.5rem;">Secondes ajoutées au lock par étiquette détectée (0 = ignorée).</p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr)); gap: 0.5rem 1rem; max-height: 18rem; overflow-y: auto; padding: 0.25rem 0;">
            <% @puryfi_label_ids.each do |id| %>
              <div class="ds-form-group" style="margin: 0;">
                <%= label_tag "puryfi_seconds_#{id}", "#{id} — #{PuryfiLabel.name_for(id)}", class: "ds-form-label", style: "font-size: 0.8rem;" %>
                <%= number_field_tag "puryfi_seconds_per_label[#{id}]", (current_user.puryfi_seconds_per_label[id.to_s] || 0), min: 0, max: 86_400, class: "ds-input" %>
              </div>
            <% end %>
          </div>
          <%= submit_tag "Enregistrer PuryFi", class: "ds-btn ds-btn--primary ds-btn--sm", style: "margin-top: 0.75rem;" %>
        <% end %>
      </div>
    </section>

    <%# PiShock %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">PiShock</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">Connecte ton collier pour recevoir un choc léger à chaque fruit mangé au Snake et un choc proportionnel à ton score quand un joueur s’inscrit au leaderboard (quiz ou snake).</p>
        <p class="ds-beta-control-hint">Crée une clé API et un share code sur <a href="https://pishock.com" target="_blank" rel="noopener noreferrer">pishock.com</a> — voir aussi la <a href="https://apidocs.pishock.com/" target="_blank" rel="noopener noreferrer">documentation API</a> et la <a href="https://docs.pishock.com/pishock/api-documentation/pishock-api-documentation.html" target="_blank" rel="noopener noreferrer">doc étapes auth / devices</a>. <%= link_to "Page debug (étapes API)", beta_pishock_debug_path %></p>
        <%= form_with url: beta_pishock_path, method: :patch, local: true, class: "ds-form", style: "margin-top: 0.75rem;" do %>
          <%= hidden_field_tag :pishock_enabled, "0" %>
          <div class="ds-form-group">
            <label class="ds-form-label">
              <%= check_box_tag :pishock_enabled, "1", current_user.pishock_enabled, id: "pishock_enabled" %>
              Activer PiShock pour ma vitrine
            </label>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_username, "Nom d’utilisateur PiShock", class: "ds-form-label" %>
            <%= text_field_tag :pishock_username, current_user.pishock_username, class: "ds-input", autocomplete: "username" %>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_share_code, "Share code", class: "ds-form-label" %>
            <%= text_field_tag :pishock_share_code, current_user.pishock_share_code, class: "ds-input", autocomplete: "off" %>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_api_key, "Clé API", class: "ds-form-label" %>
            <%= password_field_tag :pishock_api_key, nil, class: "ds-input", autocomplete: "new-password", placeholder: current_user.pishock_api_key.present? ? "•••••••• (laisser vide pour ne pas changer)" : "" %>
          </div>
          <div class="ds-form-group">
            <%= label_tag :pishock_intensity_factor, "Facteur d'intensité Z", class: "ds-form-label" %>
            <% pif = current_user.pishock_intensity_factor.to_f; pif_display = pif % 1 == 0 ? pif.to_i : pif %>
            <%= number_field_tag :pishock_intensity_factor, pif_display, min: 0.01, max: 100, step: "any", class: "ds-input" %>
            <p class="ds-beta-control-hint" style="margin-top: 0.25rem;">Multiplie l'intensité de tous les chocs. Z=1 = normal · Z=10 → 1 ligne Tétris = intensité 10 · Z=0.5 → moitié moins fort. Max 100.</p>
          </div>
          <%= submit_tag "Enregistrer PiShock", class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>
        <p class="ds-beta-control-hint" style="margin-top: 0.75rem;">Teste avec les identifiants <strong>déjà enregistrés</strong> (enregistre le formulaire si tu viens de les modifier).</p>
        <%= button_to "Tester la connexion (API publique + bip 1 s)", beta_pishock_test_path, method: :post, form: { data: { turbo_confirm: "Valider le compte sur api.pishock.com, rattacher le share code si besoin, puis bip de test ?" } }, class: "ds-btn ds-btn--secondary ds-btn--sm", style: "margin-top: 0.5rem;" %>
      </div>
    </section>

    <%# Vitrine %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">Ma vitrine</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">Ta page publique. Partage ce lien ou scanne le QR code pour que les visiteurs puissent ajouter du temps à ton lock.</p>
        <div class="ds-showcase-preview">
          <div class="ds-showcase-qr">
            <%= raw @showcase_qr %>
          </div>
          <div class="ds-showcase-link">
            <%= link_to showcase_url(current_user.nickname), showcase_path(current_user.nickname), id: "showcase-url", target: "_blank", rel: "noopener", class: "ds-showcase-link-url" %>
            <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="showcase-url" title="Copier">
              Copier
            </button>
          </div>
        </div>
      </div>
      <%= form_with url: beta_snake_seconds_path, method: :patch, local: true, class: "ds-form", style: "margin-top: 1rem;" do %>
        <h3 class="ds-section-title" style="margin-bottom: 0.5rem; font-size: 1rem;">Jeux vitrine</h3>
        <p class="ds-beta-control-hint" style="margin-bottom: 0.75rem;">Nombre de secondes ajoutées au lock Chaster pour chaque action de score. Chaque jeu a son propre réglage; une réduction n'est possible que 24 h après le dernier changement de ce jeu.</p>
        <div class="ds-form-group">
          <%= label_tag :showcase_quiz_seconds_per_point, "Quiz - secondes par point", class: "ds-form-label" %>
          <%= number_field_tag :showcase_quiz_seconds_per_point, current_user.showcase_quiz_seconds_per_point, min: 1, max: 86_400 * 365, class: "ds-input", required: true %>
        </div>
        <div class="ds-form-group">
          <%= label_tag :showcase_snake_seconds_per_fruit, "Snake - secondes par pomme", class: "ds-form-label" %>
          <%= number_field_tag :showcase_snake_seconds_per_fruit, current_user.showcase_snake_seconds_per_fruit, min: 1, max: 86_400 * 365, class: "ds-input", required: true %>
        </div>
        <div class="ds-form-group">
          <%= label_tag :showcase_dino_seconds_per_obstacle, "Dino Run - secondes par obstacle", class: "ds-form-label" %>
          <%= number_field_tag :showcase_dino_seconds_per_obstacle, current_user.showcase_dino_seconds_per_obstacle, min: 1, max: 86_400 * 365, class: "ds-input", required: true %>
        </div>
        <div class="ds-form-group">
          <%= label_tag :showcase_tetris_seconds_per_line, "Tétris - secondes par ligne complète", class: "ds-form-label" %>
          <%= number_field_tag :showcase_tetris_seconds_per_line, current_user.showcase_tetris_seconds_per_line, min: 1, max: 86_400 * 365, class: "ds-input", required: true %>
        </div>
        <%= submit_tag "Enregistrer le temps des jeux", class: "ds-btn ds-btn--secondary ds-btn--sm" %>
      <% end %>
      <%= form_with url: beta_backdoor_path, method: :patch, local: true, class: "ds-form", style: "margin-top: 1rem;" do %>
        <%= hidden_field_tag :showcase_backdoor_enabled, "0" %>
        <div class="ds-form-group">
          <label class="ds-form-label">
            <%= check_box_tag :showcase_backdoor_enabled, "1", current_user.showcase_backdoor_enabled?, id: "showcase_backdoor_enabled" %>
            Activer la page backdoor (URL fixe, non affichée sur la vitrine : <%= showcase_backdoor_path(current_user.nickname) %>)
          </label>
        </div>
        <%= submit_tag "Enregistrer la page backdoor", class: "ds-btn ds-btn--secondary ds-btn--sm" %>
      <% end %>
      <p class="ds-beta-control-hint" style="margin-top: 0.75rem;">La backdoor permet d’ajouter du temps au lock Chaster (1 s à 24 h par clic). Même limite que la vitrine : au plus 2 jours ajoutés sur une fenêtre glissante de 5 minutes.</p>
    </section>

    <%# Contrôle — qui contrôle ou lien d'invitation %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">Contrôle</h2>
      <% if @control&.accepted? %>
        <div class="ds-beta-control-card">
          <p class="ds-beta-control-text">Contrôlé par <strong><%= @control.boss.nickname %></strong></p>
          <p class="ds-beta-control-hint">Le boss peut gérer tes wallpapers et tâches via le lien partagé.</p>
        </div>
      <% else %>
        <div class="ds-beta-control-card ds-beta-control-card--invite">
          <p class="ds-beta-control-text">Personne ne te contrôle pour le moment.</p>
          <p class="ds-beta-control-hint">Partage ce lien pour inviter quelqu'un à te contrôler :</p>
          <div class="ds-beta-invite-link">
            <code id="invite-url"><%= @invite_url %></code>
            <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-copy-target="invite-url" title="Copier">
              Copier
            </button>
          </div>
          <p class="ds-beta-control-hint ds-beta-control-hint--small">Tu peux aussi envoyer une demande depuis l'app en entrant le pseudo du boss.</p>
        </div>
      <% end %>
    </section>

    <%# Tâches en cours %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">Tâches en cours</h2>
      <% if @tasks.any? %>
        <ul class="ds-task-list">
          <% @tasks.each do |task| %>
            <li class="ds-task-card">
              <div class="ds-task-card-info">
                <span class="ds-task-card-name"><%= task.name %></span>
                <div class="ds-task-card-meta">
                  Deadline: <%= task.deadline_at.strftime("%d/%m %H:%M") %>
                  · <span class="ds-task-status ds-task-status--<%= task.effective_status %>"><%= task.effective_status %></span>
                  <% if task.proof_pending? %>
                    · <span class="ds-task-status ds-task-status--pending">Preuve en attente</span>
                  <% elsif task.proof_accepted? %>
                    · <span class="ds-task-status ds-task-status--completed">Preuve acceptée</span>
                  <% end %>
                </div>
              </div>
              <div class="ds-task-card-actions">
                <% if task.can_submit_proof? %>
                  <%= link_to "Soumettre preuve", beta_task_path(task), class: "ds-btn ds-btn--primary ds-btn--sm" %>
                <% elsif task.proof_pending? %>
                  <span class="ds-btn ds-btn--ghost ds-btn--sm" disabled>En attente de validation</span>
                <% elsif task.proof_accepted? %>
                  <span class="ds-btn ds-btn--ghost ds-btn--sm" disabled>✓ Validé</span>
                <% else %>
                  <span class="ds-btn ds-btn--ghost ds-btn--sm" disabled><%= task.effective_status %></span>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="ds-text-muted">Aucune tâche pour le moment.</p>
      <% end %>
    </section>

    <%# Devices — liste seule, pas de suppression %>
    <section class="ds-beta-section">
      <h2 class="ds-section-title">Devices</h2>
      <% if @devices.any? %>
        <ul class="ds-beta-device-list">
          <% @devices.each do |device| %>
            <li class="ds-beta-device-card">
              <div class="ds-device-info">
                <span class="ds-device-name"><%= device.display_name %></span>
                <% if device.name.present? %>
                  <span class="ds-sep">·</span>
                  <span class="ds-device-id"><%= device.device_id %></span>
                <% end %>
                <% if device.screen_width.present? && device.screen_height.present? %>
                  <span class="ds-sep">·</span>
                  <span><%= device.screen_width %>×<%= device.screen_height %></span>
                <% end %>
                <% if device.fcm_token.present? %>
                  <span class="ds-sep">·</span>
                  <span class="ds-status ds-status--on">Push</span>
                <% else %>
                  <span class="ds-sep">·</span>
                  <span class="ds-status ds-status--off">Push off</span>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="ds-text-muted">Aucun device. Ouvre l'app pour t'enregistrer.</p>
      <% end %>
    </section>

    <p class="ds-beta-footer">
      <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "ds-btn ds-btn--ghost" %>
    </p>
  </div>
</div>

<script>
(function() {
  document.querySelectorAll('[data-copy-target]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const id = btn.dataset.copyTarget;
      const el = document.getElementById(id);
      if (!el) return;
      const text = el.textContent;
      navigator.clipboard.writeText(text).then(function() {
        var orig = btn.textContent;
        btn.textContent = 'Copié !';
        setTimeout(function() { btn.textContent = orig; }, 1500);
      });
    });
  });

  // Décompte Chaster
  var countdownEl = document.getElementById('chaster-countdown');
  if (countdownEl && countdownEl.dataset.isFrozen !== 'true') {
    var endDateStr = countdownEl.dataset.endDate;
    if (endDateStr) {
      var endTime = new Date(endDateStr).getTime();
      function formatRemaining(sec) {
        if (sec <= 0) return 'Terminé';
        var d = Math.floor(sec / 86400);
        var h = Math.floor((sec % 86400) / 3600);
        var m = Math.floor((sec % 3600) / 60);
        var s = sec % 60;
        if (d > 0) return d + 'j ' + h + 'h ' + m + 'min ' + s + 's';
        if (h > 0) return h + 'h ' + m + 'min ' + s + 's';
        if (m > 0) return m + 'min ' + s + 's';
        return s + 's';
      }
      function tick() {
        var remaining = Math.floor((endTime - Date.now()) / 1000);
        if (remaining <= 0) {
          countdownEl.textContent = 'Terminé';
          return;
        }
        countdownEl.textContent = formatRemaining(remaining);
        setTimeout(tick, 1000);
      }
      tick();
    }
  }
})();
</script>
