<% content_for :title, t("leverage_photo.source.title") %>

<header class="ds-beta-page-head">
  <h1 class="ds-beta-page-title"><%= t("leverage_photo.source.page_title") %></h1>
  <p class="ds-beta-page-lead"><%= t("leverage_photo.source.lead") %></p>
</header>

<section class="ds-beta-section ds-beta-section--first">
  <div class="ds-beta-control-card">
    <p class="ds-beta-control-text"><%= t("leverage_photo.source.intro") %></p>
    <div class="ds-beta-control-actions">
      <%= link_to t("leverage_photo.source.open"), beta_leverage_photos_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
      <%= link_to t("leverage_photo.source.upload"), beta_leverage_photo_upload_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </div>
    <p class="ds-beta-control-hint" style="margin-top:1rem;">
      <%= t("leverage_photo.source.photo_count", count: @photo_count) %>
    </p>
  </div>
</section>
