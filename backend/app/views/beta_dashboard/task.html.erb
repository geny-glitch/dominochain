<% content_for :title, t("beta.task_proof.page_title", name: @task.name) %>

<%= link_to t("beta.task_proof.back_account"), beta_account_path, class: "ds-back-link ds-beta-task-back" %>

<header class="ds-beta-page-head">
  <h1 class="ds-beta-page-title"><%= @task.name %></h1>
  <p class="ds-beta-page-lead">
    <%= t("beta.task_proof.deadline", datetime: l(@task.deadline_at, format: :short)) %>
  </p>
</header>

<section class="ds-beta-section">
  <div class="ds-task-detail ds-beta-task-detail">
    <% if @task.description.present? %>
      <div class="ds-form-group">
        <span class="ds-form-label"><%= t("tasks.description") %></span>
        <p class="ds-task-body"><%= simple_format(@task.description) %></p>
      </div>
    <% end %>

    <% if @task.expected_proof.present? %>
      <div class="ds-form-group">
        <span class="ds-form-label"><%= t("tasks.expected_proof") %></span>
        <p class="ds-task-body"><%= simple_format(@task.expected_proof) %></p>
      </div>
    <% end %>

    <% if @task.punishments.any? %>
      <div class="ds-proof-section">
        <h2 class="ds-section-title"><%= t("beta.task_proof.punishments_heading") %></h2>
        <ul class="ds-punishment-list">
          <% @task.punishments.order(created_at: :desc).each do |punishment| %>
            <li class="ds-punishment-item">
              <p class="ds-punishment-message"><%= punishment.message.presence || t("tasks.punishment_default") %></p>
              <p class="ds-proof-meta"><%= t("tasks.punishment_sent_at", datetime: l(punishment.created_at, format: :short)) %></p>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="ds-proof-section">
      <h2 class="ds-section-title"><%= t("beta.task_proof.submit_section") %></h2>
      <p class="ds-form-hint"><%= t("beta.task_proof.submit_hint") %></p>

      <%= form_with url: beta_task_proof_path(@task), method: :post, local: true, multipart: true, class: "ds-form" do |f| %>
        <div class="ds-form-group">
          <label for="proof_text" class="ds-form-label"><%= t("beta.task_proof.text_label") %></label>
          <%= f.text_area :text, id: "proof_text", class: "ds-input ds-textarea", rows: 4, placeholder: t("beta.task_proof.text_placeholder") %>
        </div>
        <div class="ds-form-group">
          <label for="proof_media" class="ds-form-label"><%= t("beta.task_proof.media_label") %></label>
          <input type="file" name="media" id="proof_media" class="ds-input" accept="image/*,video/*">
        </div>
        <div class="ds-proof-actions">
          <%= f.submit t("beta.task_proof.submit"), class: "ds-btn ds-btn--primary" %>
          <%= link_to t("beta.task_proof.cancel"), beta_account_path, class: "ds-btn ds-btn--ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
