<%# locals: photo, compact: false %>
<% compact = local_assigns.fetch(:compact, false) %>
<% if compact %>
  <%= render "beta_leverage_photo/photo_row", photo: photo %>
<% else %>
  <% id_prefix = "lp-#{photo.id}" %>
  <div class="ds-beta-control-card ds-beta-leverage-show-card"
       data-leverage-photo
       data-original-url="<%= beta_leverage_photo_original_path(photo) %>"
       data-start-url="<%= beta_leverage_photo_start_path(photo) %>"
       data-tlock-url="<%= beta_leverage_photo_tlock_blob_path(photo) %>"
       data-add-time-url="<%= beta_leverage_photo_add_time_path(photo) %>"
       data-decrypt-url="<%= beta_leverage_photo_decrypt_payload_path(photo) %>"
       data-restore-url="<%= beta_leverage_photo_restore_original_path(photo) %>"
       data-original-filename="<%= photo.download_filename %>"
       data-photo-status="<%= photo.status %>"
       data-has-original="<%= photo.original_image.attached? ? "true" : "false" %>"
       data-locked-until="<%= photo.locked_until&.iso8601 %>"
       data-layer-count="<%= photo.tlock_layer_count %>"
       data-invalid-minutes="<%= t("leverage_photo.show.invalid_minutes") %>"
       data-invalid-minutes-max="<%= t("leverage_photo.show.invalid_minutes_max") %>">
    <div class="ds-beta-home-card-head">
      <h2 class="ds-section-title"><%= t("leverage_photo.show.status_title") %></h2>
      <span class="ds-beta-home-pill <%= photo.active? ? "ds-beta-home-pill--on" : "" %>">
        <%= t("leverage_photo.status.#{photo.status}") %>
      </span>
    </div>

    <div class="ds-beta-leverage-reminders">
      <% if photo.original_image.attached? && !photo.active? %>
        <div class="ds-beta-leverage-reminders__item">
          <p class="ds-beta-home-muted"><%= t("leverage_photo.show.original_label") %></p>
          <%= image_tag url_for(photo.original_image), alt: t("leverage_photo.show.original_alt"), class: "ds-beta-leverage-reminders__img ds-beta-leverage-reminders__img--original" %>
        </div>
      <% end %>
      <% if photo.censored_image.attached? %>
        <div class="ds-beta-leverage-reminders__item">
          <p class="ds-beta-home-muted"><%= t("leverage_photo.show.censored_label") %></p>
          <%= image_tag url_for(photo.censored_image), alt: t("leverage_photo.show.censored_alt"), class: "ds-beta-leverage-reminders__img" %>
        </div>
      <% end %>
      <% if photo.teaser_image.attached? %>
        <div class="ds-beta-leverage-reminders__item">
          <p class="ds-beta-home-muted"><%= t("leverage_photo.show.teaser_label") %></p>
          <%= image_tag url_for(photo.teaser_image), alt: t("leverage_photo.show.teaser_alt"), class: "ds-beta-leverage-reminders__img ds-beta-leverage-reminders__img--pixel" %>
        </div>
      <% end %>
    </div>

    <% if photo.draft? || photo.unlocked? %>
      <% if photo.needs_censor? %>
        <div class="ds-beta-leverage-panel__actions ds-beta-leverage-panel__actions--standalone">
          <%= link_to t("leverage_photo.show.create_censor"), beta_leverage_photo_censor_path(photo), class: "ds-btn ds-btn--secondary ds-btn--sm" %>
        </div>
      <% elsif photo.censored_image.attached? && photo.can_censor? %>
        <div class="ds-beta-leverage-panel__actions ds-beta-leverage-panel__actions--standalone">
          <%= link_to t("leverage_photo.show.edit_censor"), beta_leverage_photo_censor_path(photo), class: "ds-btn ds-btn--ghost ds-btn--sm" %>
        </div>
      <% end %>
    <% end %>

    <% if photo.unlocked? %>
      <section class="ds-beta-leverage-panel">
        <% unless photo.original_image.attached? %>
          <div class="ds-beta-leverage-panel__actions">
            <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-action="decrypt"><%= t("leverage_photo.show.restore_original") %></button>
          </div>
          <img data-decrypted-image hidden alt="<%= t("leverage_photo.show.original_alt") %>" class="ds-beta-leverage-reminders__img ds-beta-leverage-reminders__img--original" />
        <% else %>
          <div class="ds-beta-leverage-panel__actions">
            <%= link_to t("leverage_photo.show.download_original"), beta_leverage_photo_original_path(photo), class: "ds-btn ds-btn--secondary ds-btn--sm", download: photo.download_filename %>
          </div>
        <% end %>
      </section>
      <%= render "beta_leverage_photo/time_lock_panel", photo: photo, id_prefix: id_prefix, mode: :relock %>
    <% elsif photo.draft? %>
      <%= render "beta_leverage_photo/time_lock_panel", photo: photo, id_prefix: id_prefix, mode: :start %>
    <% elsif photo.active? %>
      <%= render "beta_leverage_photo/time_lock_panel", photo: photo, id_prefix: id_prefix, mode: :add_time %>
    <% elsif photo.sanctioned? %>
      <p class="ds-beta-control-text"><%= t("leverage_photo.show.sanctioned_hint") %></p>
    <% end %>

    <% unless photo.deleted? %>
      <%= render "beta_leverage_photo/danger_zone", photo: photo %>
    <% end %>

    <p class="ds-beta-home-muted ds-beta-leverage-crypto-status" data-crypto-status
       data-starting="<%= t("leverage_photo.show.status_starting") %>"
       data-adding="<%= t("leverage_photo.show.status_adding") %>"
       data-peeling="<%= t("leverage_photo.show.status_peeling") %>"
       data-loading-crypto="<%= t("leverage_photo.show.status_loading_crypto") %>"
       data-crypto-load-error="<%= t("leverage_photo.show.status_crypto_load_error") %>"
       data-fetching-original="<%= t("leverage_photo.show.status_fetching_original") %>"
       data-fetching-blob="<%= t("leverage_photo.show.status_fetching_blob") %>"
       data-encrypting="<%= t("leverage_photo.show.status_encrypting") %>"
       data-uploading="<%= t("leverage_photo.show.status_uploading") %>"
       aria-live="polite"></p>
  </div>
<% end %>
