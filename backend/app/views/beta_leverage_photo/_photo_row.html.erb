<%# locals: photo %>
<% id_prefix = "lp-#{photo.id}" %>
<% duration_options = [
  [60, t("leverage_photo.durations.one_hour")],
  [360, t("leverage_photo.durations.six_hours")],
  [1440, t("leverage_photo.durations.one_day")],
  [4320, t("leverage_photo.durations.three_days")],
  [10080, t("leverage_photo.durations.one_week")]
] %>

<div class="ds-beta-leverage-row"
     data-leverage-photo
     data-original-url="<%= beta_leverage_photo_original_path(photo) %>"
     data-start-url="<%= beta_leverage_photo_start_path(photo) %>"
     data-tlock-url="<%= beta_leverage_photo_tlock_blob_path(photo) %>"
     data-add-time-url="<%= beta_leverage_photo_add_time_path(photo) %>"
     data-decrypt-url="<%= beta_leverage_photo_decrypt_payload_path(photo) %>"
     data-original-filename="<%= photo.download_filename %>"
     data-photo-status="<%= photo.status %>"
     data-locked-until="<%= photo.locked_until&.iso8601 %>"
     data-layer-count="<%= photo.tlock_layer_count %>"
     data-invalid-minutes="<%= t("leverage_photo.show.invalid_minutes") %>"
     data-invalid-minutes-max="<%= t("leverage_photo.show.invalid_minutes_max") %>">

  <div class="ds-beta-leverage-row__thumb-wrap">
    <% if photo.teaser_image.attached? %>
      <%= image_tag url_for(photo.teaser_image),
            alt: "",
            class: "ds-beta-leverage-row__thumb ds-beta-leverage-row__thumb--pixel" %>
    <% else %>
      <div class="ds-beta-leverage-row__thumb ds-beta-leverage-row__thumb--empty" aria-hidden="true"></div>
    <% end %>
  </div>

  <div class="ds-beta-leverage-row__meta">
    <p class="ds-beta-leverage-row__name" title="<%= photo.download_filename %>"><%= photo.download_filename %></p>
    <% if photo.active? %>
      <p class="ds-beta-leverage-row__status ds-beta-leverage-row__status--live" data-countdown data-ready="<%= t("leverage_photo.show.ready") %>">—</p>
    <% else %>
      <p class="ds-beta-leverage-row__status">
        <%= t("leverage_photo.status.#{photo.status}") %>
        <% if photo.needs_censor? %>
          <span class="ds-beta-leverage-row__dot">·</span>
          <%= t("leverage_photo.index.needs_censor_short") %>
        <% end %>
      </p>
    <% end %>
  </div>

  <div class="ds-beta-leverage-row__duration">
    <% if photo.draft? || photo.unlocked? %>
      <label class="visually-hidden" for="<%= id_prefix %>-duration-minutes"><%= t("leverage_photo.show.duration") %></label>
      <select
        id="<%= id_prefix %>-duration-minutes"
        class="ds-input ds-beta-leverage-row__select"
        data-duration-minutes
        aria-label="<%= t("leverage_photo.show.duration") %>">
        <% duration_options.each do |minutes, label| %>
          <option value="<%= minutes %>" <%= "selected" if minutes == 1440 %>><%= label %></option>
        <% end %>
      </select>
    <% elsif photo.active? %>
      <label class="visually-hidden" for="<%= id_prefix %>-add-minutes"><%= t("leverage_photo.show.add_duration") %></label>
      <select
        id="<%= id_prefix %>-add-minutes"
        class="ds-input ds-beta-leverage-row__select"
        data-add-minutes
        aria-label="<%= t("leverage_photo.show.add_duration") %>">
        <% duration_options.first(4).each do |minutes, label| %>
          <option value="<%= minutes %>" <%= "selected" if minutes == 1440 %>><%= label %></option>
        <% end %>
      </select>
    <% end %>
  </div>

  <div class="ds-beta-leverage-row__buttons">
    <% if photo.draft? || photo.unlocked? %>
      <button
        type="button"
        class="ds-btn ds-btn--primary ds-btn--icon ds-btn--sm"
        data-action="start-timer"
        title="<%= photo.unlocked? ? t("leverage_photo.show.lock_again") : t("leverage_photo.show.start_timer") %>"
        aria-label="<%= photo.unlocked? ? t("leverage_photo.show.lock_again") : t("leverage_photo.show.start_timer") %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </button>
    <% end %>

    <% if photo.active? %>
      <button
        type="button"
        class="ds-btn ds-btn--secondary ds-btn--icon ds-btn--sm"
        data-action="add-time"
        title="<%= t("leverage_photo.show.add_time") %>"
        aria-label="<%= t("leverage_photo.show.add_time") %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </button>
    <% end %>

    <% if photo.unlocked? %>
      <button
        type="button"
        class="ds-btn ds-btn--secondary ds-btn--icon ds-btn--sm"
        data-action="decrypt"
        title="<%= t("leverage_photo.show.view_original") %>"
        aria-label="<%= t("leverage_photo.show.view_original") %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </button>
      <img data-decrypted-image hidden alt="" class="ds-beta-leverage-row__hidden-media" />
      <a data-download-original hidden download="<%= photo.download_filename %>" class="ds-beta-leverage-row__hidden-media"></a>
    <% elsif photo.needs_censor? %>
      <%= link_to beta_leverage_photo_censor_path(photo),
            class: "ds-btn ds-btn--ghost ds-btn--icon ds-btn--sm",
            title: t("leverage_photo.index.create_censor"),
            aria: { label: t("leverage_photo.index.create_censor") } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <% end %>
    <% else %>
      <span class="ds-beta-leverage-row__btn-spacer" aria-hidden="true"></span>
    <% end %>

    <% if photo.wallpaper_display_attachment.present? && !current_user.controlled_by_boss? %>
      <%= button_to beta_leverage_photo_set_as_wallpaper_path(photo),
            method: :post,
            class: "ds-btn ds-btn--ghost ds-btn--icon ds-btn--sm",
            title: t("leverage_photo.index.set_as_wallpaper"),
            form: { data: { turbo_confirm: t("leverage_photo.index.set_as_wallpaper_confirm") } },
            aria: { label: t("leverage_photo.index.set_as_wallpaper") } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      <% end %>
    <% end %>

    <%= button_to beta_leverage_photo_destroy_path(photo),
          method: :delete,
          class: "ds-btn ds-btn--ghost ds-btn--icon ds-btn--sm",
          title: t("leverage_photo.show.delete"),
          form: { data: { turbo_confirm: t("leverage_photo.show.delete_confirm") } },
          aria: { label: t("leverage_photo.show.delete") } do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
    <% end %>
  </div>

  <p class="ds-beta-leverage-row__status-msg" data-crypto-status
     data-starting="<%= t("leverage_photo.show.status_starting") %>"
     data-adding="<%= t("leverage_photo.show.status_adding") %>"
     data-peeling="<%= t("leverage_photo.show.status_peeling") %>"
     data-loading-crypto="<%= t("leverage_photo.show.status_loading_crypto") %>"
     data-crypto-load-error="<%= t("leverage_photo.show.status_crypto_load_error") %>"
     data-fetching-original="<%= t("leverage_photo.show.status_fetching_original") %>"
     data-fetching-blob="<%= t("leverage_photo.show.status_fetching_blob") %>"
     data-encrypting="<%= t("leverage_photo.show.status_encrypting") %>"
     data-uploading="<%= t("leverage_photo.show.status_uploading") %>"
     aria-live="polite"></p>
</div>
