<% content_for :title, t("leverage_photo.show.title") %>

<header class="ds-beta-page-head">
  <p class="ds-beta-page-lead" style="margin-bottom:0.35rem;">
    <%= link_to t("leverage_photo.show.back_to_list"), beta_leverage_photos_path, class: "ds-beta-home-muted" %>
  </p>
  <h1 class="ds-beta-page-title"><%= @photo.download_filename %></h1>
  <p class="ds-beta-page-lead"><%= t("leverage_photo.show.lead") %></p>
</header>

<section class="ds-beta-section ds-beta-section--first">
  <div class="ds-beta-control-card"
       data-leverage-photo
       data-original-url="<%= beta_leverage_photo_original_path(@photo) %>"
       data-start-url="<%= beta_leverage_photo_start_path(@photo) %>"
       data-tlock-url="<%= beta_leverage_photo_tlock_blob_path(@photo) %>"
       data-add-time-url="<%= beta_leverage_photo_add_time_path(@photo) %>"
       data-decrypt-url="<%= beta_leverage_photo_decrypt_payload_path(@photo) %>"
       data-original-filename="<%= @photo.download_filename %>"
       data-locked-until="<%= @photo.locked_until&.iso8601 %>"
       data-layer-count="<%= @photo.tlock_layer_count %>"
       data-invalid-minutes="<%= t("leverage_photo.show.invalid_minutes") %>"
       data-invalid-minutes-max="<%= t("leverage_photo.show.invalid_minutes_max") %>">
    <div class="ds-beta-home-card-head">
      <h2 class="ds-section-title"><%= t("leverage_photo.show.status_title") %></h2>
      <span class="ds-beta-home-pill <%= @photo.active? ? "ds-beta-home-pill--on" : "" %>">
        <%= t("leverage_photo.status.#{@photo.status}") %>
      </span>
    </div>

    <div class="ds-beta-leverage-reminders" style="display:flex;gap:1rem;align-items:flex-start;flex-wrap:wrap;margin:1rem 0;">
      <% if @photo.censored_image.attached? %>
        <div>
          <p class="ds-beta-home-muted"><%= t("leverage_photo.show.censored_label") %></p>
          <%= image_tag url_for(@photo.censored_image), alt: t("leverage_photo.show.censored_alt"), style: "max-width:220px;border-radius:8px;" %>
        </div>
      <% end %>
      <% if @photo.teaser_image.attached? %>
        <div>
          <p class="ds-beta-home-muted"><%= t("leverage_photo.show.teaser_label") %></p>
          <%= image_tag url_for(@photo.teaser_image), alt: t("leverage_photo.show.teaser_alt"), style: "image-rendering:pixelated;border-radius:4px;" %>
        </div>
      <% end %>
    </div>

    <% if @photo.draft? %>
      <p class="ds-beta-control-text"><%= t("leverage_photo.show.draft_hint") %></p>
      <%= render "beta_leverage_photo/duration_picker",
            label: t("leverage_photo.show.duration"),
            input_name: "duration-minutes",
            default_minutes: 1440,
            shortcuts: [
              [60, t("leverage_photo.durations.one_hour")],
              [360, t("leverage_photo.durations.six_hours")],
              [1440, t("leverage_photo.durations.one_day")],
              [4320, t("leverage_photo.durations.three_days")],
              [10080, t("leverage_photo.durations.one_week")]
            ] %>
      <div class="ds-beta-control-actions" style="flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem;">
        <button type="button" class="ds-btn ds-btn--primary ds-btn--sm" data-action="start-timer"><%= t("leverage_photo.show.start_timer") %></button>
        <%= button_to t("leverage_photo.show.delete"), beta_leverage_photo_destroy_path(@photo), method: :delete, class: "ds-btn ds-btn--ghost ds-btn--sm", form: { data: { turbo_confirm: t("leverage_photo.show.delete_confirm") } } %>
      </div>
    <% elsif @photo.active? %>
      <p class="ds-beta-home-metric" data-countdown data-ready="<%= t("leverage_photo.show.ready") %>">—</p>
      <p class="ds-beta-home-muted"><%= t("leverage_photo.show.active_hint") %></p>
      <%= render "beta_leverage_photo/duration_picker",
            label: t("leverage_photo.show.add_duration"),
            input_name: "add-minutes",
            default_minutes: 1440,
            shortcuts: [
              [60, t("leverage_photo.durations.one_hour")],
              [360, t("leverage_photo.durations.six_hours")],
              [1440, t("leverage_photo.durations.one_day")],
              [4320, t("leverage_photo.durations.three_days")]
            ] %>
      <div class="ds-beta-control-actions" style="flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem;">
        <button type="button" class="ds-btn ds-btn--secondary ds-btn--sm" data-action="add-time"><%= t("leverage_photo.show.add_time") %></button>
        <%= button_to t("leverage_photo.show.delete"), beta_leverage_photo_destroy_path(@photo), method: :delete, class: "ds-btn ds-btn--ghost ds-btn--sm", form: { data: { turbo_confirm: t("leverage_photo.show.delete_confirm") } } %>
      </div>
    <% elsif @photo.unlocked? %>
      <p class="ds-beta-control-text"><%= t("leverage_photo.show.unlocked_hint") %></p>
      <div class="ds-beta-control-actions">
        <button type="button" class="ds-btn ds-btn--primary ds-btn--sm" data-action="decrypt"><%= t("leverage_photo.show.view_original") %></button>
        <%= button_to t("leverage_photo.show.delete"), beta_leverage_photo_destroy_path(@photo), method: :delete, class: "ds-btn ds-btn--ghost ds-btn--sm", form: { data: { turbo_confirm: t("leverage_photo.show.delete_confirm") } } %>
      </div>
      <img data-decrypted-image hidden alt="<%= t("leverage_photo.show.original_alt") %>" style="max-width:100%;margin-top:1rem;border-radius:8px;" />
      <p class="ds-beta-control-actions" style="margin-top:0.75rem;">
        <a data-download-original hidden class="ds-btn ds-btn--secondary ds-btn--sm" download="<%= @photo.download_filename %>"><%= t("leverage_photo.show.download_original") %></a>
      </p>
    <% end %>

    <p class="ds-beta-home-muted" data-crypto-status
       data-starting="<%= t("leverage_photo.show.status_starting") %>"
       data-adding="<%= t("leverage_photo.show.status_adding") %>"
       data-peeling="<%= t("leverage_photo.show.status_peeling") %>"
       data-loading-crypto="<%= t("leverage_photo.show.status_loading_crypto") %>"
       data-crypto-load-error="<%= t("leverage_photo.show.status_crypto_load_error") %>"
       data-fetching-original="<%= t("leverage_photo.show.status_fetching_original") %>"
       data-fetching-blob="<%= t("leverage_photo.show.status_fetching_blob") %>"
       data-encrypting="<%= t("leverage_photo.show.status_encrypting") %>"
       data-uploading="<%= t("leverage_photo.show.status_uploading") %>"
       style="min-height:1.25rem;color:#f87171;"></p>
  </div>
  <%= render "beta_leverage_photo/crypto_script" %>
</section>
