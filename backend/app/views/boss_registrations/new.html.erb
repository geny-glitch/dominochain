<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: t("layouts.application.logo_alt"), class: "ds-header-logo", width: 48, height: 48 %>
      <h1 class="ds-title wordmark">DominoChain</h1>
      <p class="ds-subtitle eyebrow"><%= t("boss_registration.eyebrow") %></p>
    </header>

    <%= form_for(resource, as: resource_name, url: boss_registration_path, html: { class: "ds-form ds-auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="ds-form-group">
        <%= f.label :nickname, t("devise.registrations.nickname"), class: "ds-form-label" %>
        <%= f.text_field :nickname, autofocus: true, autocomplete: "nickname", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password, t("devise.registrations.password"), class: "ds-form-label" %>
        <% if @minimum_password_length %>
          <span class="ds-form-hint">(<%= t("devise.registrations.password_hint", count: @minimum_password_length) %>)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password_confirmation, t("devise.registrations.password_confirmation"), class: "ds-form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-actions">
        <%= f.submit t("boss_registration.submit"), class: "ds-btn ds-btn--primary" %>
      </div>
    <% end %>

    <nav class="ds-auth-links">
      <%= link_to t("devise.links.log_in"), new_user_session_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      <%= link_to t("devise.links.sign_up_beta"), new_user_registration_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
    </nav>
  </div>
</div>
