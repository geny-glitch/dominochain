<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <h1 class="ds-title">OTB</h1>
      <p class="ds-subtitle">Créer un compte (Boss)</p>
    </header>

    <%= form_for(resource, as: resource_name, url: boss_registration_path, html: { class: "ds-form ds-auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="ds-form-group">
        <%= f.label :nickname, "Pseudo", class: "ds-form-label" %>
        <%= f.text_field :nickname, autofocus: true, autocomplete: "nickname", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password, "Mot de passe", class: "ds-form-label" %>
        <% if @minimum_password_length %>
          <span class="ds-form-hint">(<%= @minimum_password_length %> caractères minimum)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password_confirmation, "Confirmation", class: "ds-form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-actions">
        <%= f.submit "Créer mon compte", class: "ds-btn ds-btn--primary" %>
      </div>
    <% end %>

    <nav class="ds-auth-links">
      <%= link_to "Connexion", new_user_session_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      <%= link_to "Inscription Beta", new_user_registration_path, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
    </nav>
  </div>
</div>
