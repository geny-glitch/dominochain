<script>
(function () {
  var root = document.getElementById("cornertime-monitor");
  if (!root) return;

  var video = document.getElementById("cornertime-video");
  var canvas = document.getElementById("cornertime-canvas");
  var ctx = canvas.getContext("2d", { willReadFrequently: true });
  var statusEl = document.getElementById("cornertime-status");
  var violationsEl = document.getElementById("cornertime-violations");
  var elapsedEl = document.getElementById("cornertime-elapsed");
  var hintEl = document.getElementById("cornertime-hint");
  var startBtn = document.getElementById("cornertime-start");
  var stopBtn = document.getElementById("cornertime-stop");
  var voiceToggle = document.getElementById("cornertime-voice");
  var voicePick = document.getElementById("cornertime-voice-pick");
  var voicePickWrap = document.getElementById("cornertime-voice-pick-wrap");
  var VOICE_STORAGE_KEY = "cornertime_tts_voice";
  var FEMALE_VOICE_RE = /female|woman|girl|samantha|victoria|karen|moira|fiona|tessa|amelie|am[eé]lie|hortense|denise|audrey|marie|virginie|zira|susan|linda|ava|emma|joanna|salli|ivy|kendra|kimberly|amy|aria|jenny|natalie|sofie|elsa|alva|nicky|heather|google fran[cç]ais|microsoft hortense/i;
  var MALE_VOICE_RE = /male|man|boy|david|daniel|alex|fred|thomas|paul|nicolas|jacques|mark|james|brian|matthew|joey|justin|kevin|guy|eric|microsoft paul|microsoft guy/i;

  var i18n = JSON.parse(root.dataset.i18n || "{}");
  var config = JSON.parse(root.dataset.config || "{}");
  var sourceEnabled = root.dataset.sourceEnabled === "true";
  var csrf = document.querySelector('meta[name="csrf-token"]');
  var csrfToken = csrf ? csrf.getAttribute("content") : "";
  var speechLocale = (root.dataset.speechLang || "en").replace("_", "-");
  var speechVoice = null;

  var stream = null;
  var sessionId = null;
  var rafId = null;
  var lastViolationAt = 0;
  var lastSanctionAt = 0;
  var violationCount = 0;
  var startedAt = null;
  var elapsedTimer = null;
  var monitoring = false;
  var calibrating = false;
  var reporting = false;

  var DETECTION_DEBOUNCE_MS = 1000;
  var sanctionCooldownMs = (config.violation_cooldown_seconds || 8) * 1000;
  var calibrationMs = (config.calibration_seconds || 5) * 1000;
  var diffSensitivity = config.diff_sensitivity || 0.2;
  var pixelThreshold = config.pixel_threshold || 21;
  var motionThreshold = config.motion_threshold || 0.12;
  var driftThreshold = config.drift_threshold || 0.18;
  var driftHoldMs = config.drift_hold_ms || 1800;
  var driftPixelDelta = config.drift_pixel_delta || 18;
  var cellActiveBelow = config.cell_active_below || 200;
  var matrixW = config.matrix_width || 12;
  var matrixH = config.matrix_height || 8;
  var sourceW = config.source_width || 160;
  var sourceH = config.source_height || 120;

  function applyConfig(cfg) {
    if (!cfg) return;
    sanctionCooldownMs = (cfg.violation_cooldown_seconds || 8) * 1000;
    calibrationMs = (cfg.calibration_seconds || 5) * 1000;
    diffSensitivity = cfg.diff_sensitivity || 0.2;
    pixelThreshold = cfg.pixel_threshold || 21;
    motionThreshold = cfg.motion_threshold || 0.12;
    driftThreshold = cfg.drift_threshold || 0.18;
    driftHoldMs = cfg.drift_hold_ms || 1800;
    driftPixelDelta = cfg.drift_pixel_delta || 18;
    cellActiveBelow = cfg.cell_active_below || 200;
    matrixW = cfg.matrix_width || 12;
    matrixH = cfg.matrix_height || 8;
    sourceW = cfg.source_width || 160;
    sourceH = cfg.source_height || 120;
    applyVoiceFromConfig(cfg);
  }

  // Beta locale drives both spoken text and TTS voice (same source).
  function applyVoiceFromConfig(cfg) {
    if (!cfg) return;
    if (cfg.locale) {
      speechLocale = String(cfg.locale).replace("_", "-");
      speechVoice = null;
    }
    var voice = cfg.voice || {};
    if (voice.intro) i18n.voice_intro = voice.intro;
    if (voice.stop_moving) i18n.voice_stop_moving = voice.stop_moving;
    if (voice.return_to_position) i18n.voice_return_to_position = voice.return_to_position;
    refreshVoicePicker();
  }

  applyVoiceFromConfig(config);

  function setStatus(key) {
    statusEl.textContent = i18n[key] || key;
  }

  function setHint(text) {
    if (!text) {
      hintEl.hidden = true;
      hintEl.textContent = "";
      return;
    }
    hintEl.hidden = false;
    hintEl.textContent = text;
  }

  function voiceEnabled() {
    return !!(voiceToggle && voiceToggle.checked && window.speechSynthesis);
  }

  function voiceLabel(v) {
    return (v.name || v.voiceURI || v.lang || "voice").trim();
  }

  function voicesForLocale() {
    if (!window.speechSynthesis) return [];
    var voices = window.speechSynthesis.getVoices() || [];
    var wanted = speechLocale.toLowerCase();
    var prefix = wanted.slice(0, 2);
    var exact = voices.filter(function (v) {
      return (v.lang || "").toLowerCase() === wanted;
    });
    if (exact.length) return exact;
    return voices.filter(function (v) {
      return (v.lang || "").toLowerCase().indexOf(prefix) === 0;
    });
  }

  function isFemaleVoice(v) {
    var label = voiceLabel(v);
    if (MALE_VOICE_RE.test(label)) return false;
    return FEMALE_VOICE_RE.test(label);
  }

  function preferredVoice(voices) {
    if (!voices.length) return null;
    var saved = null;
    try { saved = localStorage.getItem(VOICE_STORAGE_KEY); } catch (e) { saved = null; }
    if (saved) {
      var match = voices.find(function (v) {
        return voiceLabel(v) === saved || v.voiceURI === saved;
      });
      if (match) return match;
    }
    return voices.find(isFemaleVoice) || voices[0];
  }

  function resolveSpeechVoice() {
    return preferredVoice(voicesForLocale());
  }

  function refreshVoicePicker() {
    if (!voicePick) return;
    var voices = voicesForLocale();
    var selected = preferredVoice(voices);
    speechVoice = selected;
    voicePick.innerHTML = "";
    if (!voices.length) {
      if (voicePickWrap) voicePickWrap.hidden = true;
      return;
    }
    if (voicePickWrap) voicePickWrap.hidden = false;
    voices.forEach(function (v) {
      var opt = document.createElement("option");
      opt.value = voiceLabel(v);
      opt.textContent = voiceLabel(v) + (isFemaleVoice(v) ? " ♀" : "");
      if (selected && voiceLabel(v) === voiceLabel(selected)) opt.selected = true;
      voicePick.appendChild(opt);
    });
  }

  function ensureSpeechVoice() {
    if (speechVoice) return speechVoice;
    speechVoice = resolveSpeechVoice();
    return speechVoice;
  }

  function syncVoicePickerVisibility() {
    if (!voicePickWrap) return;
    voicePickWrap.hidden = !(voiceToggle && voiceToggle.checked);
    if (!voicePickWrap.hidden) refreshVoicePicker();
  }

  if (window.speechSynthesis) {
    window.speechSynthesis.addEventListener("voiceschanged", function () {
      refreshVoicePicker();
    });
    refreshVoicePicker();
  }

  if (voiceToggle) {
    voiceToggle.addEventListener("change", syncVoicePickerVisibility);
    syncVoicePickerVisibility();
  }

  if (voicePick) {
    voicePick.addEventListener("change", function () {
      var voices = voicesForLocale();
      var chosen = voices.find(function (v) { return voiceLabel(v) === voicePick.value; });
      if (!chosen) return;
      speechVoice = chosen;
      try { localStorage.setItem(VOICE_STORAGE_KEY, voiceLabel(chosen)); } catch (e) { /* ignore */ }
    });
  }

  function speak(text) {
    if (!voiceEnabled() || !text) return;
    try {
      window.speechSynthesis.cancel();
      var utter = new SpeechSynthesisUtterance(text);
      utter.lang = speechLocale;
      var voice = ensureSpeechVoice();
      if (voice) utter.voice = voice;
      utter.rate = 1;
      window.speechSynthesis.speak(utter);
    } catch (e) { /* ignore TTS failures */ }
  }

  function stopSpeaking() {
    if (!window.speechSynthesis) return;
    try { window.speechSynthesis.cancel(); } catch (e) { /* ignore */ }
  }

  function formatElapsed(ms) {
    var total = Math.floor(ms / 1000);
    var m = Math.floor(total / 60);
    var s = total % 60;
    return String(m).padStart(2, "0") + ":" + String(s).padStart(2, "0");
  }

  function updateElapsed() {
    if (!startedAt) return;
    elapsedEl.textContent = (i18n.elapsed || "Elapsed: %{time}").replace("%{time}", formatElapsed(Date.now() - startedAt));
  }

  function updateViolations() {
    violationsEl.textContent = (i18n.violations || "Movements: %{count}").replace("%{count}", String(violationCount));
  }

  function uuid() {
    if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
    return "v-" + Date.now() + "-" + Math.floor(Math.random() * 1e9);
  }

  function toLuma(rgba, width, height) {
    var out = new Float32Array(width * height);
    for (var i = 0, p = 0; i < rgba.length; i += 4, p++) {
      out[p] = (rgba[i] + rgba[i + 1] + rgba[i + 2]) / 3;
    }
    return out;
  }

  // Diffy-style instant motion (consecutive frames).
  function DiffyDetector(width, height, resX, resY, sensitivity, threshold) {
    this.width = width;
    this.height = height;
    this.resolutionX = resX;
    this.resolutionY = resY;
    this.sensitivity = sensitivity;
    this.threshold = threshold;
    this.previousFrame = null;
    this.diffBuffer = new Uint8ClampedArray(width * height);
  }

  DiffyDetector.prototype.reset = function () {
    this.previousFrame = null;
  };

  DiffyDetector.prototype.processFrame = function (rgba) {
    if (!this.previousFrame) {
      this.previousFrame = new Uint8ClampedArray(rgba);
      return 0;
    }
    this.createDiffBuffer(rgba, this.previousFrame);
    var score = this.motionScoreFromMatrix();
    this.previousFrame = new Uint8ClampedArray(rgba);
    return score;
  };

  DiffyDetector.prototype.createDiffBuffer = function (current, previous) {
    var amp = 1 - this.sensitivity;
    if (amp < 0.05) amp = 0.05;
    var len = this.width * this.height;
    for (var i = 0; i < len; i++) {
      var h = i * 4;
      var cAvg = Math.round((current[h] + current[h + 1] + current[h + 2]) / 3);
      var pAvg = Math.round((previous[h] + previous[h + 1] + previous[h + 2]) / 3);
      var delta = Math.abs(Math.round(cAvg / amp) - Math.round(pAvg / amp));
      this.diffBuffer[i] = delta > this.threshold ? 0 : 255;
    }
  };

  DiffyDetector.prototype.cellAverage = function (x0, y0, x1, y1) {
    var sum = 0;
    var count = 0;
    for (var y = y0; y < y1 && y < this.height; y++) {
      for (var x = x0; x < x1 && x < this.width; x++) {
        sum += this.diffBuffer[y * this.width + x];
        count += 1;
      }
    }
    return count > 0 ? sum / count : 255;
  };

  DiffyDetector.prototype.motionScoreFromMatrix = function () {
    var cellW = this.width / this.resolutionX;
    var cellH = this.height / this.resolutionY;
    var active = 0;
    var total = this.resolutionX * this.resolutionY;
    for (var row = 0; row < this.resolutionY; row++) {
      for (var col = 0; col < this.resolutionX; col++) {
        var x0 = Math.floor(col * cellW);
        var y0 = Math.floor(row * cellH);
        var x1 = Math.floor((col + 1) * cellW);
        var y1 = Math.floor((row + 1) * cellH);
        if (this.cellAverage(x0, y0, x1, y1) < cellActiveBelow) active += 1;
      }
    }
    return total > 0 ? active / total : 0;
  };

  // Long-horizon pose drift vs calibration baseline.
  // Tolerates brief rebalancing; triggers only if drift stays high for holdMs.
  function DriftDetector(width, height, resX, resY, pixelDelta, driftThreshold, holdMs) {
    this.width = width;
    this.height = height;
    this.resolutionX = resX;
    this.resolutionY = resY;
    this.pixelDelta = pixelDelta;
    this.driftThreshold = driftThreshold;
    this.holdMs = holdMs;
    this.baseline = null;
    this.samples = 0;
    this.driftSince = null;
  }

  DriftDetector.prototype.reset = function () {
    this.baseline = null;
    this.samples = 0;
    this.driftSince = null;
  };

  DriftDetector.prototype.accumulate = function (luma) {
    if (!this.baseline || this.baseline.length !== luma.length) {
      this.baseline = new Float32Array(luma.length);
      this.samples = 0;
    }
    this.samples += 1;
    var n = this.samples;
    for (var i = 0; i < luma.length; i++) {
      this.baseline[i] += (luma[i] - this.baseline[i]) / n;
    }
  };

  DriftDetector.prototype.cellMean = function (buf, x0, y0, x1, y1) {
    var sum = 0;
    var count = 0;
    for (var y = y0; y < y1 && y < this.height; y++) {
      for (var x = x0; x < x1 && x < this.width; x++) {
        sum += buf[y * this.width + x];
        count += 1;
      }
    }
    return count > 0 ? sum / count : 0;
  };

  DriftDetector.prototype.driftScore = function (luma) {
    if (!this.baseline || this.samples < 3) return 0;
    var cellW = this.width / this.resolutionX;
    var cellH = this.height / this.resolutionY;
    var drifted = 0;
    var total = this.resolutionX * this.resolutionY;
    for (var row = 0; row < this.resolutionY; row++) {
      for (var col = 0; col < this.resolutionX; col++) {
        var x0 = Math.floor(col * cellW);
        var y0 = Math.floor(row * cellH);
        var x1 = Math.floor((col + 1) * cellW);
        var y1 = Math.floor((row + 1) * cellH);
        var cur = this.cellMean(luma, x0, y0, x1, y1);
        var base = this.cellMean(this.baseline, x0, y0, x1, y1);
        if (Math.abs(cur - base) > this.pixelDelta) drifted += 1;
      }
    }
    return total > 0 ? drifted / total : 0;
  };

  // Returns { score, triggered } — triggered only after sustained drift.
  DriftDetector.prototype.evaluate = function (luma, now) {
    var score = this.driftScore(luma);
    if (score > this.driftThreshold) {
      if (this.driftSince == null) this.driftSince = now;
      if (now - this.driftSince >= this.holdMs) {
        return { score: score, triggered: true };
      }
      return { score: score, triggered: false };
    }
    this.driftSince = null;
    return { score: score, triggered: false };
  };

  // After a drift sanction, re-anchor so staying put does not keep firing.
  DriftDetector.prototype.rebaseTo = function (luma) {
    this.baseline = new Float32Array(luma);
    this.samples = Math.max(this.samples, 8);
    this.driftSince = null;
  };

  var diffy = null;
  var drift = null;

  function ensureDetectors() {
    canvas.width = sourceW;
    canvas.height = sourceH;
    diffy = new DiffyDetector(sourceW, sourceH, matrixW, matrixH, diffSensitivity, pixelThreshold);
    drift = new DriftDetector(
      sourceW, sourceH, matrixW, matrixH,
      driftPixelDelta, driftThreshold, driftHoldMs
    );
  }

  async function api(url, method, body) {
    var res = await fetch(url, {
      method: method,
      headers: {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "X-CSRF-Token": csrfToken
      },
      body: body ? JSON.stringify(body) : undefined,
      credentials: "same-origin"
    });
    var data = {};
    try { data = await res.json(); } catch (e) { data = {}; }
    if (!res.ok) {
      var err = new Error(data.error || i18n.error || "Error");
      err.status = res.status;
      err.data = data;
      throw err;
    }
    return data;
  }

  async function reportViolation(score, kind, luma) {
    if (!sessionId) return;
    var now = Date.now();

    if (now - lastViolationAt < DETECTION_DEBOUNCE_MS) return;
    lastViolationAt = now;
    violationCount += 1;
    updateViolations();

    if (kind === "drift") {
      speak(i18n.voice_return_to_position || "");
      setHint(i18n.voice_return_to_position || "");
      if (drift && luma) drift.rebaseTo(luma);
    } else {
      speak(i18n.voice_stop_moving || "");
      setHint(i18n.voice_stop_moving || "");
    }

    if (reporting) return;
    if (now - lastSanctionAt < sanctionCooldownMs) return;
    lastSanctionAt = now;
    reporting = true;
    try {
      var data = await api(
        root.dataset.violationUrlTemplate.replace(":id", sessionId),
        "POST",
        {
          motion_score: score,
          detected_at: new Date().toISOString(),
          client_violation_id: uuid()
        }
      );
      if (typeof data.cooldown_remaining_seconds === "number" && data.cooldown_remaining_seconds > 0) {
        sanctionCooldownMs = Math.max(DETECTION_DEBOUNCE_MS, data.cooldown_remaining_seconds * 1000);
      }
      if (data.status === "no_sanctions") {
        setHint(i18n.no_sanctions || "");
      }
    } catch (e) {
      setHint(e.message);
    } finally {
      reporting = false;
    }
  }

  function tick() {
    if (!monitoring) return;
    rafId = requestAnimationFrame(tick);
    if (document.hidden || !diffy || !drift) return;
    if (!video.videoWidth) return;

    ctx.drawImage(video, 0, 0, sourceW, sourceH);
    var image = ctx.getImageData(0, 0, sourceW, sourceH);
    var luma = toLuma(image.data, sourceW, sourceH);

    if (calibrating) {
      drift.accumulate(luma);
      diffy.processFrame(image.data); // seed previous frame only
      return;
    }

    var instant = diffy.processFrame(image.data);
    var driftResult = drift.evaluate(luma, Date.now());

    if (instant > motionThreshold) {
      reportViolation(instant, "instant", null);
    } else if (driftResult.triggered) {
      reportViolation(driftResult.score, "drift", luma);
    }
  }

  async function startCamera() {
    setStatus("requesting_camera");
    stream = await navigator.mediaDevices.getUserMedia({
      audio: false,
      video: { facingMode: "user", width: { ideal: 640 }, height: { ideal: 480 } }
    });
    video.srcObject = stream;
    await video.play();
  }

  function stopCamera() {
    if (stream) {
      stream.getTracks().forEach(function (t) { t.stop(); });
      stream = null;
    }
    video.srcObject = null;
  }

  async function startSession() {
    if (!sourceEnabled) {
      setHint(i18n.source_disabled);
      return;
    }
    startBtn.disabled = true;
    setHint("");
    try {
      await startCamera();
      var data = await api(root.dataset.startUrl, "POST", {});
      sessionId = data.session.id;
      applyConfig(data.config || config);
      violationCount = 0;
      updateViolations();
      startedAt = Date.now();
      updateElapsed();
      elapsedTimer = setInterval(updateElapsed, 1000);
      ensureDetectors();
      calibrating = true;
      monitoring = true;
      stopBtn.disabled = false;
      setStatus("calibrating");
      lastViolationAt = 0;
      lastSanctionAt = 0;
      rafId = requestAnimationFrame(tick);
      setTimeout(function () {
        if (!monitoring) return;
        calibrating = false;
        setStatus("active");
        speak(i18n.voice_intro || "");
      }, Math.max(calibrationMs, 1200));
    } catch (e) {
      stopCamera();
      startBtn.disabled = false;
      stopBtn.disabled = true;
      if (e.name === "NotAllowedError" || e.name === "PermissionDeniedError") {
        setStatus("error");
        setHint(i18n.camera_denied);
      } else {
        setStatus("error");
        setHint(e.message || i18n.error);
      }
    }
  }

  async function stopSession() {
    monitoring = false;
    calibrating = false;
    stopSpeaking();
    if (rafId) cancelAnimationFrame(rafId);
    rafId = null;
    if (elapsedTimer) clearInterval(elapsedTimer);
    elapsedTimer = null;
    diffy = null;
    drift = null;
    stopCamera();
    stopBtn.disabled = true;
    startBtn.disabled = !sourceEnabled;
    setStatus("stopped");
    setHint("");
    if (sessionId) {
      try {
        await api(root.dataset.stopUrlTemplate.replace(":id", sessionId), "PATCH");
      } catch (e) {
        setHint(e.message);
      }
      sessionId = null;
    }
  }

  document.addEventListener("visibilitychange", function () {
    if (!monitoring) return;
    if (document.hidden) {
      setStatus("paused");
      setHint(i18n.tab_hidden);
      if (diffy) diffy.reset();
      if (drift) drift.driftSince = null;
    } else if (calibrating) {
      setStatus("calibrating");
      setHint("");
    } else {
      setStatus("active");
      setHint("");
    }
  });

  startBtn.addEventListener("click", startSession);
  stopBtn.addEventListener("click", stopSession);
  window.addEventListener("beforeunload", function () {
    stopCamera();
  });
})();
</script>
