<div class="ds-page">
  <div class="ds-container">
    <h1><%= t("dashboard.heading") %></h1>

    <% if @controlled_betas.any? %>
      <section>
        <h2><%= t("dashboard.controlled_betas") %></h2>
        <ul>
          <% @controlled_betas.each do |control| %>
            <li>
              <%= control.beta.nickname %>
              <%= link_to t("dashboard.manage"), wallpaper_upload_path(control.beta.nickname), class: "ds-btn ds-btn--primary ds-btn--sm" %>
              <%= button_to t("dashboard.release"), control_release_path(control_id: control.id), method: :post, form: { data: { turbo_confirm: t("dashboard.release_confirm") } }, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if @pending_control_requests.any? %>
      <section>
        <h2><%= t("dashboard.requests_title") %></h2>
        <ul>
          <% @pending_control_requests.each do |request| %>
            <li>
              <%= t("dashboard.request_line", nickname: request.beta.nickname) %>
              <%= button_to t("dashboard.accept"), control_accept_request_path(request_id: request.id), method: :post, class: "ds-btn ds-btn--primary ds-btn--sm" %>
              <%= button_to t("dashboard.reject"), control_reject_request_path(request_id: request.id), method: :post, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if @controlled_betas.empty? && @pending_control_requests.empty? %>
      <p><%= t("dashboard.empty") %></p>
    <% end %>

    <p><%= button_to t("dashboard.sign_out"), destroy_user_session_path, method: :delete, class: "ds-btn ds-btn--ghost" %></p>
  </div>
</div>
