<mjml>
  <mj-head>
    <mj-preview><%= t("devise.mailer.confirmation_instructions.preview") %></mj-preview>
    <mj-attributes>
      <mj-all font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" color="#e8e6e3" />
      <mj-text font-size="14px" line-height="22px" color="#e8e6e3" />
      <mj-button background-color="#e9a03f" color="#0a0a0b" border-radius="6px" font-size="14px" font-weight="700" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#0a0a0b">
    <mj-section padding="32px 24px 12px">
      <mj-column>
        <mj-image src="<%= image_url("domino-chain-logo.png") %>" alt="<%= t("layouts.application.logo_alt") %>" width="56px" padding="0 0 12px" />
        <mj-text align="center" font-size="24px" line-height="32px" font-weight="300" letter-spacing="2px" padding="0">DominoChain</mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#121214" border="1px solid #2a2a2e" border-radius="8px" padding="24px">
      <mj-column>
        <mj-text color="#8a8784" font-size="12px" letter-spacing="1.4px" text-transform="uppercase" padding="0 0 10px">
          <%= t("devise.mailer.confirmation_instructions.eyebrow") %>
        </mj-text>
        <mj-text font-size="22px" line-height="30px" font-weight="600" padding="0 0 12px">
          <%= t("devise.mailer.confirmation_instructions.heading") %>
        </mj-text>
        <mj-text padding="0 0 18px">
          <%= t("devise.mailer.confirmation_instructions.body", email: @resource.email) %>
        </mj-text>
        <mj-button href="<%= user_confirmation_url(confirmation_token: @token) %>" align="left" padding="0">
          <%= t("devise.mailer.confirmation_instructions.cta") %>
        </mj-button>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
