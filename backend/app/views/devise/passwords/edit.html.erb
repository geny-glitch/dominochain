<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <h1 class="ds-title"><%= t("devise.passwords.edit_title") %></h1>
    </header>

    <%= form_for(resource, as: resource_name, url: user_password_path, html: { method: :put, class: "ds-form ds-auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="ds-form-group">
        <%= f.label :password, t("devise.passwords.new_password"), class: "ds-form-label" %>
        <% if @minimum_password_length %>
          <span class="ds-form-hint">(<%= t("devise.registrations.password_hint", count: @minimum_password_length) %>)</span>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password_confirmation, t("devise.passwords.confirm_password"), class: "ds-form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "ds-input" %>
      </div>

      <div class="ds-form-actions">
        <%= f.submit t("devise.passwords.submit_change"), class: "ds-btn ds-btn--primary" %>
      </div>
    <% end %>

    <nav class="ds-auth-links">
      <%= render "devise/shared/links" %>
    </nav>
  </div>
</div>
