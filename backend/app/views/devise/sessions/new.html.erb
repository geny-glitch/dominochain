<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: t("layouts.application.logo_alt"), class: "ds-header-logo", width: 48, height: 48 %>
      <h1 class="ds-title wordmark">DominoChain</h1>
      <p class="ds-subtitle eyebrow"><%= t("devise.sessions.title") %></p>
    </header>

    <%= form_for(resource, as: resource_name, url: user_session_path, html: { class: "ds-form ds-auth-form" }) do |f| %>
      <div class="ds-form-group">
        <%= f.label :email, t("devise.sessions.email"), class: "ds-form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "ds-input" %>
      </div>

      <div class="ds-form-group">
        <%= f.label :password, t("devise.sessions.password"), class: "ds-form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "ds-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="ds-form-group">
          <label class="ds-checkbox-label">
            <%= f.check_box :remember_me %>
            <span><%= t("devise.sessions.remember_me") %></span>
          </label>
        </div>
      <% end %>

      <div class="ds-form-actions">
        <%= f.submit t("devise.sessions.submit"), class: "ds-btn ds-btn--primary" %>
      </div>
    <% end %>

    <nav class="ds-auth-links">
      <%= render "devise/shared/links" %>
    </nav>
  </div>
</div>
