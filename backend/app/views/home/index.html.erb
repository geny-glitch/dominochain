<% content_for :title, "OTB - Own their backgrounds" %>

<div class="home">
  <div class="home__collage" aria-hidden="true">
    <% 24.times do |i| %>
      <div class="home__collage-tile" style="--i: <%= i %>">
        <img src="https://picsum.photos/seed/<%= ['lifestyle', 'aesthetic', 'mood', 'vibe', 'style', 'photo'][i % 6] %>-<%= i %>/400/300" alt="" loading="lazy" />
      </div>
    <% end %>
  </div>

  <div class="home__content">
    <div class="home__logo">
      <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#0f0f1a"/>
            <stop offset="100%" style="stop-color:#1a1a2e"/>
          </linearGradient>
        </defs>
        <rect width="120" height="120" rx="28" fill="url(#logoGrad)"/>
        <rect x="14" y="14" width="92" height="92" rx="18" fill="none" stroke="white" stroke-width="2.5" opacity="0.95"/>
        <rect x="26" y="26" width="68" height="68" rx="12" fill="none" stroke="white" stroke-width="1.5" opacity="0.6"/>
        <rect x="38" y="38" width="44" height="44" rx="8" fill="white" opacity="0.2"/>
        <rect x="44" y="44" width="32" height="32" rx="4" fill="white" opacity="0.85"/>
      </svg>
    </div>
    <h1 class="home__title">OTB</h1>
    <p class="home__tagline">Own their backgrounds</p>
  </div>
</div>
