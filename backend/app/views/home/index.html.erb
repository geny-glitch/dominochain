<% content_for :title, t("home.title") %>

<div class="ds-home">
  <div class="ds-home__content">
    <div class="ds-home__logo">
      <%= image_tag "domino-chain-logo.png", alt: "Domino Chain", width: 120, height: 120 %>
    </div>
    <h1 class="ds-home__title wordmark">DominoChain</h1>
    <nav class="ds-home__auth">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= link_to t("home.admin"), admin_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% elsif current_user.beta? %>
          <%= link_to t("home.my_dashboard"), beta_dashboard_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% else %>
          <%= link_to t("home.dashboard"), dashboard_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>
        <%= button_to t("home.sign_out"), destroy_user_session_path, method: :delete, class: "ds-btn ds-btn--ghost ds-btn--sm", form: { style: "display: contents" } %>
      <% else %>
        <%= link_to t("home.sign_in"), new_user_session_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <%= link_to t("home.sign_up_beta"), new_user_registration_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
      <% end %>
    </nav>
  </div>
</div>
