<% content_for :title, "OTB - Own their backgrounds" %>

<div class="ds-home">
  <div class="ds-home__collage" id="influencer-collage" aria-hidden="true">
    <% if @tiles.any? %>
      <% @tiles.each_with_index do |tile, i| %>
        <div class="ds-home__collage-tile" data-index="<%= i %>" data-name="<%= tile[:name] %>" style="--i: <%= i %>">
          <img src="<%= tile[:url] %>" alt="" loading="lazy" />
        </div>
      <% end %>
    <% else %>
      <p class="ds-home__empty">Aucune image. Configure la liste dans Admin > Paramètres, puis enregistre ou lance <code>rails wikimedia:fetch_images</code>.</p>
    <% end %>
  </div>

  <div class="ds-home__content">
    <div class="ds-home__logo">
      <%= image_tag "otb-logo.png", alt: "OTB", width: 120, height: 120 %>
    </div>
    <h1 class="ds-home__title">OTB</h1>
    <p class="ds-home__tagline">Own their backgrounds</p>
    <nav class="ds-home__auth">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= link_to "Admin", admin_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% elsif current_user.beta? %>
          <%= link_to "Mon dashboard", beta_dashboard_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% else %>
          <%= link_to "Dashboard", dashboard_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>
        <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "ds-btn ds-btn--ghost ds-btn--sm" %>
      <% else %>
        <%= link_to "Connexion", new_user_session_path, class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <%= link_to "Inscription Beta", new_user_registration_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
        <%= link_to "Inscription Boss", new_boss_registration_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
      <% end %>
    </nav>
  </div>
</div>

<script>
(function() {
  const allUrls = <%= raw @all_urls.to_json %>;
  const collage = document.getElementById('influencer-collage');
  if (!collage || allUrls.length === 0) return;

  const tiles = collage.querySelectorAll('.ds-home__collage-tile');
  const total = tiles.length;

  function getRandomUrl() {
    return allUrls[Math.floor(Math.random() * allUrls.length)];
  }

  function getRandomTile() {
    return tiles[Math.floor(Math.random() * total)];
  }

  function refreshTile(tile) {
    const img = tile.querySelector('img');
    if (!img) return;
    const newUrl = getRandomUrl();
    tile.classList.add('ds-home__collage-tile--refreshing');
    img.onload = function() {
      setTimeout(function() {
        tile.classList.remove('ds-home__collage-tile--refreshing');
      }, 500);
    };
    img.src = newUrl;
  }

  setInterval(function() {
    const tile = getRandomTile();
    refreshTile(tile);
  }, 1000);
})();
</script>
