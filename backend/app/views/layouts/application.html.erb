<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("layouts.application.default_title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= render "shared/robots_meta" %>
    <meta name="theme-color" content="#0a0a0b">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/favicons/favicon-48.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96.png">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicons/icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/favicons/icon-512.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= render "shared/posthog" %>
  </head>

  <body class="<%= content_for?(:body_class) ? yield(:body_class) : '' %>">
    <% if flash[:notice].present? %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert].present? %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>
    <%= yield %>
  </body>
</html>
