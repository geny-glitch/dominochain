<% content_for :title, "Debug PiShock API" %>

<div class="ds-page">
  <div class="ds-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: "Domino Chain", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Debug PiShock (étapes API)</h1>
        <p class="ds-subtitle"><%= current_user.nickname %> — suivi de la <a href="https://docs.pishock.com/pishock/api-documentation/pishock-api-documentation.html" target="_blank" rel="noopener noreferrer">doc officielle</a></p>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <p class="ds-beta-control-hint" style="margin-bottom: 1rem;">
      Les appels partent du <strong>serveur Rails</strong>. Journaux et gros JSON : <strong>Rails.cache</strong> (pas le cookie), sauf en dev si le cache est désactivé — alors aperçus courts pour éviter le dépassement cookie.
      <% if @pishock_debug_cookie_limited %>
        <span class="ds-text-muted"> Ici : active <code>bin/rails dev:cache</code> pour des aperçus complets.</span>
      <% end %>
      <%= button_to "Effacer session + journaux", beta_pishock_debug_clear_path, method: :post, class: "ds-btn ds-btn--ghost ds-btn--sm", form: { style: "display:inline;" } %>
      <%= link_to "← Actions PiShock", beta_actions_pishock_path, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
    </p>

    <section class="ds-beta-section">
      <h2 class="ds-section-title">Contexte (session)</h2>
      <div class="ds-beta-control-card">
        <dl style="margin:0; display:grid; gap:0.35rem; font-size:0.9rem;">
          <dt class="ds-text-muted">Username</dt><dd><%= @ctx["username"].presence || "—" %></dd>
          <dt class="ds-text-muted">API key</dt><dd><%= @ctx["apikey"].present? ? "[présente, masquée]" : "—" %></dd>
          <dt class="ds-text-muted">UserId (étape 1)</dt><dd><%= @ctx["user_id"].presence || "—" %></dd>
        </dl>
      </div>
    </section>

    <section class="ds-beta-section">
      <h2 class="ds-section-title">1. GetUserIfAPIKeyValid</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">GET <code>auth.pishock.com/Auth/GetUserIfAPIKeyValid</code> — vérifie username + clé API, retour JSON avec <code>UserId</code>.</p>
        <%= form_with url: beta_pishock_debug_step1_path, method: :post, local: true, class: "ds-form" do %>
          <div class="ds-form-group">
            <%= label_tag "pishock_debug_username", "Username PiShock", class: "ds-form-label" %>
            <%= text_field_tag "pishock_debug[username]", @prefill_username, class: "ds-input", autocomplete: "username", required: true %>
          </div>
          <div class="ds-form-group">
            <%= label_tag "pishock_debug_apikey", "Clé API", class: "ds-form-label" %>
            <%= password_field_tag "pishock_debug[apikey]", nil, class: "ds-input", autocomplete: "off", required: true, placeholder: @ctx["apikey"].present? ? "Laisser vide pour réutiliser la clé en session (non supporté ici — ressaisir ou effacer la session)" : "" %>
          </div>
          <%= submit_tag "Exécuter l’étape 1", class: "ds-btn ds-btn--primary ds-btn--sm" %>
        <% end %>
        <p class="ds-beta-control-hint">Après succès, le <code>UserId</code> est extrait pour les étapes suivantes.</p>
      </div>
    </section>

    <section class="ds-beta-section">
      <h2 class="ds-section-title">2. GetUserDevices</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">GET <code>ps.pishock.com/PiShock/GetUserDevices?UserId=…&amp;Token={apikey}&amp;api=true</code></p>
        <%= button_to "Exécuter l’étape 2", beta_pishock_debug_step2_path, method: :post, class: "ds-btn ds-btn--secondary ds-btn--sm", disabled: @ctx["user_id"].blank? %>
      </div>
    </section>

    <section class="ds-beta-section">
      <h2 class="ds-section-title">3. GetShareCodesByOwner</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">GET <code>ps.pishock.com/PiShock/GetShareCodesByOwner?UserId=…&amp;Token={apikey}&amp;api=true</code></p>
        <%= button_to "Exécuter l’étape 3", beta_pishock_debug_step3_path, method: :post, class: "ds-btn ds-btn--secondary ds-btn--sm", disabled: @ctx["user_id"].blank? %>
      </div>
    </section>

    <section class="ds-beta-section">
      <h2 class="ds-section-title">4. GetShockersByShareIds</h2>
      <div class="ds-beta-control-card">
        <p class="ds-beta-control-text">GET avec <code>shareIds</code> répétés (IDs numériques, pas les codes alphanumériques du site).</p>
        <%= form_with url: beta_pishock_debug_step4_path, method: :post, local: true, class: "ds-form" do %>
          <div class="ds-form-group">
            <%= label_tag "pishock_debug_share_ids", "Share IDs (séparés par virgule)", class: "ds-form-label" %>
            <%= text_field_tag "pishock_debug[share_ids]", nil, class: "ds-input", placeholder: "ex. 123, 456", required: true, disabled: @ctx["user_id"].blank? %>
          </div>
          <%= submit_tag "Exécuter l’étape 4", class: "ds-btn ds-btn--secondary ds-btn--sm", disabled: @ctx["user_id"].blank? %>
        <% end %>
      </div>
    </section>

    <% if @logs.any? %>
      <section class="ds-beta-section">
        <h2 class="ds-section-title">Journal (dernières requêtes)</h2>
        <% @logs.reverse_each do |log| %>
          <div class="ds-beta-control-card" style="margin-bottom: 0.75rem;">
            <h3 class="ds-section-title" style="font-size:1rem;"><%= log["title"] %> — HTTP <%= log["http_status"] %> <%= log["http_success"] ? "✓" : "✗" %></h3>
            <p class="ds-beta-control-hint" style="font-size:0.8rem;"><%= log["doc"] %></p>
            <p class="ds-beta-control-text" style="font-size:0.8rem;"><strong>Requête :</strong> <code style="word-break:break-all;"><%= log["request_summary"] %></code></p>
            <p class="ds-beta-control-hint" style="font-size:0.75rem;"><%= log["at"] %></p>
            <pre class="ds-input" style="white-space:pre-wrap; max-height:20rem; overflow:auto; font-size:0.75rem; margin-top:0.5rem;"><%= log["body_preview"].presence || "(vide)" %></pre>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
