<script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  (function() {
    const root = document.querySelector("[data-image-editor]");
    if (!root) return;
    const submitMode = root.dataset.submitMode || "wallpaper";
    const uploadUrl = root.dataset.uploadUrl;
    const betaPageUrl = root.dataset.redirectUrl;
    const aspectRatioAttr = root.dataset.aspectRatio;
    const aspectRatio = aspectRatioAttr === "" || aspectRatioAttr == null
      ? NaN
      : parseFloat(aspectRatioAttr);
    const labelSubmitting = root.dataset.labelSubmitting || "Sending...";
    const labelSubmit = root.dataset.labelSubmit || "Submit";
    const labelSkipCensor = root.dataset.labelSkipCensor || "Skip for now";
    const labelBatchUploading = root.dataset.labelBatchUploading || "Uploading…";
    const labelError = root.dataset.labelError || "Upload error.";
    const allowSkipCensor = root.dataset.allowSkipCensor === "true";
    const allowMulti = root.dataset.allowMulti === "true";
    const preloadUrl = root.dataset.preloadUrl || "";
    const HINTS = {
      text: root.dataset.hintText || "",
      pixelate: root.dataset.hintPixelate || ""
    };
    let sourceFile = null;

    const input         = document.getElementById('image-input');
    const form          = document.getElementById('upload-form');
    const stepChoose    = document.getElementById('step-choose');
    const stepCrop      = document.getElementById('step-crop');
    const stepEdit      = document.getElementById('step-edit');
    const stepIndicator = document.getElementById('step-indicator');
    const cropImg       = document.getElementById('crop-img');
    const changeImageBtn = document.getElementById('change-image-btn');
    const suivantBtn   = document.getElementById('suivant-btn');
    const skipCensorBtn = document.getElementById('skip-censor-btn');
    const batchStatus   = document.getElementById('batch-status');

    let cropper = null;

    function setStep(n) {
      [stepChoose, stepCrop, stepEdit].forEach(function(el, i) {
        if (el) el.style.display = (i + 1) === n ? '' : 'none';
      });
      stepIndicator.querySelectorAll('.ds-upload-step').forEach(function(el) {
        el.classList.toggle('ds-upload-step--active', parseInt(el.dataset.step) === n);
      });
    }

    function csrfToken() {
      return form.querySelector('input[name="authenticity_token"]')?.value ||
        document.querySelector('meta[name="csrf-token"]')?.content || "";
    }

    function fileToCanvas(file) {
      return new Promise(function(resolve, reject) {
        const url = URL.createObjectURL(file);
        const img = new Image();
        img.onload = function() {
          const canvas = document.createElement("canvas");
          canvas.width = img.naturalWidth || img.width;
          canvas.height = img.naturalHeight || img.height;
          canvas.getContext("2d").drawImage(img, 0, 0);
          URL.revokeObjectURL(url);
          resolve(canvas);
        };
        img.onerror = function() {
          URL.revokeObjectURL(url);
          reject(new Error("image load failed"));
        };
        img.src = url;
      });
    }

    function blobToObjectUrl(blob) {
      return URL.createObjectURL(blob);
    }

    async function postLeverageDraft(formData) {
      const token = csrfToken();
      if (token) formData.append("authenticity_token", token);
      const res = await fetch(uploadUrl, {
        method: "POST",
        body: formData,
        credentials: "same-origin",
        headers: { "X-CSRF-Token": token || "", "Accept": "application/json" }
      });
      const data = await res.json().catch(function() { return {}; });
      if (!res.ok) throw new Error(data.error || "upload failed");
      return data;
    }

    async function uploadDraftFromFile(file, censoredCanvas) {
      if (!file) throw new Error("missing original file");
      const originalCanvas = await fileToCanvas(file);
      const teaserBlob = await canvasToBlob(buildTeaserCanvas(originalCanvas), "image/jpeg", 0.8);
      const originalName = file.name || "photo.jpg";
      const formData = new FormData();
      formData.append("original_filename", originalName);
      formData.append("original_image", file, originalName);
      formData.append("teaser_image", teaserBlob, "teaser.jpg");
      if (censoredCanvas) {
        const censoredBlob = await canvasToBlob(censoredCanvas, "image/jpeg", 0.9);
        formData.append("censored_image", censoredBlob, "censored.jpg");
      }
      return postLeverageDraft(formData);
    }

    async function uploadBatch(files) {
      const list = Array.prototype.slice.call(files).filter(function(f) {
        return f && f.type && f.type.startsWith("image/");
      });
      if (list.length === 0) return;
      if (batchStatus) {
        batchStatus.style.display = "";
        batchStatus.textContent = labelBatchUploading.replace("%{current}", "0").replace("%{total}", String(list.length));
      }
      for (let i = 0; i < list.length; i++) {
        if (batchStatus) {
          batchStatus.textContent = labelBatchUploading
            .replace("%{current}", String(i + 1))
            .replace("%{total}", String(list.length));
        }
        await uploadDraftFromFile(list[i], null);
      }
      window.location.href = betaPageUrl;
    }

    function initCropper() {
      if (cropper) cropper.destroy();
      const cropperOpts = {
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        restore: false
      };
      if (!Number.isNaN(aspectRatio) && aspectRatio > 0) {
        cropperOpts.aspectRatio = aspectRatio;
      }
      cropper = new Cropper(cropImg, cropperOpts);
    }

    function showCrop(file) {
      const reader = new FileReader();
      reader.onload = function() {
        cropImg.src = reader.result;
        setStep(2);
        cropImg.onload = function() { initCropper(); };
      };
      reader.readAsDataURL(file);
    }

    function resetToChoose() {
      if (cropper) { cropper.destroy(); cropper = null; }
      cropImg.src = '';
      input.value = '';
      sourceFile = null;
      setStep(1);
    }

    if (input) {
      input.addEventListener('change', function(e) {
        const files = e.target.files;
        if (!files || files.length === 0) return;
        if (allowMulti && submitMode === "leverage_upload" && files.length > 1) {
          uploadBatch(files).catch(function(err) {
            console.error("[image_editor] batch upload failed", err);
            if (batchStatus) {
              batchStatus.style.display = "";
              batchStatus.textContent = labelError;
            } else {
              alert(labelError);
            }
            input.value = "";
          });
          return;
        }
        const file = files[0];
        if (!file || !file.type.startsWith('image/')) return;
        sourceFile = file;
        showCrop(file);
      });
    }

    if (changeImageBtn) changeImageBtn.addEventListener('click', resetToChoose);

    if (preloadUrl && submitMode === "leverage_censor") {
      fetch(preloadUrl, { credentials: "same-origin" })
        .then(function(res) {
          if (!res.ok) throw new Error("preload failed");
          return res.blob();
        })
        .then(function(blob) {
          sourceFile = new File([blob], "photo.jpg", { type: blob.type || "image/jpeg" });
          const url = blobToObjectUrl(blob);
          cropImg.src = url;
          setStep(2);
          cropImg.onload = function() { initCropper(); };
        })
        .catch(function(err) {
          console.error("[image_editor] preload failed", err);
          alert(labelError);
        });
    }

    if (suivantBtn) {
      suivantBtn.addEventListener('click', function() {
        if (!cropper) return;
        const croppedCanvas = cropper.getCroppedCanvas();
        if (!croppedCanvas) return;
        initEditStep(croppedCanvas);
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && stepCrop && stepCrop.style.display !== 'none') {
        e.preventDefault();
        if (suivantBtn) suivantBtn.click();
      }
    });

    // ── STEP 3 : EDIT ──────────────────────────────────────────────────────────

    const editCanvas      = document.getElementById('edit-canvas');
    const canvasWrapper   = document.getElementById('canvas-wrapper');
    const editBackBtn     = document.getElementById('edit-back-btn');
    const editSubmitBtn   = document.getElementById('edit-submit-btn');
    const toolTextBtn     = document.getElementById('tool-text');
    const toolPixelateBtn = document.getElementById('tool-pixelate');
    const toolUndoBtn     = document.getElementById('tool-undo');
    const textOptions     = document.getElementById('text-options');
    const pixelateOptions = document.getElementById('pixelate-options');
    const textFontInput   = document.getElementById('text-font');
    const textAlignBtns   = document.querySelectorAll('.ds-editor-align-btn');
    const textColorInput  = document.getElementById('text-color');
    const textSizeInput   = document.getElementById('text-size');
    const textSizeDisplay = document.getElementById('text-size-display');
    const brushSizeInput  = document.getElementById('brush-size');
    const pixelSizeInput  = document.getElementById('pixel-size');
    const pixelSizeDisplay = document.getElementById('pixel-size-display');
    const floatingInput   = document.getElementById('floating-text-input');
    const floatingWrapper = document.getElementById('floating-text-wrapper');
    const textDeleteBtn   = document.getElementById('text-delete-btn');
    const editorHint      = document.getElementById('editor-hint');
    const brushCursor     = document.getElementById('brush-cursor');

    let editCtx = null;
    let imageLayer = null;
    let texts = [];
    let currentTool = 'pixelate';
    let undoStack = [];
    let pendingCanvasX = 0, pendingCanvasY = 0;
    let draggingTextIndex = -1;
    let dragOffsetX = 0, dragOffsetY = 0;
    let editingTextIndex = -1;
    let potentialDrag = null;
    let isBrushDrawing = false;
    let lastBrushX = -1, lastBrushY = -1;
    let brushStrokePositions = [];
    let brushStrokeImageData = null;
    let skipNextTouchEndForNewText = false;

    function getCSSToCanvasScale() {
      const r = editCanvas.getBoundingClientRect();
      return { x: editCanvas.width / r.width, y: editCanvas.height / r.height };
    }

    function clientToCanvas(clientX, clientY) {
      const rect = editCanvas.getBoundingClientRect();
      const scale = getCSSToCanvasScale();
      return { x: (clientX - rect.left) * scale.x, y: (clientY - rect.top) * scale.y };
    }

    function saveUndoState() {
      if (!imageLayer || !editCtx) return;
      const imgCopy = editCtx.createImageData(imageLayer);
      imgCopy.data.set(imageLayer.data);
      undoStack.push({ imageData: imgCopy, texts: JSON.parse(JSON.stringify(texts)) });
      if (undoStack.length > 20) undoStack.shift();
    }

    function setTool(tool) {
      currentTool = tool;
      toolTextBtn.classList.toggle('ds-tool-btn--active', tool === 'text');
      toolPixelateBtn.classList.toggle('ds-tool-btn--active', tool === 'pixelate');
      if (canvasWrapper) canvasWrapper.classList.toggle('ds-tool-pixelate', tool === 'pixelate');
      textOptions.style.display = tool === 'text' ? '' : 'none';
      pixelateOptions.style.display = tool === 'pixelate' ? '' : 'none';
      if (editorHint) editorHint.textContent = HINTS[tool] || '';
      cancelText();
    }

    function initEditStep(croppedCanvas) {
      editCanvas.width  = croppedCanvas.width;
      editCanvas.height = croppedCanvas.height;
      editCtx = editCanvas.getContext('2d');
      editCtx.drawImage(croppedCanvas, 0, 0);
      imageLayer = editCtx.getImageData(0, 0, editCanvas.width, editCanvas.height);
      texts = [];
      undoStack = [];
      setStep(3);
      setTool('pixelate');
      render();
    }

    function canvasToBlob(canvas, type, quality) {
      return new Promise(function(resolve) {
        canvas.toBlob(function(blob) { resolve(blob); }, type, quality);
      });
    }

    function buildTeaserCanvas(sourceCanvas) {
      const w = sourceCanvas.width;
      const h = sourceCanvas.height;
      const scale = Math.min(50 / w, 50 / h, 1);
      const teaser = document.createElement("canvas");
      teaser.width = Math.max(1, Math.round(w * scale));
      teaser.height = Math.max(1, Math.round(h * scale));
      const ctx = teaser.getContext("2d");
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(sourceCanvas, 0, 0, teaser.width, teaser.height);
      return teaser;
    }

    function getBrushStrokeRect() {
      if (brushStrokePositions.length === 0) return null;
      const brushSize = parseInt(brushSizeInput.value) || 320;
      const half = brushSize / 2;
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      brushStrokePositions.forEach(function(p) {
        minX = Math.min(minX, p.x - half);
        minY = Math.min(minY, p.y - half);
        maxX = Math.max(maxX, p.x + half);
        maxY = Math.max(maxY, p.y + half);
      });
      const x = Math.max(0, Math.round(minX));
      const y = Math.max(0, Math.round(minY));
      const w = Math.min(Math.round(maxX - minX), editCanvas.width - x);
      const h = Math.min(Math.round(maxY - minY), editCanvas.height - y);
      return w > 0 && h > 0 ? { x: x, y: y, w: w, h: h } : null;
    }

    function buildBrushPreview() {
      if (!brushStrokeImageData || brushStrokePositions.length === 0) return null;
      const rect = getBrushStrokeRect();
      if (!rect) return null;
      const preview = editCtx.createImageData(brushStrokeImageData);
      preview.data.set(brushStrokeImageData.data);
      const brushSize = parseInt(brushSizeInput.value) || 320;
      const pixelSize = parseInt(pixelSizeInput.value) || 44;
      pixelateRegionCircular(preview, brushStrokeImageData, rect, brushStrokePositions, brushSize, pixelSize);
      return preview;
    }

    function getFontFamily(t) {
      return t.font || (textFontInput ? textFontInput.value : 'Inter, -apple-system, sans-serif');
    }

    function getTextAlign(t) {
      return t.align || (document.querySelector('.ds-editor-align-btn--active')?.dataset?.align) || 'center';
    }

    function getTextBlockMetrics(t) {
      const font = getFontFamily(t);
      const align = getTextAlign(t);
      editCtx.font = `bold ${t.fontSize}px ${font}`;
      const lines = (t.text || '').split('\n');
      const lineHeight = t.fontSize * 1.2;
      const widths = lines.map(function(l) { return editCtx.measureText(l).width; });
      const maxWidth = widths.length ? Math.max.apply(null, widths) : 0;
      const totalHeight = lines.length * lineHeight;
      let left, right;
      if (align === 'center') {
        left = t.x - maxWidth / 2;
        right = t.x + maxWidth / 2;
      } else if (align === 'right') {
        left = t.x - maxWidth;
        right = t.x;
      } else {
        left = t.x;
        right = t.x + maxWidth;
      }
      return { lines, widths, lineHeight, totalHeight, left, right, top: t.y - totalHeight / 2, bottom: t.y + totalHeight / 2 };
    }

    function render(alternateImageData) {
      if (!editCtx || !imageLayer) return;
      const src = alternateImageData || imageLayer;
      editCtx.putImageData(src, 0, 0);
      texts.forEach(function(t, i) {
        if (i === editingTextIndex) return;
        const font = getFontFamily(t);
        const align = getTextAlign(t);
        editCtx.font = `bold ${t.fontSize}px ${font}`;
        editCtx.fillStyle = t.color;
        editCtx.textAlign = align;
        editCtx.textBaseline = 'middle';
        editCtx.shadowColor = 'rgba(0,0,0,0.8)';
        editCtx.shadowBlur = Math.max(3, t.fontSize * 0.15);
        const m = getTextBlockMetrics(t);
        let y = t.y - m.totalHeight / 2 + m.lineHeight / 2;
        m.lines.forEach(function(line, idx) {
          editCtx.fillText(line, t.x, y);
          y += m.lineHeight;
        });
        editCtx.textAlign = 'left';
        editCtx.textBaseline = 'top';
        editCtx.shadowBlur = 0;
      });
    }

    function hitTestText(cx, cy) {
      if (!editCtx) return -1;
      for (let i = texts.length - 1; i >= 0; i--) {
        const m = getTextBlockMetrics(texts[i]);
        if (cx >= m.left && cx <= m.right && cy >= m.top && cy <= m.bottom) return i;
      }
      return -1;
    }

    function setAlignActive(align) {
      textAlignBtns.forEach(function(btn) {
        btn.classList.toggle('ds-editor-align-btn--active', btn.dataset.align === align);
      });
    }

    function getFloatingInputPadPx() {
      const style = floatingInput && window.getComputedStyle(floatingInput);
      return style ? (parseFloat(style.paddingLeft) || 0) + (parseFloat(style.borderLeftWidth) || 0) : 7;
    }

    function showFloatingInput(cssX, cssY, canvasX, canvasY, textIndex) {
      editingTextIndex = textIndex !== undefined ? textIndex : -1;
      pendingCanvasX = canvasX;
      pendingCanvasY = canvasY;
      const scale = getCSSToCanvasScale();
      let displaySize, color, font, align;
      if (editingTextIndex >= 0) {
        const t = texts[editingTextIndex];
        displaySize = t.fontSize / scale.x;
        color = t.color;
        font = getFontFamily(t);
        align = getTextAlign(t);
        floatingInput.innerText = t.text || '';
        if (textDeleteBtn) textDeleteBtn.style.display = '';
        if (textFontInput) textFontInput.value = font;
        setAlignActive(align);
        const padPx = getFloatingInputPadPx();
        if (align === 'left') cssX -= padPx;
        else if (align === 'right') cssX += padPx;
      } else {
        displaySize = parseInt(textSizeInput.value) / scale.x;
        color = textColorInput.value;
        font = textFontInput ? textFontInput.value : 'Inter, -apple-system, sans-serif';
        align = document.querySelector('.ds-editor-align-btn--active')?.dataset?.align || 'center';
        floatingInput.innerText = '';
        if (textDeleteBtn) textDeleteBtn.style.display = 'none';
      }
      floatingWrapper.style.left = cssX + 'px';
      floatingWrapper.style.top = cssY + 'px';
      floatingWrapper.style.transform = align === 'left' ? 'translate(0, -50%)' : align === 'right' ? 'translate(-100%, -50%)' : 'translate(-50%, -50%)';
      floatingInput.style.fontSize = displaySize + 'px';
      floatingInput.style.fontFamily = font;
      floatingInput.style.textAlign = align;
      floatingInput.style.color = color;
      floatingWrapper.style.display = 'block';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          floatingInput.focus({ preventScroll: true });
          const range = document.createRange();
          range.selectNodeContents(floatingInput);
          range.collapse(editingTextIndex >= 0);
          const sel = window.getSelection();
          if (sel) { sel.removeAllRanges(); sel.addRange(range); }
        });
      });
    }

    function commitText() {
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      const text = (floatingInput.innerText || '').trim();
      const wasEditing = editingTextIndex >= 0;
      const idx = editingTextIndex;
      const align = document.querySelector('.ds-editor-align-btn--active')?.dataset?.align || 'center';
      const padPx = getFloatingInputPadPx();
      floatingWrapper.style.display = 'none';
      floatingInput.innerText = '';
      editingTextIndex = -1;
      if (wasEditing) {
        saveUndoState();
        if (!text) texts.splice(idx, 1);
        else {
          texts[idx].text = text;
          texts[idx].font = textFontInput ? textFontInput.value : getFontFamily(texts[idx]);
          texts[idx].align = align;
        }
      } else {
        if (!text) return;
        saveUndoState();
        const font = textFontInput ? textFontInput.value : 'Inter, -apple-system, sans-serif';
        const scale = getCSSToCanvasScale();
        const pad = padPx * scale.x;
        const x = pendingCanvasX + (align === 'left' ? pad : align === 'right' ? -pad : 0);
        texts.push({ text: text, x: x, y: pendingCanvasY, fontSize: parseInt(textSizeInput.value), color: textColorInput.value, font: font, align: align });
      }
      render();
    }

    function cancelText() {
      if (!floatingWrapper) return;
      floatingWrapper.style.display = 'none';
      floatingInput.innerText = '';
      editingTextIndex = -1;
    }

    function deleteCurrentText() {
      if (editingTextIndex < 0) return;
      saveUndoState();
      texts.splice(editingTextIndex, 1);
      editingTextIndex = -1;
      floatingWrapper.style.display = 'none';
      floatingInput.innerText = '';
      render();
    }

    if (floatingInput) {
      floatingInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          if (e.shiftKey) {
            e.preventDefault();
            document.execCommand('insertLineBreak', false, null);
          } else {
            e.preventDefault();
            commitText();
          }
        }
        if (e.key === 'Escape') { e.preventDefault(); e.stopPropagation(); cancelText(); }
      });
      floatingInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text/plain');
        document.execCommand('insertText', false, text);
      });
    }
    if (textDeleteBtn) textDeleteBtn.addEventListener('click', function(e) { e.stopPropagation(); deleteCurrentText(); });

    if (textSizeInput && textSizeDisplay) {
      textSizeInput.addEventListener('input', function() {
        textSizeDisplay.textContent = this.value + 'px';
        if (floatingWrapper && floatingWrapper.style.display === 'block' && editingTextIndex < 0) {
          floatingInput.style.fontSize = (parseInt(this.value) / getCSSToCanvasScale().x) + 'px';
        }
      });
    }
    if (textFontInput) {
      textFontInput.addEventListener('change', function() {
        if (floatingWrapper && floatingWrapper.style.display === 'block') {
          floatingInput.style.fontFamily = this.value;
        }
      });
    }
    textAlignBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        const align = this.dataset.align;
        const prevAlign = document.querySelector('.ds-editor-align-btn--active')?.dataset?.align;
        setAlignActive(align);
        if (floatingWrapper && floatingWrapper.style.display === 'block') {
          floatingInput.style.textAlign = align;
          floatingWrapper.style.transform = align === 'left' ? 'translate(0, -50%)' : align === 'right' ? 'translate(-100%, -50%)' : 'translate(-50%, -50%)';
          var curLeft = parseFloat(floatingWrapper.style.left) || 0;
          var padPx = getFloatingInputPadPx();
          var anchorX = prevAlign === 'left' ? curLeft + padPx : prevAlign === 'right' ? curLeft - padPx : curLeft;
          var newLeft = anchorX + (align === 'left' ? -padPx : align === 'right' ? padPx : 0);
          floatingWrapper.style.left = newLeft + 'px';
        }
      });
    });
    if (brushSizeInput) brushSizeInput.addEventListener('input', function() { updateBrushCursor(); });
    if (pixelSizeInput && pixelSizeDisplay) pixelSizeInput.addEventListener('input', function() { pixelSizeDisplay.textContent = this.value; });

    function updateBrushCursor(clientX, clientY) {
      if (!brushCursor || !canvasWrapper || !editCanvas) return;
      const show = stepEdit && stepEdit.style.display !== 'none' && currentTool === 'pixelate' && !isBrushDrawing && clientX != null && clientY != null;
      if (!show) {
        brushCursor.style.display = 'none';
        return;
      }
      const wrapperRect = canvasWrapper.getBoundingClientRect();
      const canvasRect = editCanvas.getBoundingClientRect();
      if (clientX < canvasRect.left || clientX > canvasRect.right || clientY < canvasRect.top || clientY > canvasRect.bottom) {
        brushCursor.style.display = 'none';
        return;
      }
      const scale = canvasRect.width / editCanvas.width;
      const brushSize = parseInt(brushSizeInput.value) || 320;
      const sizePx = Math.max(20, brushSize * scale);
      brushCursor.style.width = sizePx + 'px';
      brushCursor.style.height = sizePx + 'px';
      brushCursor.style.left = (clientX - wrapperRect.left) + 'px';
      brushCursor.style.top = (clientY - wrapperRect.top) + 'px';
      brushCursor.style.display = 'block';
    }

    function pixelateRegionInImageData(data, x, y, w, h, blockSize) {
      const wd = data.width, ht = data.height, d = data.data;
      x = Math.max(0, Math.round(x)); y = Math.max(0, Math.round(y));
      w = Math.min(Math.round(w), wd - x); h = Math.min(Math.round(h), ht - y);
      if (w <= 0 || h <= 0) return;
      blockSize = Math.max(2, blockSize);
      for (let py = 0; py < h; py += blockSize) {
        for (let px = 0; px < w; px += blockSize) {
          const i = ((y + py) * wd + (x + px)) * 4;
          const r = d[i], g = d[i+1], b = d[i+2], a = d[i+3];
          for (let by = 0; by < blockSize && py + by < h; by++) {
            for (let bx = 0; bx < blockSize && px + bx < w; bx++) {
              const idx = ((y + py + by) * wd + (x + px + bx)) * 4;
              d[idx] = r; d[idx+1] = g; d[idx+2] = b; d[idx+3] = a;
            }
          }
        }
      }
    }

    function isInBrushCircles(px, py, positions, radius) {
      for (let i = 0; i < positions.length; i++) {
        const dx = px - positions[i].x, dy = py - positions[i].y;
        if (dx * dx + dy * dy <= radius * radius) return true;
      }
      return false;
    }

    function pixelateRegionCircular(data, originalData, rect, positions, brushSize, blockSize) {
      const wd = data.width, ht = data.height, d = data.data, orig = originalData.data;
      const half = brushSize / 2;
      const x = rect.x, y = rect.y, w = rect.w, h = rect.h;
      pixelateRegionInImageData(data, x, y, w, h, blockSize);
      for (let py = 0; py < h; py++) {
        for (let px = 0; px < w; px++) {
          const gx = x + px, gy = y + py;
          if (!isInBrushCircles(gx, gy, positions, half)) {
            const idx = (gy * wd + gx) * 4;
            d[idx] = orig[idx]; d[idx+1] = orig[idx+1]; d[idx+2] = orig[idx+2]; d[idx+3] = orig[idx+3];
          }
        }
      }
    }

    function addBrushPosition(canvasX, canvasY) {
      brushStrokePositions.push({ x: canvasX, y: canvasY });
    }

    function commitBrushStroke() {
      if (!brushStrokeImageData || brushStrokePositions.length === 0) return;
      const rect = getBrushStrokeRect();
      if (!rect) { brushStrokePositions = []; brushStrokeImageData = null; return; }
      const brushSize = parseInt(brushSizeInput.value) || 320;
      const pixelSize = parseInt(pixelSizeInput.value) || 44;
      imageLayer.data.set(brushStrokeImageData.data);
      pixelateRegionCircular(imageLayer, brushStrokeImageData, rect, brushStrokePositions, brushSize, pixelSize);
      brushStrokePositions = [];
      brushStrokeImageData = null;
    }

    function handleBrushDown(clientX, clientY) {
      const pt = clientToCanvas(clientX, clientY);
      saveUndoState();
      isBrushDrawing = true;
      brushStrokePositions = [];
      brushStrokeImageData = editCtx.createImageData(imageLayer);
      brushStrokeImageData.data.set(imageLayer.data);
      addBrushPosition(pt.x, pt.y);
      lastBrushX = pt.x; lastBrushY = pt.y;
      const preview = buildBrushPreview();
      render(preview || undefined);
    }

    function handleBrushMove(clientX, clientY) {
      if (!isBrushDrawing) return;
      const pt = clientToCanvas(clientX, clientY);
      const step = 12;
      const dist = Math.hypot(pt.x - lastBrushX, pt.y - lastBrushY);
      if (dist >= step) {
        const n = Math.floor(dist / step);
        const dx = (pt.x - lastBrushX) / (n + 1);
        const dy = (pt.y - lastBrushY) / (n + 1);
        for (let i = 1; i <= n; i++) {
          addBrushPosition(lastBrushX + dx * i, lastBrushY + dy * i);
        }
        addBrushPosition(pt.x, pt.y);
        lastBrushX = pt.x; lastBrushY = pt.y;
        const preview = buildBrushPreview();
        render(preview || undefined);
      }
    }

    function handleCanvasMouseDown(e) {
      if (floatingWrapper && floatingWrapper.style.display === 'block') { commitText(); return; }
      const wrapperRect = canvasWrapper.getBoundingClientRect();
      const pt = clientToCanvas(e.clientX, e.clientY);
      if (currentTool === 'text') {
        const hit = hitTestText(pt.x, pt.y);
        if (hit >= 0) potentialDrag = { index: hit, startX: pt.x, startY: pt.y };
        else {
          e.preventDefault();
          commitText();
          showFloatingInput(e.clientX - wrapperRect.left, e.clientY - wrapperRect.top, pt.x, pt.y);
        }
      } else if (currentTool === 'pixelate') handleBrushDown(e.clientX, e.clientY);
    }

    function handleCanvasMouseMove(e) {
      if (currentTool === 'pixelate') handleBrushMove(e.clientX, e.clientY);
      else if (currentTool === 'text') {
        if (potentialDrag) {
          const pt = clientToCanvas(e.clientX, e.clientY);
          if (Math.hypot(pt.x - potentialDrag.startX, pt.y - potentialDrag.startY) > 6) {
            saveUndoState();
            draggingTextIndex = potentialDrag.index;
            dragOffsetX = pt.x - texts[potentialDrag.index].x;
            dragOffsetY = pt.y - texts[potentialDrag.index].y;
            potentialDrag = null;
          }
        } else if (draggingTextIndex >= 0) {
          const pt = clientToCanvas(e.clientX, e.clientY);
          texts[draggingTextIndex].x = pt.x - dragOffsetX;
          texts[draggingTextIndex].y = pt.y - dragOffsetY;
          render();
        }
      }
    }

    function handleCanvasMouseUp(e) {
      if (currentTool === 'pixelate') {
        if (isBrushDrawing) { commitBrushStroke(); isBrushDrawing = false; render(); }
      }
      else if (currentTool === 'text') {
        if (draggingTextIndex >= 0) draggingTextIndex = -1;
        else if (potentialDrag) {
          const wrapperRect = canvasWrapper.getBoundingClientRect();
          const canvasRect = editCanvas.getBoundingClientRect();
          const scale = getCSSToCanvasScale();
          const t = texts[potentialDrag.index];
          showFloatingInput((canvasRect.left - wrapperRect.left) + t.x / scale.x, (canvasRect.top - wrapperRect.top) + t.y / scale.y, t.x, t.y, potentialDrag.index);
          potentialDrag = null;
          render();
        }
      }
    }

    if (canvasWrapper) {
      canvasWrapper.addEventListener('mousemove', function(e) { updateBrushCursor(e.clientX, e.clientY); });
      canvasWrapper.addEventListener('mouseleave', function() { updateBrushCursor(); });
    }

    if (editCanvas) {
      editCanvas.addEventListener('mousedown', handleCanvasMouseDown);
      editCanvas.addEventListener('touchstart', function(e) {
        const t = e.touches[0];
        if (floatingWrapper && floatingWrapper.style.display === 'block') { e.preventDefault(); commitText(); skipNextTouchEndForNewText = true; return; }
        skipNextTouchEndForNewText = false;
        if (currentTool === 'pixelate') { e.preventDefault(); handleCanvasMouseDown({ clientX: t.clientX, clientY: t.clientY }); }
        else if (currentTool === 'text') {
          const pt = clientToCanvas(t.clientX, t.clientY);
          const hit = hitTestText(pt.x, pt.y);
          if (hit >= 0) { e.preventDefault(); potentialDrag = { index: hit, startX: pt.x, startY: pt.y }; }
        }
      }, { passive: false });
      editCanvas.addEventListener('touchmove', function(e) {
        if (currentTool === 'pixelate' || draggingTextIndex >= 0 || potentialDrag) e.preventDefault();
        handleCanvasMouseMove({ clientX: e.touches[0].clientX, clientY: e.touches[0].clientY });
      }, { passive: false });
      editCanvas.addEventListener('touchend', function(e) {
        if (currentTool === 'pixelate' || draggingTextIndex >= 0 || potentialDrag) e.preventDefault();
        const t = e.changedTouches[0];
        if (currentTool === 'text') {
          if (draggingTextIndex >= 0 || potentialDrag) handleCanvasMouseUp(e);
          else if (skipNextTouchEndForNewText) skipNextTouchEndForNewText = false;
          else { const pt = clientToCanvas(t.clientX, t.clientY); commitText(); showFloatingInput(t.clientX - canvasWrapper.getBoundingClientRect().left, t.clientY - canvasWrapper.getBoundingClientRect().top, pt.x, pt.y); }
        } else handleCanvasMouseUp(e);
      }, { passive: false });
    }

    window.addEventListener('mousemove', handleCanvasMouseMove);
    window.addEventListener('mouseup', handleCanvasMouseUp);

    document.addEventListener('mousedown', function(e) {
      if (!stepEdit || stepEdit.style.display === 'none') return;
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      if (floatingWrapper.contains(e.target)) return;
      commitText();
      e.stopPropagation();
    }, true);
    document.addEventListener('touchstart', function(e) {
      if (!stepEdit || stepEdit.style.display === 'none') return;
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      if (floatingWrapper.contains(e.target)) return;
      commitText();
      skipNextTouchEndForNewText = true;
    }, { passive: true, capture: true });

    if (toolTextBtn) toolTextBtn.addEventListener('click', function() { setTool('text'); updateBrushCursor(); });
    if (toolPixelateBtn) toolPixelateBtn.addEventListener('click', function() { setTool('pixelate'); });
    if (toolUndoBtn) toolUndoBtn.addEventListener('click', function() {
      cancelText();
      if (undoStack.length > 0 && imageLayer && editCtx) { const s = undoStack.pop(); imageLayer.data.set(s.imageData.data); texts = s.texts; render(); }
    });

    if (editBackBtn) editBackBtn.addEventListener('click', function() {
      cancelText();
      setStep(2);
    });

    if (editSubmitBtn) editSubmitBtn.addEventListener('click', async function() {
      commitText();
      if (!editCanvas || !editCanvas.width || !editCtx) return;
      editSubmitBtn.disabled = true;
      if (skipCensorBtn) skipCensorBtn.disabled = true;
      editSubmitBtn.textContent = labelSubmitting;
      const token = csrfToken();
      try {
        if (submitMode === "leverage_upload") {
          const data = await uploadDraftFromFile(sourceFile, editCanvas);
          window.location.href = data.url || betaPageUrl;
          return;
        }
        if (submitMode === "leverage_censor") {
          const censoredBlob = await canvasToBlob(editCanvas, "image/jpeg", 0.9);
          const formData = new FormData();
          if (token) formData.append("authenticity_token", token);
          formData.append("censored_image", censoredBlob, "censored.jpg");
          const res = await fetch(uploadUrl, {
            method: "POST",
            body: formData,
            credentials: "same-origin",
            headers: { "X-CSRF-Token": token || "", "Accept": "text/html" },
            redirect: "follow"
          });
          if (res.ok || res.redirected) {
            window.location.href = res.url || betaPageUrl;
            return;
          }
          throw new Error("upload failed");
        }
        const formData = new FormData();
        if (token) formData.append("authenticity_token", token);
        const blob = await canvasToBlob(editCanvas, "image/jpeg", 0.9);
        formData.append("image", blob, "wallpaper.jpg");
        const res = await fetch(uploadUrl, {
          method: "POST",
          body: formData,
          credentials: "same-origin",
          headers: { "X-CSRF-Token": token || "", "Accept": "text/html" },
          redirect: "follow"
        });
        if (res.ok || res.redirected) {
          window.location.href = res.url || betaPageUrl;
        } else {
          throw new Error("upload failed");
        }
      } catch (err) {
        editSubmitBtn.disabled = false;
        if (skipCensorBtn) skipCensorBtn.disabled = false;
        editSubmitBtn.textContent = labelSubmit;
        alert(labelError);
      }
    });

    if (skipCensorBtn && allowSkipCensor) {
      skipCensorBtn.addEventListener("click", async function() {
        commitText();
        if (!sourceFile) return;
        skipCensorBtn.disabled = true;
        if (editSubmitBtn) editSubmitBtn.disabled = true;
        skipCensorBtn.textContent = labelSubmitting;
        try {
          const data = await uploadDraftFromFile(sourceFile, null);
          window.location.href = data.url || betaPageUrl;
        } catch (err) {
          console.error("[image_editor] skip censor failed", err);
          skipCensorBtn.disabled = false;
          if (editSubmitBtn) editSubmitBtn.disabled = false;
          skipCensorBtn.textContent = labelSkipCensor;
          alert(labelError);
        }
      });
    }
  })();
</script>
