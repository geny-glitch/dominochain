<% content_for :title, t("showcase.dino.title") %>
<% content_for :body_class, "dino-page-active" %>
<% content_for :head do %>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no">
<% end %>

<div class="dino-page" data-nickname="<%= @beta.nickname %>" data-dino-seconds-per-obstacle="<%= @dino_seconds_per_obstacle %>">
  <div class="dino-container">
    <div id="dino-intro" class="dino-intro">
      <h1 class="dino-title"><%= t("showcase.dino.title") %></h1>
      <p class="dino-hint"><%= t("showcase.dino.intro_hint") %></p>
      <button type="button" class="dino-btn dino-btn--start" id="dino-start"><%= t("showcase.dino.play") %></button>
    </div>

    <div id="dino-game" class="dino-game" style="display: none;">
      <div class="dino-score"><%= t("showcase.dino.time_added") %>: <span id="dino-score">0 <%= t("showcase.dino.second_singular") %></span></div>
      <canvas id="dino-canvas" class="dino-canvas" width="720" height="260"></canvas>
      <p class="dino-tap-hint"><%= t("showcase.dino.tap_hint") %></p>
    </div>

    <div id="dino-gameover" class="dino-gameover" style="display: none;">
      <h2 class="dino-gameover-title"><%= t("showcase.dino.game_over") %></h2>
      <p class="dino-gameover-score"><%= t("showcase.dino.time_added") %>: <span id="dino-final-score">0 <%= t("showcase.dino.second_singular") %></span></p>
      <div class="dino-leaderboard-form" id="dino-lb-name-block">
        <p id="dino-lb-auto-registered" class="dino-lb-registered" hidden><%= t("showcase.dino.score_saved_prefix") %> <strong id="dino-lb-registered-name"></strong></p>
        <div id="dino-lb-name-fields" class="dino-lb-name-fields">
          <input type="text" id="dino-player-name" class="dino-input" placeholder="<%= t("showcase.dino.name_placeholder") %>" maxlength="30" />
          <button type="button" class="dino-btn dino-btn--submit" id="dino-save-name"><%= t("showcase.dino.save_leaderboard") %></button>
        </div>
      </div>
      <button type="button" class="dino-btn dino-btn--ghost" id="dino-replay"><%= t("showcase.dino.replay") %></button>
    </div>
  </div>

  <section class="dino-leaderboard" id="dino-leaderboard">
    <h3 class="dino-leaderboard-title"><%= t("showcase.dino.leaderboard") %></h3>
    <div class="dino-leaderboard-toolbar">
      <label class="dino-leaderboard-toolbar-label" for="dino-lb-sort"><%= t("showcase.dino.sort_label") %></label>
      <select id="dino-lb-sort" class="dino-input dino-leaderboard-sort" aria-label="<%= t("showcase.dino.sort_aria") %>">
        <option value="score"><%= t("showcase.dino.sort_score") %></option>
        <option value="recent"><%= t("showcase.dino.sort_recent") %></option>
      </select>
    </div>
    <div id="dino-leaderboard-list" class="dino-leaderboard-list">
      <p class="dino-leaderboard-empty"><%= t("showcase.snake.empty") %></p>
    </div>
    <div id="dino-leaderboard-pagination" class="dino-leaderboard-pagination" hidden>
      <button type="button" class="dino-btn dino-btn--ghost dino-btn--sm" id="dino-lb-prev" disabled><%= t("showcase.snake.prev") %></button>
      <span class="dino-leaderboard-page-label" id="dino-lb-page-label"></span>
      <button type="button" class="dino-btn dino-btn--ghost dino-btn--sm" id="dino-lb-next"><%= t("showcase.snake.next") %></button>
    </div>
  </section>
</div>

<script type="application/json" id="dino-i18n-json"><%= raw json_escape({
  lb_empty: t("showcase.snake.empty"),
  page_of: t("showcase.snake.page_of"),
  table_aria: t("showcase.dino.table_aria"),
  col_player: t("showcase.snake.col_player"),
  col_time_added: t("showcase.dino.col_time_added"),
  col_date: t("showcase.snake.col_date"),
  col_time: t("showcase.snake.col_time"),
  minute_short: t("showcase.dino.minute_short"),
  second_short: t("showcase.dino.second_short"),
  minute_singular: t("showcase.dino.minute_singular"),
  minute_plural: t("showcase.dino.minute_plural"),
  second_singular: t("showcase.dino.second_singular"),
  second_plural: t("showcase.dino.second_plural")
}.to_json) %></script>

<% if flash[:notice] %>
  <div class="dino-flash dino-flash--success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="dino-flash dino-flash--error"><%= flash[:alert] %></div>
<% end %>

<script>
(function() {
  const pageEl = document.querySelector(".dino-page");
  const nickname = pageEl.dataset.nickname;
  const dinoI18nEl = document.getElementById("dino-i18n-json");
  const dinoI18n = dinoI18nEl ? JSON.parse(dinoI18nEl.textContent) : {};
  const LB_EMPTY_HTML = "<p class=\"dino-leaderboard-empty\">" + (dinoI18n.lb_empty || "") + "</p>";
  const PAGE_OF_TPL = dinoI18n.page_of || "";
  const secondsPerObstacle = Math.max(1, parseInt(pageEl.dataset.dinoSecondsPerObstacle || "300", 10) || 300);
  const LEADERBOARD_PER_PAGE = 10;
  const urls = {
    createSession: `/showcase/${nickname}/sessions`,
    updateSession: (id) => `/showcase/${nickname}/sessions/${id}`,
    addTime: `/showcase/${nickname}/add_time`
  };

  const canvas = document.getElementById("dino-canvas");
  const ctx = canvas.getContext("2d");
  const intro = document.getElementById("dino-intro");
  const gameEl = document.getElementById("dino-game");
  const gameoverEl = document.getElementById("dino-gameover");
  const scoreEl = document.getElementById("dino-score");
  const finalScoreEl = document.getElementById("dino-final-score");
  const playerNameInput = document.getElementById("dino-player-name");
  const saveNameBtn = document.getElementById("dino-save-name");
  const leaderboardList = document.getElementById("dino-leaderboard-list");
  const lbSortEl = document.getElementById("dino-lb-sort");
  const lbPagEl = document.getElementById("dino-leaderboard-pagination");
  const lbPrevBtn = document.getElementById("dino-lb-prev");
  const lbNextBtn = document.getElementById("dino-lb-next");
  const lbPageLabel = document.getElementById("dino-lb-page-label");
  const nameFields = document.getElementById("dino-lb-name-fields");
  const autoReg = document.getElementById("dino-lb-auto-registered");
  const regName = document.getElementById("dino-lb-registered-name");

  const WORLD_WIDTH = 720;
  const WORLD_HEIGHT = 260;
  const groundY = 202;
  const dino = { x: 70, y: 0, w: 44, h: 52, vy: 0 };
  const gravity = 0.82;
  const jumpVelocity = -15.2;
  let obstacles = [];
  let score = 0;
  let distance = 0;
  let speed = 6;
  let last = 0;
  let spawnIn = 0;
  let gameLoop = null;
  let gameOver = false;
  let currentSessionId = null;
  let lbPage = 1;
  let runFrame = 0;

  function fetchJson(url, options = {}) {
    const opts = {
      headers: { "Accept": "application/json", "Content-Type": "application/json", "X-Requested-With": "XMLHttpRequest", ...options.headers },
      ...options
    };
    return fetch(url, opts);
  }

  function postForm(url, body) {
    const formData = new URLSearchParams(body);
    return fetch(url, {
      method: "POST",
      headers: { "Accept": "application/json", "X-Requested-With": "XMLHttpRequest", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.content || "" },
      body: formData
    });
  }

  function playerCookieKey() {
    return "bgShowcasePlayer_" + nickname.replace(/[^a-zA-Z0-9]/g, "_");
  }
  function getPlayerCookie() {
    const prefix = playerCookieKey() + "=";
    const parts = document.cookie.split(";");
    for (let c of parts) {
      c = c.trim();
      if (c.startsWith(prefix)) return decodeURIComponent(c.slice(prefix.length).replace(/\+/g, " "));
    }
    return "";
  }
  function setPlayerCookie(value) {
    const maxAge = 365 * 24 * 60 * 60;
    document.cookie = playerCookieKey() + "=" + encodeURIComponent(value) + ";path=/;max-age=" + maxAge + ";SameSite=Lax";
  }
  function parsePlayedAt(iso) {
    if (!iso) return null;
    const d = new Date(iso);
    return Number.isNaN(d.getTime()) ? null : d;
  }
  function formatPlayedDate(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    const dd = String(d.getDate()).padStart(2, "0");
    const mm = String(d.getMonth() + 1).padStart(2, "0");
    return dd + "/" + mm + "/" + d.getFullYear();
  }
  function formatPlayedTime(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    const locale = document.documentElement.lang || navigator.language || "en";
    return d.toLocaleTimeString(locale, { hour: "2-digit", minute: "2-digit" });
  }
  function formatAddedTime(points) {
    const totalSeconds = Math.max(0, (parseInt(points || 0, 10) || 0) * secondsPerObstacle);
    const minutes = Math.floor(totalSeconds / 60);
    const seconds = totalSeconds % 60;
    if (minutes > 0 && seconds > 0) return minutes + " " + (dinoI18n.minute_short || "min") + " " + seconds + " " + (dinoI18n.second_short || "s");
    if (minutes > 0) return minutes + " " + (minutes > 1 ? (dinoI18n.minute_plural || "minutes") : (dinoI18n.minute_singular || "minute"));
    return seconds + " " + (seconds > 1 ? (dinoI18n.second_plural || "seconds") : (dinoI18n.second_singular || "second"));
  }
  function buildLeaderboardUrl() {
    const p = new URLSearchParams({
      game_type: "dino",
      sort: lbSortEl.value,
      page: String(lbPage),
      per_page: String(LEADERBOARD_PER_PAGE)
    });
    return "/showcase/" + nickname + "/leaderboard?" + p.toString();
  }
  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  async function addTimeForObstacle() {
    if (!currentSessionId) return;
    const updatePromise = fetchJson(urls.updateSession(currentSessionId), {
      method: "PATCH",
      body: JSON.stringify({ score: score })
    }).catch(() => {});
    const addTimePromise = secondsPerObstacle > 0 ? postForm(urls.addTime, { game_type: "dino" }).catch(() => {}) : Promise.resolve();
    await Promise.all([updatePromise, addTimePromise]);
  }

  function setDinoLeaderboardUi(showRegistered, nameForForm) {
    if (showRegistered && nameForForm) {
      nameFields.hidden = true;
      autoReg.hidden = false;
      regName.textContent = nameForForm;
    } else {
      nameFields.hidden = false;
      autoReg.hidden = true;
      playerNameInput.value = (nameForForm != null && nameForForm !== "") ? nameForForm : (getPlayerCookie() || "");
    }
  }

  function renderLeaderboardPagination(meta) {
    const { page, total_pages: totalPages, total } = meta;
    if (total === 0 || !totalPages || totalPages <= 1) {
      lbPagEl.hidden = true;
      return;
    }
    lbPagEl.hidden = false;
    lbPrevBtn.disabled = page <= 1;
    lbNextBtn.disabled = page >= totalPages;
    const tpl = PAGE_OF_TPL || "Page %{page} / %{total}";
    lbPageLabel.textContent = tpl.replace("%{page}", String(page)).replace("%{total}", String(totalPages));
  }

  async function loadLeaderboard() {
    try {
      const res = await fetchJson(buildLeaderboardUrl());
      const data = await res.json();
      if (data.error) {
        leaderboardList.innerHTML = LB_EMPTY_HTML;
        lbPagEl.hidden = true;
        return;
      }
      const entries = data.entries;
      if (Array.isArray(entries) && entries.length > 0) {
        leaderboardList.innerHTML =
          '<div class="dino-leaderboard-table-wrap">' +
          `<table class="dino-leaderboard-table" aria-label="${escapeHtml(dinoI18n.table_aria || "Leaderboard")}">` +
          "<thead><tr>" +
          '<th scope="col" class="dino-leaderboard-th dino-leaderboard-th--num">#</th>' +
          `<th scope="col" class="dino-leaderboard-th">${escapeHtml(dinoI18n.col_player || "Player")}</th>` +
          `<th scope="col" class="dino-leaderboard-th dino-leaderboard-th--score">${escapeHtml(dinoI18n.col_time_added || "Time added")}</th>` +
          `<th scope="col" class="dino-leaderboard-th dino-leaderboard-th--meta">${escapeHtml(dinoI18n.col_date || "Date")}</th>` +
          `<th scope="col" class="dino-leaderboard-th dino-leaderboard-th--meta">${escapeHtml(dinoI18n.col_time || "Time")}</th>` +
          "</tr></thead><tbody>" +
          entries.map(s =>
            "<tr>" +
            `<td class="dino-leaderboard-td dino-leaderboard-td--num">${s.rank}</td>` +
            `<td class="dino-leaderboard-td dino-leaderboard-td--name">` +
              `<strong class="dino-lb-name">${escapeHtml(s.player_name)}</strong></td>` +
            `<td class="dino-leaderboard-td dino-leaderboard-td--score">` +
              `<strong class="dino-lb-score">${escapeHtml(formatAddedTime(s.score))}</strong></td>` +
            `<td class="dino-leaderboard-td dino-leaderboard-td--date dino-lb-meta"><time datetime="${escapeHtml(s.played_at || "")}">${escapeHtml(formatPlayedDate(s.played_at))}</time></td>` +
            `<td class="dino-leaderboard-td dino-leaderboard-td--time dino-lb-meta">${escapeHtml(formatPlayedTime(s.played_at))}</td>` +
            "</tr>"
          ).join("") +
          "</tbody></table></div>";
        renderLeaderboardPagination(data);
      } else {
        leaderboardList.innerHTML = LB_EMPTY_HTML;
        lbPagEl.hidden = true;
      }
    } catch {
      leaderboardList.innerHTML = LB_EMPTY_HTML;
      lbPagEl.hidden = true;
    }
  }

  function resetGame() {
    dino.y = groundY - dino.h;
    dino.vy = 0;
    obstacles = [];
    score = 0;
    distance = 0;
    speed = 6;
    last = 0;
    spawnIn = 92;
    runFrame = 0;
    gameOver = false;
    currentSessionId = null;
    scoreEl.textContent = formatAddedTime(score);
  }

  function jump() {
    if (gameOver) return;
    if (dino.y >= groundY - dino.h - 0.5) {
      dino.vy = jumpVelocity;
    }
  }

  function currentDifficulty() {
    return Math.min(1, score / 18);
  }

  function spawnObstacle() {
    const difficulty = currentDifficulty();
    const count = Math.min(4, 1 + Math.floor(Math.random() * (2 + difficulty * 3)));
    const group = [];
    let x = WORLD_WIDTH + 16;

    for (let i = 0; i < count; i++) {
      const tall = Math.random() < 0.42 + difficulty * 0.24;
      const w = tall ? 24 : 30;
      const h = tall ? 62 : 46;
      group.push({
        x,
        y: groundY - h,
        w,
        h,
        scored: false,
        tall
      });
      x += w + 8 + Math.random() * Math.max(6, 18 - difficulty * 12);
    }

    obstacles.push(...group);
    const minGap = Math.max(44, 98 - difficulty * 42 - speed * 2);
    const maxGap = Math.max(minGap + 12, 150 - difficulty * 54 - speed * 2.8);
    spawnIn = Math.floor(minGap + Math.random() * (maxGap - minGap));
  }

  function intersects(a, b) {
    return a.x + 7 < b.x + b.w - 5 && a.x + a.w - 10 > b.x + 5 && a.y + 5 < b.y + b.h - 4 && a.y + a.h - 3 > b.y + 4;
  }

  function roundedRect(x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r);
    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h);
    ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();
  }

  function fillRoundedRect(x, y, w, h, r) {
    roundedRect(x, y, w, h, r);
    ctx.fill();
  }

  function drawDino() {
    const x = dino.x;
    const y = dino.y;
    const step = runFrame % 24 < 12;

    ctx.fillStyle = "#535353";
    fillRoundedRect(x + 5, y + 17, 29, 30, 7);
    fillRoundedRect(x + 28, y + 5, 25, 21, 5);
    fillRoundedRect(x + 47, y + 15, 11, 8, 3);
    ctx.fillRect(x + 23, y + 36, 25, 8);
    ctx.fillRect(x - 8, y + 25, 16, 7);

    ctx.fillRect(x + (step ? 10 : 16), y + 45, 7, 16);
    ctx.fillRect(x + (step ? 29 : 24), y + 45, 7, 16);
    ctx.fillRect(x + (step ? 7 : 15), y + 58, 13, 4);
    ctx.fillRect(x + (step ? 28 : 22), y + 58, 13, 4);

    ctx.fillStyle = "#f7f7f7";
    ctx.beginPath();
    ctx.arc(x + 46, y + 12, 2.2, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawCactus(c) {
    ctx.fillStyle = "#535353";
    fillRoundedRect(c.x + c.w * 0.28, c.y, c.w * 0.44, c.h, 5);
    fillRoundedRect(c.x + c.w * 0.02, c.y + c.h * 0.28, c.w * 0.28, c.h * 0.42, 4);
    fillRoundedRect(c.x + c.w * 0.68, c.y + c.h * 0.42, c.w * 0.28, c.h * 0.38, 4);
    ctx.fillRect(c.x + c.w * 0.16, c.y + c.h * 0.28, c.w * 0.22, 6);
    ctx.fillRect(c.x + c.w * 0.62, c.y + c.h * 0.42, c.w * 0.22, 6);
    ctx.fillStyle = "#f7f7f7";
    ctx.fillRect(c.x + c.w * 0.46, c.y + 8, 2, c.h - 16);
    ctx.fillRect(c.x + c.w * 0.12, c.y + c.h * 0.34, 1.5, c.h * 0.22);
    ctx.fillRect(c.x + c.w * 0.82, c.y + c.h * 0.48, 1.5, c.h * 0.18);
  }

  function draw() {
    ctx.fillStyle = "#f7f7f7";
    ctx.fillRect(0, 0, WORLD_WIDTH, WORLD_HEIGHT);
    ctx.fillStyle = "#777";
    ctx.fillRect(0, groundY, WORLD_WIDTH, 2);
    for (let i = 0; i < WORLD_WIDTH + 34; i += 34) {
      const x = (i - Math.floor(distance * 0.6) % 34);
      ctx.fillRect(x, groundY + 18, 14, 2);
    }

    drawDino();
    obstacles.forEach(drawCactus);
  }

  function update() {
    dino.vy += gravity;
    dino.y += dino.vy;
    if (dino.y > groundY - dino.h) {
      dino.y = groundY - dino.h;
      dino.vy = 0;
    }

    speed = Math.min(13.5, 6 + score * 0.28 + distance / 18000);
    distance += speed;
    runFrame += speed / 6;
    spawnIn--;
    if (spawnIn <= 0) spawnObstacle();
    obstacles.forEach(c => {
      c.x -= speed;
      if (!c.scored && c.x + c.w < dino.x) {
        c.scored = true;
        score++;
        scoreEl.textContent = formatAddedTime(score);
        addTimeForObstacle();
      }
    });
    obstacles = obstacles.filter(c => c.x + c.w > -20);

    const dinoBox = { x: dino.x, y: dino.y, w: dino.w, h: dino.h };
    if (obstacles.some(c => intersects(dinoBox, c))) {
      endGame();
    }
  }

  function run(now) {
    if (gameOver) return;
    if (!last) last = now;
    const elapsed = now - last;
    if (elapsed >= 16) {
      last = now;
      update();
      draw();
    }
    if (!gameOver) gameLoop = requestAnimationFrame(run);
  }

  async function endGame() {
    gameOver = true;
    if (gameLoop) cancelAnimationFrame(gameLoop);
    gameEl.style.display = "none";
    gameoverEl.style.display = "block";
    finalScoreEl.textContent = formatAddedTime(score);

    const saved = getPlayerCookie().trim();
    if (currentSessionId) {
      if (saved) {
        try {
          const res = await fetchJson(urls.updateSession(currentSessionId), {
            method: "PATCH",
            body: JSON.stringify({ score: score, player_name: saved })
          });
          if (res.ok) {
            setPlayerCookie(saved);
            setDinoLeaderboardUi(true, saved);
            lbPage = 1;
            lbSortEl.value = "score";
            loadLeaderboard();
            return;
          }
        } catch (_) {}
      }
      fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ score: score })
      }).catch(() => {});
    }
    setDinoLeaderboardUi(false, saved);
  }

  async function startGame() {
    resetGame();
    intro.style.display = "none";
    gameEl.style.display = "block";
    gameoverEl.style.display = "none";
    setDinoLeaderboardUi(false, getPlayerCookie() || "");

    try {
      const res = await fetchJson(urls.createSession, {
        method: "POST",
        body: JSON.stringify({ game_type: "dino" })
      });
      const data = await res.json();
      if (data.id) currentSessionId = data.id;
    } catch (_) {}

    draw();
    gameLoop = requestAnimationFrame(run);
  }

  saveNameBtn.addEventListener("click", async () => {
    const name = (playerNameInput.value || "").trim();
    if (!name || !currentSessionId) return;
    saveNameBtn.disabled = true;
    try {
      const res = await fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ player_name: name })
      });
      if (res.ok) {
        setPlayerCookie(name);
        setDinoLeaderboardUi(true, name);
        lbPage = 1;
        lbSortEl.value = "score";
        loadLeaderboard();
      }
    } finally {
      saveNameBtn.disabled = false;
    }
  });

  document.getElementById("dino-start").addEventListener("click", startGame);
  document.getElementById("dino-replay").addEventListener("click", startGame);
  lbSortEl.addEventListener("change", () => {
    lbPage = 1;
    loadLeaderboard();
  });
  lbPrevBtn.addEventListener("click", () => {
    if (lbPage > 1) { lbPage--; loadLeaderboard(); }
  });
  lbNextBtn.addEventListener("click", () => {
    if (lbNextBtn.disabled) return;
    lbPage++;
    loadLeaderboard();
  });

  canvas.addEventListener("pointerdown", (e) => {
    e.preventDefault();
    jump();
  });
  document.addEventListener("keydown", e => {
    const jumpKeys = ["ArrowUp", " ", "Space"];
    if (jumpKeys.includes(e.key)) {
      e.preventDefault();
      if (!e.repeat) jump();
    }
  }, { passive: false });

  resetGame();
  draw();
  loadLeaderboard();
})();
</script>
