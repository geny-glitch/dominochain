<% content_for :title, "Le Jeu des 1000 €" %>

<div class="quiz-page ds-page" data-nickname="<%= @beta.nickname %>">
  <div class="ds-container quiz-container">
    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: "Domino Chain", class: "ds-header-logo", width: 48, height: 48 %>
      <div>
        <h1 class="ds-title">Le Jeu des 1000 €</h1>
        <p class="ds-subtitle">Inspiré de France Inter — Culture générale</p>
      </div>
    </header>

    <div class="quiz-nav">
      <%= link_to "← Retour", showcase_path(@beta.nickname), class: "ds-btn ds-btn--ghost ds-btn--sm" %>
    </div>

    <div id="quiz-intro" class="quiz-intro">
      <p class="quiz-rules">
        6 questions : 3 bleues (15€), 2 blanches (30€), 1 rouge (45€). 60 secondes par question, autant d'essais que tu veux — une erreur ne remet pas le timer. Réponds aux 6 pour tenter le Banco (500€), puis le Super Banco (1000€) !
      </p>
      <button type="button" class="ds-btn ds-btn--primary" id="quiz-start">Jouer</button>
    </div>

    <div id="quiz-game" class="quiz-game" style="display: none;">
      <div class="quiz-progress">
        <span id="quiz-question-num">1</span> / 6
        <span class="quiz-score">Score : <strong id="quiz-score">0</strong> €</span>
      </div>
      <div id="quiz-difficulty" class="quiz-difficulty quiz-difficulty--bleu"></div>
      <p id="quiz-question" class="quiz-question"></p>
      <div class="quiz-timer">
        <div id="quiz-timer-bar" class="quiz-timer-bar"></div>
      </div>
      <div class="quiz-answer-form">
        <input type="text" id="quiz-answer" class="ds-input quiz-input" placeholder="Ta réponse..." autocomplete="off" />
        <button type="button" class="ds-btn ds-btn--primary" id="quiz-submit">Valider</button>
      </div>
    </div>

    <div id="quiz-banco-choice" class="quiz-choice" style="display: none;">
      <h2 class="quiz-choice-title">Banco !</h2>
      <p>Tu as répondu aux 6 questions. Une question difficile : 1 minute, 1 réponse. 500€ ou tu perds tout.</p>
      <div class="quiz-choice-buttons">
        <button type="button" class="ds-btn ds-btn--secondary" id="quiz-skip-banco">Garder mes gains</button>
        <button type="button" class="ds-btn ds-btn--primary" id="quiz-do-banco">Tenter le Banco</button>
      </div>
    </div>

    <div id="quiz-super-choice" class="quiz-choice" style="display: none;">
      <h2 class="quiz-choice-title">Super Banco !</h2>
      <p>Bravo ! Une dernière question très difficile : 1 minute, 1 réponse. 1000€ ou tu repars avec 500€.</p>
      <div class="quiz-choice-buttons">
        <button type="button" class="ds-btn ds-btn--secondary" id="quiz-skip-super">Garder 500€</button>
        <button type="button" class="ds-btn ds-btn--primary" id="quiz-do-super">Tenter le Super Banco</button>
      </div>
    </div>

    <div id="quiz-gameover" class="quiz-gameover" style="display: none;">
      <h2 class="quiz-gameover-title">Fin de partie</h2>
      <p class="quiz-gameover-score">Score final : <strong id="quiz-final-score">0</strong> €</p>
      <div class="quiz-leaderboard-form" id="quiz-lb-name-block">
        <p id="quiz-lb-auto-registered" class="quiz-lb-registered" hidden>Score enregistré pour <strong id="quiz-lb-registered-name"></strong></p>
        <div id="quiz-lb-name-fields" class="quiz-lb-name-fields">
          <input type="text" id="quiz-player-name" class="ds-input" placeholder="Ton pseudo pour le leaderboard" maxlength="30" />
          <button type="button" class="ds-btn ds-btn--primary" id="quiz-save-name">Enregistrer</button>
        </div>
      </div>
      <button type="button" class="ds-btn ds-btn--ghost" id="quiz-replay">Rejouer</button>
    </div>

    <section class="quiz-leaderboard" id="quiz-leaderboard">
      <h3 class="ds-section-title">Leaderboard</h3>
      <div class="quiz-leaderboard-toolbar">
        <label class="quiz-leaderboard-toolbar-label" for="quiz-lb-sort">Trier</label>
        <select id="quiz-lb-sort" class="ds-input quiz-leaderboard-sort" aria-label="Trier le classement">
          <option value="score">Meilleur score</option>
          <option value="recent">Plus récent</option>
        </select>
      </div>
      <div id="quiz-leaderboard-list" class="quiz-leaderboard-list">
        <p class="quiz-leaderboard-empty">Aucun score enregistré</p>
      </div>
      <div id="quiz-leaderboard-pagination" class="quiz-leaderboard-pagination" hidden>
        <button type="button" class="ds-btn ds-btn--ghost ds-btn--sm" id="quiz-lb-prev" disabled>Précédent</button>
        <span class="quiz-leaderboard-page-label" id="quiz-lb-page-label"></span>
        <button type="button" class="ds-btn ds-btn--ghost ds-btn--sm" id="quiz-lb-next">Suivant</button>
      </div>
    </section>
  </div>
</div>

<% if flash[:notice] %>
  <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
<% end %>

<script>
(function() {
  const POINTS = { bleu: 15, blanc: 30, rouge: 45 };
  const TIME_PER_QUESTION = 60; // comme le jeu radio : 60 s, erreur ne reset pas le timer

  const nickname = document.querySelector(".quiz-page").dataset.nickname;
  const LEADERBOARD_PER_PAGE = 10;
  const urls = {
    createSession: `/showcase/${nickname}/sessions`,
    updateSession: (id) => `/showcase/${nickname}/sessions/${id}`,
    addTime: `/showcase/${nickname}/add_time`,
    questions: `/showcase/${nickname}/questions`,
    checkAnswer: `/showcase/${nickname}/check_answer`
  };

  let questions = [];
  let currentIndex = 0;
  let score = 0;
  let currentSessionId = null;
  let timerId = null;
  let timeLeft = 0;
  let bancoWon = false;

  const intro = document.getElementById("quiz-intro");
  const gameEl = document.getElementById("quiz-game");
  const bancoChoice = document.getElementById("quiz-banco-choice");
  const superChoice = document.getElementById("quiz-super-choice");
  const gameoverEl = document.getElementById("quiz-gameover");
  const questionEl = document.getElementById("quiz-question");
  const difficultyEl = document.getElementById("quiz-difficulty");
  const questionNumEl = document.getElementById("quiz-question-num");
  const scoreEl = document.getElementById("quiz-score");
  const finalScoreEl = document.getElementById("quiz-final-score");
  const answerInput = document.getElementById("quiz-answer");
  const submitBtn = document.getElementById("quiz-submit");
  const timerBar = document.getElementById("quiz-timer-bar");
  const leaderboardList = document.getElementById("quiz-leaderboard-list");
  const lbSortEl = document.getElementById("quiz-lb-sort");
  const lbPagEl = document.getElementById("quiz-leaderboard-pagination");
  const lbPrevBtn = document.getElementById("quiz-lb-prev");
  const lbNextBtn = document.getElementById("quiz-lb-next");
  const lbPageLabel = document.getElementById("quiz-lb-page-label");
  const quizPlayerNameInput = document.getElementById("quiz-player-name");

  let lbPage = 1;

  function fetchJson(url, options = {}) {
    return fetch(url, {
      headers: { "Accept": "application/json", "Content-Type": "application/json", "X-Requested-With": "XMLHttpRequest", ...options.headers },
      ...options
    });
  }

  function postForm(url, body) {
    return fetch(url, {
      method: "POST",
      headers: { "Accept": "application/json", "X-Requested-With": "XMLHttpRequest", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.content || "", "Content-Type": "application/x-www-form-urlencoded" },
      body: new URLSearchParams(body)
    });
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function playerCookieKey() {
    return "bgShowcasePlayer_" + nickname.replace(/[^a-zA-Z0-9]/g, "_");
  }
  function getPlayerCookie() {
    const prefix = playerCookieKey() + "=";
    const parts = document.cookie.split(";");
    for (let c of parts) {
      c = c.trim();
      if (c.startsWith(prefix)) return decodeURIComponent(c.slice(prefix.length).replace(/\+/g, " "));
    }
    return "";
  }
  function setPlayerCookie(value) {
    const maxAge = 365 * 24 * 60 * 60;
    document.cookie = playerCookieKey() + "=" + encodeURIComponent(value) + ";path=/;max-age=" + maxAge + ";SameSite=Lax";
  }
  function parsePlayedAt(iso) {
    if (!iso) return null;
    const d = new Date(iso);
    return Number.isNaN(d.getTime()) ? null : d;
  }
  function formatPlayedDate(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    const dd = String(d.getDate()).padStart(2, "0");
    const mm = String(d.getMonth() + 1).padStart(2, "0");
    return dd + "/" + mm + "/" + d.getFullYear();
  }
  function formatPlayedTime(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    return d.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
  }
  function buildLeaderboardUrl() {
    const p = new URLSearchParams({
      game_type: "quiz",
      sort: lbSortEl.value,
      page: String(lbPage),
      per_page: String(LEADERBOARD_PER_PAGE)
    });
    return "/showcase/" + nickname + "/leaderboard?" + p.toString();
  }

  function setQuizLeaderboardUi(showRegistered, nameForForm) {
    const fields = document.getElementById("quiz-lb-name-fields");
    const reg = document.getElementById("quiz-lb-auto-registered");
    const regName = document.getElementById("quiz-lb-registered-name");
    if (showRegistered && nameForForm) {
      fields.hidden = true;
      reg.hidden = false;
      regName.textContent = nameForForm;
    } else {
      fields.hidden = false;
      reg.hidden = true;
      quizPlayerNameInput.value = nameForForm != null && nameForForm !== "" ? nameForForm : (getPlayerCookie() || "");
    }
  }

  async function loadQuestions() {
    const res = await fetchJson(urls.questions);
    const data = await res.json();
    return Array.isArray(data) ? data : [];
  }

  async function checkAnswer(questionId, answer) {
    const res = await fetch(urls.checkAnswer, {
      method: "POST",
      headers: { "Accept": "application/json", "Content-Type": "application/json", "X-Requested-With": "XMLHttpRequest", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.content || "" },
      body: JSON.stringify({ question_id: questionId, answer })
    });
    const data = await res.json();
    return data.correct === true;
  }

  async function addTime(seconds) {
    try {
      await postForm(urls.addTime, { seconds });
    } catch (_) {}
  }

  function clearTimer() {
    if (timerId) {
      clearInterval(timerId);
      timerId = null;
    }
  }

  function startTimer(seconds, onEnd) {
    clearTimer();
    timeLeft = seconds;
    const total = seconds;
    timerBar.style.width = "100%";

    timerId = setInterval(() => {
      timeLeft--;
      timerBar.style.width = `${(timeLeft / total) * 100}%`;
      if (timeLeft <= 0) {
        clearTimer();
        onEnd();
      }
    }, 1000);
  }

  function showQuestion() {
    const q = questions[currentIndex];
    if (!q) return;

    questionNumEl.textContent = currentIndex + 1;
    scoreEl.textContent = score;
    questionEl.textContent = q.question;
    difficultyEl.className = "quiz-difficulty quiz-difficulty--" + q.difficulty;
    difficultyEl.textContent = q.difficulty.charAt(0).toUpperCase() + q.difficulty.slice(1);
    answerInput.value = "";
    answerInput.focus();

    startTimer(TIME_PER_QUESTION, () => {
      submitBtn.disabled = true;
      nextQuestion(false);
    });
    submitBtn.disabled = false;
  }

  async function nextQuestion(correct) {
    clearTimer();
    if (correct) {
      const q = questions[currentIndex];
      const pts = POINTS[q?.difficulty] || 0;
      score += pts;
      await addTime(pts);
    }
    currentIndex++;
    if (currentIndex >= questions.length) {
      endRound();
    } else {
      showQuestion();
    }
  }

  async function endRound() {
    gameEl.style.display = "none";
    const maxScore = 15*3 + 30*2 + 45;
    if (score >= maxScore) {
      bancoChoice.style.display = "block";
    } else {
      showGameOver();
    }
  }

  async function playBanco() {
    bancoChoice.style.display = "none";
    const res = await fetchJson(urls.questions + "?type=banco");
    const data = await res.json();
    if (!data.id) {
      showGameOver();
      return;
    }
    questions = [{ id: data.id, question: data.question, difficulty: "rouge" }];
    currentIndex = 0;
    gameEl.style.display = "block";
    startTimer(TIME_PER_QUESTION, () => {
      submitBtn.disabled = true;
      bancoFailed();
    });
    showQuestion();
  }

  async function bancoFailed() {
    score = 0;
    showGameOver();
  }

  async function bancoSuccess() {
    bancoWon = true;
    score = 500;
    gameEl.style.display = "none";
    superChoice.style.display = "block";
  }

  async function playSuperBanco() {
    superChoice.style.display = "none";
    const res = await fetchJson(urls.questions + "?type=super_banco");
    const data = await res.json();
    if (!data.id) {
      score = 500;
      showGameOver();
      return;
    }
    questions = [{ id: data.id, question: data.question, difficulty: "rouge" }];
    currentIndex = 0;
    gameEl.style.display = "block";
    startTimer(TIME_PER_QUESTION, () => {
      submitBtn.disabled = true;
      score = 500;
      showGameOver();
    });
    showQuestion();
  }

  async function superBancoSuccess() {
    score = 1000;
    showGameOver();
  }

  async function showGameOver() {
    gameEl.style.display = "none";
    bancoChoice.style.display = "none";
    superChoice.style.display = "none";
    gameoverEl.style.display = "block";
    finalScoreEl.textContent = score;

    const saved = getPlayerCookie().trim();
    if (currentSessionId) {
      if (saved) {
        try {
          const res = await fetchJson(urls.updateSession(currentSessionId), {
            method: "PATCH",
            body: JSON.stringify({ score, player_name: saved })
          });
          if (res.ok) {
            setPlayerCookie(saved);
            setQuizLeaderboardUi(true, saved);
            lbPage = 1;
            lbSortEl.value = "score";
            loadLeaderboard();
            return;
          }
        } catch (_) {}
      }
      fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ score })
      }).catch(() => {});
    }
    setQuizLeaderboardUi(false, saved);
  }

  function renderLeaderboardPagination(meta) {
    const { page, total_pages: totalPages, total } = meta;
    if (total === 0 || !totalPages || totalPages <= 1) {
      lbPagEl.hidden = true;
      return;
    }
    lbPagEl.hidden = false;
    lbPrevBtn.disabled = page <= 1;
    lbNextBtn.disabled = page >= totalPages;
    lbPageLabel.textContent = "Page " + page + " / " + totalPages;
  }

  async function loadLeaderboard() {
    try {
      const res = await fetchJson(buildLeaderboardUrl());
      const data = await res.json();
      if (data.error) {
        leaderboardList.innerHTML = "<p class=\"quiz-leaderboard-empty\">Aucun score enregistré</p>";
        lbPagEl.hidden = true;
        return;
      }
      const entries = data.entries;
      if (Array.isArray(entries) && entries.length > 0) {
        leaderboardList.innerHTML =
          '<div class="quiz-leaderboard-table-wrap">' +
          '<table class="quiz-leaderboard-table" aria-label="Classement">' +
          "<thead><tr>" +
          '<th scope="col" class="quiz-leaderboard-th quiz-leaderboard-th--num">#</th>' +
          '<th scope="col" class="quiz-leaderboard-th">Joueur</th>' +
          '<th scope="col" class="quiz-leaderboard-th quiz-leaderboard-th--score">Score</th>' +
          '<th scope="col" class="quiz-leaderboard-th quiz-leaderboard-th--meta">Date</th>' +
          '<th scope="col" class="quiz-leaderboard-th quiz-leaderboard-th--meta">Heure</th>' +
          "</tr></thead><tbody>" +
          entries.map(s =>
            "<tr>" +
            `<td class="quiz-leaderboard-td quiz-leaderboard-td--num">${s.rank}</td>` +
            `<td class="quiz-leaderboard-td quiz-leaderboard-td--name"><strong>${escapeHtml(s.player_name)}</strong></td>` +
            `<td class="quiz-leaderboard-td quiz-leaderboard-td--score"><strong>${s.score} €</strong></td>` +
            `<td class="quiz-leaderboard-td quiz-leaderboard-td--date quiz-leaderboard-td--meta"><time datetime="${escapeHtml(s.played_at || "")}">${escapeHtml(formatPlayedDate(s.played_at))}</time></td>` +
            `<td class="quiz-leaderboard-td quiz-leaderboard-td--time quiz-leaderboard-td--meta">${escapeHtml(formatPlayedTime(s.played_at))}</td>` +
            "</tr>"
          ).join("") +
          "</tbody></table></div>";
        renderLeaderboardPagination(data);
      } else {
        leaderboardList.innerHTML = "<p class=\"quiz-leaderboard-empty\">Aucun score enregistré</p>";
        lbPagEl.hidden = true;
      }
    } catch {
      leaderboardList.innerHTML = "<p class=\"quiz-leaderboard-empty\">Aucun score enregistré</p>";
      lbPagEl.hidden = true;
    }
  }

  async function startGame() {
    intro.style.display = "none";
    gameoverEl.style.display = "none";
    bancoChoice.style.display = "none";
    superChoice.style.display = "none";
    setQuizLeaderboardUi(false, getPlayerCookie() || "");

    questions = await loadQuestions();
    if (questions.length < 6) {
      alert("Pas assez de questions disponibles. Lancez les seeds.");
      intro.style.display = "block";
      return;
    }

    questions = questions.slice(0, 6);
    currentIndex = 0;
    score = 0;
    bancoWon = false;

    try {
      const res = await fetchJson(urls.createSession, {
        method: "POST",
        body: JSON.stringify({ game_type: "quiz" })
      });
      const data = await res.json();
      if (data.id) currentSessionId = data.id;
    } catch (_) {}

    gameEl.style.display = "block";
    showQuestion();
  }

  submitBtn.addEventListener("click", async () => {
    const answer = answerInput.value.trim();
    if (!answer) return;
    const q = questions[currentIndex];
    if (!q) return;

    submitBtn.disabled = true;
    const correct = await checkAnswer(q.id, answer);

    if (correct) {
      clearTimer();
      const pts = POINTS[q.difficulty] || 0;
      score += pts;
      if (questions.length === 1 && bancoWon) {
        superBancoSuccess();
      } else if (questions.length === 1 && !bancoWon) {
        bancoSuccess();
      } else {
        currentIndex++;
        if (currentIndex >= questions.length) endRound();
        else { showQuestion(); }
      }
    } else {
      submitBtn.disabled = false;
      answerInput.value = "";
      answerInput.focus();
    }
  });

  answerInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") submitBtn.click();
  });

  document.getElementById("quiz-start").addEventListener("click", startGame);
  document.getElementById("quiz-replay").addEventListener("click", startGame);
  document.getElementById("quiz-do-banco").addEventListener("click", playBanco);
  document.getElementById("quiz-skip-banco").addEventListener("click", showGameOver);
  document.getElementById("quiz-do-super").addEventListener("click", playSuperBanco);
  document.getElementById("quiz-skip-super").addEventListener("click", () => { score = 500; showGameOver(); });

  document.getElementById("quiz-save-name").addEventListener("click", async () => {
    const name = quizPlayerNameInput.value.trim();
    if (!name || !currentSessionId) return;
    const btn = document.getElementById("quiz-save-name");
    btn.disabled = true;
    try {
      const res = await fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ player_name: name })
      });
      if (res.ok) {
        setPlayerCookie(name);
        setQuizLeaderboardUi(true, name);
        lbPage = 1;
        lbSortEl.value = "score";
        loadLeaderboard();
      }
    } finally {
      btn.disabled = false;
    }
  });

  lbSortEl.addEventListener("change", () => {
    lbPage = 1;
    loadLeaderboard();
  });
  lbPrevBtn.addEventListener("click", () => {
    if (lbPage > 1) { lbPage--; loadLeaderboard(); }
  });
  lbNextBtn.addEventListener("click", () => {
    if (lbNextBtn.disabled) return;
    lbPage++;
    loadLeaderboard();
  });

  loadLeaderboard();
})();
</script>
