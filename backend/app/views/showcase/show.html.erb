<% content_for :title, "Vitrine" %>

<div class="showcase-page ds-page">
  <div class="ds-container showcase-container">
    <header class="ds-header">
      <h1 class="ds-title">Choisis un jeu</h1>
    </header>

    <div class="showcase-games">
      <% if @showcase_quiz_enabled %>
        <%= link_to showcase_quiz_path(@beta.nickname), class: "showcase-game-card showcase-game-card--quiz" do %>
          <span class="showcase-game-icon">📻</span>
          <h2 class="showcase-game-title">Le Jeu des 1000 €</h2>
          <p class="showcase-game-desc">Quiz culture générale, Banco et Super Banco. Inspiré de France Inter.</p>
        <% end %>
      <% end %>

      <% if @showcase_snake_enabled %>
        <%= link_to showcase_snake_path(@beta.nickname), class: "showcase-game-card showcase-game-card--snake" do %>
          <span class="showcase-game-icon">🐍</span>
          <h2 class="showcase-game-title">Snake</h2>
          <p class="showcase-game-desc">Le classique Nokia 3310. Flèches ou swipe pour diriger.</p>
        <% end %>
      <% end %>

      <% if @showcase_backdoor_enabled %>
        <%= link_to showcase_backdoor_path(@beta.nickname), class: "showcase-game-card" do %>
          <span class="showcase-game-icon">⏱</span>
          <h2 class="showcase-game-title">Backdoor</h2>
          <p class="showcase-game-desc">Voir le timer Chaster et ajouter du temps avec un message.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
