<% content_for :title, "Snake" %>
<% content_for :body_class, "snake-page-active" %>
<% content_for :head do %>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no">
<% end %>

<div class="snake-page" data-nickname="<%= @beta.nickname %>">
  <div class="snake-container">
    <div id="snake-intro" class="snake-intro">
      <h1 class="snake-title">Snake</h1>
      <p class="snake-hint">Clavier, swipe sur le terrain, croix ou joystick pour diriger</p>
      <button type="button" class="snake-btn snake-btn--start" id="snake-start">Jouer</button>
    </div>

    <div id="snake-game" class="snake-game" style="display: none;">
      <div class="snake-score">Score: <span id="snake-score">0</span></div>
      <canvas id="snake-canvas" class="snake-canvas" width="300" height="300"></canvas>
      <div class="snake-controls-row" aria-label="Contrôles tactiles">
        <div class="snake-dpad" aria-label="Croix directionnelle">
          <div class="snake-dpad-cross">
            <span class="snake-dpad-center"></span>
            <button type="button" class="snake-dpad-btn snake-dpad-btn--up" data-dir="up" aria-label="Haut"><span class="snake-dpad-arrow"></span></button>
            <button type="button" class="snake-dpad-btn snake-dpad-btn--down" data-dir="down" aria-label="Bas"><span class="snake-dpad-arrow"></span></button>
            <button type="button" class="snake-dpad-btn snake-dpad-btn--left" data-dir="left" aria-label="Gauche"><span class="snake-dpad-arrow"></span></button>
            <button type="button" class="snake-dpad-btn snake-dpad-btn--right" data-dir="right" aria-label="Droite"><span class="snake-dpad-arrow"></span></button>
          </div>
        </div>
        <div class="snake-joystick-wrap" aria-label="Joystick virtuel">
          <div class="snake-joystick-ring" id="snake-joystick-ring" role="presentation">
            <div class="snake-joystick-knob" id="snake-joystick-knob"></div>
          </div>
        </div>
      </div>
    </div>

    <div id="snake-gameover" class="snake-gameover" style="display: none;">
      <h2 class="snake-gameover-title">Game Over</h2>
      <p class="snake-gameover-score">Score: <span id="snake-final-score">0</span></p>
      <div class="snake-leaderboard-form" id="snake-lb-name-block">
        <p id="snake-lb-auto-registered" class="snake-lb-registered" hidden>Score enregistré pour <strong id="snake-lb-registered-name"></strong></p>
        <div id="snake-lb-name-fields" class="snake-lb-name-fields">
          <input type="text" id="snake-player-name" class="snake-input" placeholder="Ton pseudo pour le leaderboard" maxlength="30" />
          <button type="button" class="snake-btn snake-btn--submit" id="snake-save-name">Enregistrer au leaderboard</button>
        </div>
      </div>
      <button type="button" class="snake-btn snake-btn--ghost" id="snake-replay">Rejouer</button>
    </div>
  </div>

  <section class="snake-leaderboard" id="snake-leaderboard">
    <h3 class="snake-leaderboard-title">Leaderboard</h3>
    <div class="snake-leaderboard-toolbar">
      <label class="snake-leaderboard-toolbar-label" for="snake-lb-sort">Trier</label>
      <select id="snake-lb-sort" class="snake-input snake-leaderboard-sort" aria-label="Trier le classement">
        <option value="score">Meilleur score</option>
        <option value="recent">Plus récent</option>
      </select>
    </div>
    <div id="snake-leaderboard-list" class="snake-leaderboard-list">
      <p class="snake-leaderboard-empty">Aucun score enregistré</p>
    </div>
    <div id="snake-leaderboard-pagination" class="snake-leaderboard-pagination" hidden>
      <button type="button" class="snake-btn snake-btn--ghost snake-btn--sm" id="snake-lb-prev" disabled>Précédent</button>
      <span class="snake-leaderboard-page-label" id="snake-lb-page-label"></span>
      <button type="button" class="snake-btn snake-btn--ghost snake-btn--sm" id="snake-lb-next">Suivant</button>
    </div>
  </section>
</div>

<% if flash[:notice] %>
  <div class="snake-flash snake-flash--success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="snake-flash snake-flash--error"><%= flash[:alert] %></div>
<% end %>

<script>
(function() {
  const GRID = 15;
  const CELL = 20;
  const CANVAS_SIZE = GRID * CELL;

  const nickname = document.querySelector(".snake-page").dataset.nickname;
  const LEADERBOARD_PER_PAGE = 10;
  const urls = {
    createSession: `/showcase/${nickname}/sessions`,
    updateSession: (id) => `/showcase/${nickname}/sessions/${id}`,
    addTime: `/showcase/${nickname}/add_time`
  };

  const canvas = document.getElementById("snake-canvas");
  const ctx = canvas.getContext("2d");

  let snake = [];
  let food = { x: 0, y: 0 };
  let dir = { x: 1, y: 0 };
  const dirQueue = [];
  const MAX_QUEUE = 5;
  let score = 0;
  let gameLoop = null;
  let gameOver = false;
  let currentSessionId = null;

  const intro = document.getElementById("snake-intro");
  const gameEl = document.getElementById("snake-game");
  const gameoverEl = document.getElementById("snake-gameover");
  const scoreEl = document.getElementById("snake-score");
  const finalScoreEl = document.getElementById("snake-final-score");
  const playerNameInput = document.getElementById("snake-player-name");
  const saveNameBtn = document.getElementById("snake-save-name");
  const leaderboardList = document.getElementById("snake-leaderboard-list");
  const lbSortEl = document.getElementById("snake-lb-sort");
  const lbPagEl = document.getElementById("snake-leaderboard-pagination");
  const lbPrevBtn = document.getElementById("snake-lb-prev");
  const lbNextBtn = document.getElementById("snake-lb-next");
  const lbPageLabel = document.getElementById("snake-lb-page-label");
  let lbPage = 1;

  function fetchJson(url, options = {}) {
    const opts = {
      headers: { "Accept": "application/json", "Content-Type": "application/json", "X-Requested-With": "XMLHttpRequest", ...options.headers },
      ...options
    };
    return fetch(url, opts);
  }

  function postForm(url, body) {
    const formData = new URLSearchParams(body);
    return fetch(url, {
      method: "POST",
      headers: { "Accept": "application/json", "X-Requested-With": "XMLHttpRequest", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.content || "" },
      body: formData
    });
  }

  async function onFruitEaten() {
    if (!currentSessionId) return;
    const updatePromise = fetchJson(urls.updateSession(currentSessionId), {
      method: "PATCH",
      body: JSON.stringify({ score: score })
    }).catch(() => {});
    const addTimePromise = postForm(urls.addTime, { game_type: "snake" }).catch(() => {});
    await Promise.all([updatePromise, addTimePromise]);
  }

  function playerCookieKey() {
    return "bgShowcasePlayer_" + nickname.replace(/[^a-zA-Z0-9]/g, "_");
  }
  function getPlayerCookie() {
    const prefix = playerCookieKey() + "=";
    const parts = document.cookie.split(";");
    for (let c of parts) {
      c = c.trim();
      if (c.startsWith(prefix)) return decodeURIComponent(c.slice(prefix.length).replace(/\+/g, " "));
    }
    return "";
  }
  function setPlayerCookie(value) {
    const maxAge = 365 * 24 * 60 * 60;
    document.cookie = playerCookieKey() + "=" + encodeURIComponent(value) + ";path=/;max-age=" + maxAge + ";SameSite=Lax";
  }
  function parsePlayedAt(iso) {
    if (!iso) return null;
    const d = new Date(iso);
    return Number.isNaN(d.getTime()) ? null : d;
  }
  function formatPlayedDate(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    const dd = String(d.getDate()).padStart(2, "0");
    const mm = String(d.getMonth() + 1).padStart(2, "0");
    return dd + "/" + mm + "/" + d.getFullYear();
  }
  function formatPlayedTime(iso) {
    const d = parsePlayedAt(iso);
    if (!d) return "—";
    return d.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
  }
  function buildLeaderboardUrl() {
    const p = new URLSearchParams({
      game_type: "snake",
      sort: lbSortEl.value,
      page: String(lbPage),
      per_page: String(LEADERBOARD_PER_PAGE)
    });
    return "/showcase/" + nickname + "/leaderboard?" + p.toString();
  }

  const snakeNameFields = document.getElementById("snake-lb-name-fields");
  const snakeAutoReg = document.getElementById("snake-lb-auto-registered");
  const snakeRegName = document.getElementById("snake-lb-registered-name");

  function setSnakeLeaderboardUi(showRegistered, nameForForm) {
    if (showRegistered && nameForForm) {
      snakeNameFields.hidden = true;
      snakeAutoReg.hidden = false;
      snakeRegName.textContent = nameForForm;
    } else {
      snakeNameFields.hidden = false;
      snakeAutoReg.hidden = true;
      playerNameInput.value = (nameForForm != null && nameForForm !== "") ? nameForForm : (getPlayerCookie() || "");
    }
  }

  function renderLeaderboardPagination(meta) {
    const { page, total_pages: totalPages, total } = meta;
    if (total === 0 || !totalPages || totalPages <= 1) {
      lbPagEl.hidden = true;
      return;
    }
    lbPagEl.hidden = false;
    lbPrevBtn.disabled = page <= 1;
    lbNextBtn.disabled = page >= totalPages;
    lbPageLabel.textContent = "Page " + page + " / " + totalPages;
  }

  async function loadLeaderboard() {
    try {
      const res = await fetchJson(buildLeaderboardUrl());
      const data = await res.json();
      if (data.error) {
        leaderboardList.innerHTML = "<p class=\"snake-leaderboard-empty\">Aucun score enregistré</p>";
        lbPagEl.hidden = true;
        return;
      }
      const entries = data.entries;
      if (Array.isArray(entries) && entries.length > 0) {
        leaderboardList.innerHTML =
          '<div class="snake-leaderboard-table-wrap">' +
          '<table class="snake-leaderboard-table" aria-label="Classement">' +
          "<thead><tr>" +
          '<th scope="col" class="snake-leaderboard-th snake-leaderboard-th--num">#</th>' +
          '<th scope="col" class="snake-leaderboard-th">Joueur</th>' +
          '<th scope="col" class="snake-leaderboard-th snake-leaderboard-th--score">Score</th>' +
          '<th scope="col" class="snake-leaderboard-th snake-leaderboard-th--meta">Date</th>' +
          '<th scope="col" class="snake-leaderboard-th snake-leaderboard-th--meta">Heure</th>' +
          "</tr></thead><tbody>" +
          entries.map(s =>
            "<tr>" +
            `<td class="snake-leaderboard-td snake-leaderboard-td--num">${s.rank}</td>` +
            `<td class="snake-leaderboard-td snake-leaderboard-td--name">` +
              `<strong class="snake-lb-name">${escapeHtml(s.player_name)}</strong></td>` +
            `<td class="snake-leaderboard-td snake-leaderboard-td--score">` +
              `<strong class="snake-lb-score">${s.score}</strong></td>` +
            `<td class="snake-leaderboard-td snake-leaderboard-td--date snake-lb-meta"><time datetime="${escapeHtml(s.played_at || "")}">${escapeHtml(formatPlayedDate(s.played_at))}</time></td>` +
            `<td class="snake-leaderboard-td snake-leaderboard-td--time snake-lb-meta">${escapeHtml(formatPlayedTime(s.played_at))}</td>` +
            "</tr>"
          ).join("") +
          "</tbody></table></div>";
        renderLeaderboardPagination(data);
      } else {
        leaderboardList.innerHTML = "<p class=\"snake-leaderboard-empty\">Aucun score enregistré</p>";
        lbPagEl.hidden = true;
      }
    } catch {
      leaderboardList.innerHTML = "<p class=\"snake-leaderboard-empty\">Aucun score enregistré</p>";
      lbPagEl.hidden = true;
    }
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function init() {
    snake = [{ x: 7, y: 7 }];
    dir = { x: 1, y: 0 };
    dirQueue.length = 0;
    score = 0;
    gameOver = false;
    currentSessionId = null;
    spawnFood();
  }

  function enqueueDir(d) {
    const ref = dirQueue.length ? dirQueue[dirQueue.length - 1] : dir;
    const opposite = ref.x === -d.x && ref.y === -d.y;
    if (!opposite && dirQueue.length < MAX_QUEUE) dirQueue.push(d);
  }

  function spawnFood() {
    let ok = false;
    while (!ok) {
      food = { x: Math.floor(Math.random() * GRID), y: Math.floor(Math.random() * GRID) };
      ok = !snake.some(s => s.x === food.x && s.y === food.y);
    }
  }

  function drawPixel(x, y, color) {
    ctx.fillStyle = color;
    ctx.fillRect(x * CELL, y * CELL, CELL - 1, CELL - 1);
  }

  function draw() {
    ctx.fillStyle = "#0d1f0d";
    ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

    snake.forEach((s, i) => {
      drawPixel(s.x, s.y, i === 0 ? "#33ff33" : "#22cc22");
    });
    drawPixel(food.x, food.y, "#55ff55");
  }

  function tick() {
    if (gameOver) return;

    if (dirQueue.length) dir = dirQueue.shift();
    const head = { x: (snake[0].x + dir.x + GRID) % GRID, y: (snake[0].y + dir.y + GRID) % GRID };

    if (snake.some(s => s.x === head.x && s.y === head.y)) {
      endGame();
      return;
    }

    snake.unshift(head);
    if (head.x === food.x && head.y === food.y) {
      score++;
      onFruitEaten();
      spawnFood();
    } else {
      snake.pop();
    }

    scoreEl.textContent = score;
    draw();
  }

  async function endGame() {
    gameOver = true;
    if (gameLoop) cancelAnimationFrame(gameLoop);
    gameEl.style.display = "none";
    gameoverEl.style.display = "block";
    finalScoreEl.textContent = score;

    const saved = getPlayerCookie().trim();
    if (currentSessionId) {
      if (saved) {
        try {
          const res = await fetchJson(urls.updateSession(currentSessionId), {
            method: "PATCH",
            body: JSON.stringify({ score: score, player_name: saved })
          });
          if (res.ok) {
            setPlayerCookie(saved);
            setSnakeLeaderboardUi(true, saved);
            lbPage = 1;
            lbSortEl.value = "score";
            loadLeaderboard();
            return;
          }
        } catch (_) {}
      }
      fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ score: score })
      }).catch(() => {});
    }
    setSnakeLeaderboardUi(false, saved);
  }

  const fps = 18;
  const interval = 1000 / fps;
  let last = 0;
  function run() {
    const now = performance.now();
    if (now - last >= interval) {
      last = now;
      tick();
    }
    if (!gameOver) gameLoop = requestAnimationFrame(run);
  }

  async function startGame() {
    init();
    intro.style.display = "none";
    gameEl.style.display = "block";
    gameoverEl.style.display = "none";
    scoreEl.textContent = "0";
    setSnakeLeaderboardUi(false, getPlayerCookie() || "");

    try {
      const res = await fetchJson(urls.createSession, {
        method: "POST",
        body: JSON.stringify({ game_type: "snake" })
      });
      const data = await res.json();
      if (data.id) currentSessionId = data.id;
    } catch (_) {}

    draw();
    run();
  }

  saveNameBtn.addEventListener("click", async () => {
    const name = (playerNameInput.value || "").trim();
    if (!name || !currentSessionId) return;
    saveNameBtn.disabled = true;
    try {
      const res = await fetchJson(urls.updateSession(currentSessionId), {
        method: "PATCH",
        body: JSON.stringify({ player_name: name })
      });
      if (res.ok) {
        setPlayerCookie(name);
        setSnakeLeaderboardUi(true, name);
        lbPage = 1;
        lbSortEl.value = "score";
        loadLeaderboard();
      }
    } finally {
      saveNameBtn.disabled = false;
    }
  });

  document.getElementById("snake-start").addEventListener("click", startGame);
  document.getElementById("snake-replay").addEventListener("click", startGame);

  lbSortEl.addEventListener("change", () => {
    lbPage = 1;
    loadLeaderboard();
  });
  lbPrevBtn.addEventListener("click", () => {
    if (lbPage > 1) { lbPage--; loadLeaderboard(); }
  });
  lbNextBtn.addEventListener("click", () => {
    if (lbNextBtn.disabled) return;
    lbPage++;
    loadLeaderboard();
  });

  const dirMap = { up: { x: 0, y: -1 }, down: { x: 0, y: 1 }, left: { x: -1, y: 0 }, right: { x: 1, y: 0 } };
  function applyDirFromName(name) {
    const d = dirMap[name];
    if (d) enqueueDir(d);
  }
  document.querySelectorAll(".snake-dpad-btn").forEach(btn => {
    const dirName = btn.dataset.dir;
    const onPointerDown = (e) => {
      if (e.pointerType === "touch") e.preventDefault();
      if (gameOver) return;
      applyDirFromName(dirName);
    };
    btn.addEventListener("pointerdown", onPointerDown);
    btn.addEventListener("touchstart", (e) => { e.preventDefault(); }, { passive: false, capture: true });
  });

  const SWIPE_MIN = 14;
  let swipePointerId = null;
  let swipeStart = null;
  canvas.addEventListener("pointerdown", (e) => {
    if (gameOver) return;
    swipePointerId = e.pointerId;
    swipeStart = { x: e.clientX, y: e.clientY };
    try { canvas.setPointerCapture(e.pointerId); } catch (_) {}
  });
  canvas.addEventListener("pointerup", (e) => {
    if (e.pointerId !== swipePointerId || !swipeStart || gameOver) return;
    const dx = e.clientX - swipeStart.x;
    const dy = e.clientY - swipeStart.y;
    swipePointerId = null;
    swipeStart = null;
    if (Math.abs(dx) < SWIPE_MIN && Math.abs(dy) < SWIPE_MIN) return;
    if (Math.abs(dx) > Math.abs(dy)) {
      if (dx > 0) enqueueDir({ x: 1, y: 0 });
      else enqueueDir({ x: -1, y: 0 });
    } else {
      if (dy > 0) enqueueDir({ x: 0, y: 1 });
      else enqueueDir({ x: 0, y: -1 });
    }
  });
  canvas.addEventListener("pointercancel", () => {
    swipePointerId = null;
    swipeStart = null;
  });
  canvas.addEventListener("lostpointercapture", () => {
    swipePointerId = null;
    swipeStart = null;
  });

  const joystickRing = document.getElementById("snake-joystick-ring");
  const joystickKnob = document.getElementById("snake-joystick-knob");
  let joyPointerId = null;
  let joyCenter = { x: 0, y: 0 };
  const JOY_COMMIT = 22;
  const JOY_VISUAL_MAX = 36;

  function joySetKnob(dx, dy) {
    const len = Math.hypot(dx, dy) || 1;
    const cap = Math.min(len, JOY_VISUAL_MAX);
    const kx = (dx / len) * cap;
    const ky = (dy / len) * cap;
    joystickKnob.style.transform = "translate(calc(-50% + " + kx + "px), calc(-50% + " + ky + "px))";
  }

  function joyCommitDirection(dx, dy) {
    if (Math.abs(dx) < JOY_COMMIT && Math.abs(dy) < JOY_COMMIT) return;
    if (Math.abs(dx) > Math.abs(dy)) {
      if (dx > 0) applyDirFromName("right");
      else applyDirFromName("left");
    } else {
      if (dy > 0) applyDirFromName("down");
      else applyDirFromName("up");
    }
  }

  function joyPointerMove(e) {
    if (e.pointerId !== joyPointerId) return;
    const dx = e.clientX - joyCenter.x;
    const dy = e.clientY - joyCenter.y;
    joySetKnob(dx, dy);
    joyCommitDirection(dx, dy);
  }

  function joyPointerEnd(e) {
    if (e.pointerId !== joyPointerId) return;
    joyPointerId = null;
    joystickKnob.style.transform = "translate(-50%, -50%)";
    try { joystickRing.releasePointerCapture(e.pointerId); } catch (_) {}
  }

  joystickRing.addEventListener("lostpointercapture", () => {
    joyPointerId = null;
    joystickKnob.style.transform = "translate(-50%, -50%)";
  });

  joystickRing.addEventListener("pointerdown", (e) => {
    if (gameOver) return;
    e.preventDefault();
    const r = joystickRing.getBoundingClientRect();
    joyCenter = { x: r.left + r.width / 2, y: r.top + r.height / 2 };
    joyPointerId = e.pointerId;
    joySetKnob(e.clientX - joyCenter.x, e.clientY - joyCenter.y);
    joyCommitDirection(e.clientX - joyCenter.x, e.clientY - joyCenter.y);
    try { joystickRing.setPointerCapture(e.pointerId); } catch (_) {}
  });
  joystickRing.addEventListener("pointermove", joyPointerMove);
  joystickRing.addEventListener("pointerup", joyPointerEnd);
  joystickRing.addEventListener("pointercancel", joyPointerEnd);

  document.addEventListener("keydown", e => {
    const scrollKeys = ["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", " ", "Space", "PageUp", "PageDown", "Home", "End"];
    if (scrollKeys.includes(e.key)) e.preventDefault();
    if (gameOver || e.repeat) return;
    switch (e.key) {
      case "ArrowUp": enqueueDir({ x: 0, y: -1 }); break;
      case "ArrowDown": enqueueDir({ x: 0, y: 1 }); break;
      case "ArrowLeft": enqueueDir({ x: -1, y: 0 }); break;
      case "ArrowRight": enqueueDir({ x: 1, y: 0 }); break;
    }
  }, { passive: false });

  loadLeaderboard();
})();
</script>
