<%= form_with url: wallpaper_tasks_path(@nickname, device_id: @device_id), method: :post, local: true, class: "ds-form ds-task-form", id: "task-form" do |f| %>
  <div class="ds-form-group">
    <label for="task_name" class="ds-form-label"><%= t("tasks_form.name") %></label>
    <input type="text" name="task[name]" id="task_name" class="ds-input" required placeholder="<%= t("tasks_form.name_placeholder") %>">
  </div>

  <div class="ds-form-group">
    <label for="task_description" class="ds-form-label"><%= t("tasks_form.description") %></label>
    <textarea name="task[description]" id="task_description" class="ds-input ds-textarea" rows="3" placeholder="<%= t("tasks_form.description_placeholder") %>"></textarea>
  </div>

  <div class="ds-form-group">
    <label for="task_expected_proof" class="ds-form-label"><%= t("tasks_form.expected_proof") %></label>
    <textarea name="task[expected_proof]" id="task_expected_proof" class="ds-input ds-textarea" rows="2" placeholder="<%= t("tasks_form.expected_proof_placeholder") %>"></textarea>
  </div>

  <div class="ds-form-group">
    <span class="ds-form-label"><%= t("tasks_form.deadline") %></span>
    <div class="ds-deadline-options">
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="duration" checked>
        <span><%= t("tasks_form.in_duration") %></span>
        <select name="deadline_duration" class="ds-select">
          <option value="15"><%= t("tasks_form.option_15m") %></option>
          <option value="30"><%= t("tasks_form.option_30m") %></option>
          <option value="60"><%= t("tasks_form.option_1h") %></option>
          <option value="120"><%= t("tasks_form.option_2h") %></option>
          <option value="180"><%= t("tasks_form.option_3h") %></option>
          <option value="360"><%= t("tasks_form.option_6h") %></option>
          <option value="720"><%= t("tasks_form.option_12h") %></option>
          <option value="1440"><%= t("tasks_form.option_24h") %></option>
        </select>
      </label>
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="tonight">
        <span><%= t("tasks_form.tonight") %></span>
      </label>
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="tomorrow">
        <span><%= t("tasks_form.tomorrow") %></span>
      </label>
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="datetime">
        <span><%= t("tasks_form.datetime_exact") %></span>
      </label>
    </div>
    <div id="datetime-wrapper" class="ds-datetime-wrapper" style="display: none;">
      <input type="datetime-local" id="task_deadline_at_display" class="ds-input" min="">
      <input type="hidden" name="task[deadline_at]" id="task_deadline_at">
    </div>
  </div>

  <div class="ds-form-group">
    <label class="ds-checkbox-label">
      <input type="checkbox" name="task[trigger_alarm]" value="1" id="task_trigger_alarm">
      <span><%= t("tasks_form.alarm") %></span>
    </label>
    <div id="alarm-sound-options" class="ds-alarm-sound-options" style="display: none;">
      <span class="ds-form-label"><%= t("tasks_form.alarm_sound") %></span>
      <select name="task[alarm_sound]" class="ds-select">
        <option value="urgent"><%= t("tasks_form.alarm_urgent") %></option>
        <option value="default"><%= t("tasks_form.alarm_default") %></option>
      </select>
    </div>
  </div>

  <button type="submit" class="ds-btn ds-btn--primary"><%= t("tasks_form.submit") %></button>
<% end %>

<script>
(function() {
  const form = document.getElementById('task-form');
  const durationRadio = document.querySelector('input[name="deadline_mode"][value="duration"]');
  const tonightRadio = document.querySelector('input[name="deadline_mode"][value="tonight"]');
  const tomorrowRadio = document.querySelector('input[name="deadline_mode"][value="tomorrow"]');
  const datetimeRadio = document.querySelector('input[name="deadline_mode"][value="datetime"]');
  const datetimeWrapper = document.getElementById('datetime-wrapper');
  const deadlineDisplay = document.getElementById('task_deadline_at_display');
  const deadlineHidden = document.getElementById('task_deadline_at');
  const durationSelect = document.querySelector('select[name="deadline_duration"]');

  function formatDatetimeLocal(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    const h = String(d.getHours()).padStart(2, '0');
    const min = String(d.getMinutes()).padStart(2, '0');
    return y + '-' + m + '-' + day + 'T' + h + ':' + min;
  }

  function setDatetimeMin() {
    if (deadlineDisplay) {
      deadlineDisplay.min = formatDatetimeLocal(new Date());
    }
  }

  function applyPreset(preset) {
    const now = new Date();
    let target;
    if (preset === 'tonight') {
      target = new Date(now);
      target.setHours(18, 0, 0, 0);
      if (target <= now) {
        target.setDate(target.getDate() + 1);
      }
    } else if (preset === 'tomorrow') {
      target = new Date(now);
      target.setDate(target.getDate() + 1);
      target.setHours(9, 0, 0, 0);
    }
    if (target && deadlineDisplay) {
      deadlineDisplay.value = formatDatetimeLocal(target);
    }
  }

  function toggleDatetime() {
    const needsDatetime = tonightRadio?.checked || tomorrowRadio?.checked || datetimeRadio?.checked;
    if (datetimeWrapper) datetimeWrapper.style.display = needsDatetime ? 'block' : 'none';
    if (deadlineHidden) deadlineHidden.required = needsDatetime;
    if (durationSelect) durationSelect.disabled = needsDatetime;

    if (needsDatetime) {
      setDatetimeMin();
      if (tonightRadio?.checked) applyPreset('tonight');
      else if (tomorrowRadio?.checked) applyPreset('tomorrow');
      else if (deadlineDisplay && !deadlineDisplay.value) {
        const d = new Date();
        d.setMinutes(d.getMinutes() + 30);
        deadlineDisplay.value = formatDatetimeLocal(d);
      }
    } else {
      if (deadlineHidden) deadlineHidden.value = '';
      if (deadlineDisplay) deadlineDisplay.value = '';
    }
  }

  function localToISO(localStr) {
    if (!localStr) return '';
    const [datePart, timePart] = localStr.split('T');
    const [y, m, d] = datePart.split('-').map(Number);
    const [h, min] = (timePart || '00:00').split(':').map(Number);
    const localDate = new Date(y, m - 1, d, h, min);
    return localDate.toISOString();
  }

  if (form) {
    form.addEventListener('submit', function(e) {
      if (tonightRadio?.checked || tomorrowRadio?.checked || datetimeRadio?.checked) {
        const displayVal = deadlineDisplay?.value;
        if (displayVal && deadlineHidden) {
          deadlineHidden.value = localToISO(displayVal);
        }
      }
    });
  }

  [durationRadio, tonightRadio, tomorrowRadio, datetimeRadio].forEach(function(r) {
    if (r) r.addEventListener('change', toggleDatetime);
  });
  if (tonightRadio) tonightRadio.addEventListener('change', function() { if (tonightRadio.checked) applyPreset('tonight'); });
  if (tomorrowRadio) tomorrowRadio.addEventListener('change', function() { if (tomorrowRadio.checked) applyPreset('tomorrow'); });
  toggleDatetime();

  const triggerAlarmCheckbox = document.getElementById('task_trigger_alarm');
  const alarmSoundOptions = document.getElementById('alarm-sound-options');
  if (triggerAlarmCheckbox && alarmSoundOptions) {
    function toggleAlarmSound() {
      alarmSoundOptions.style.display = triggerAlarmCheckbox.checked ? 'block' : 'none';
    }
    triggerAlarmCheckbox.addEventListener('change', toggleAlarmSound);
    toggleAlarmSound();
  }
})();
</script>
