<%= form_with url: wallpaper_tasks_path(@nickname, device_id: @device_id), method: :post, local: true, class: "ds-form ds-task-form" do |f| %>
  <div class="ds-form-group">
    <label for="task_name" class="ds-form-label">Nom</label>
    <input type="text" name="task[name]" id="task_name" class="ds-input" required placeholder='Ex: Ecrire 100 fois "je serai obéissant"'>
  </div>

  <div class="ds-form-group">
    <label for="task_description" class="ds-form-label">Description</label>
    <textarea name="task[description]" id="task_description" class="ds-input ds-textarea" rows="3" placeholder="Détails de la tâche..."></textarea>
  </div>

  <div class="ds-form-group">
    <label for="task_expected_proof" class="ds-form-label">Preuve attendue</label>
    <textarea name="task[expected_proof]" id="task_expected_proof" class="ds-input ds-textarea" rows="2" placeholder="Ex: Photo des lignes ou lien vers writeforme"></textarea>
  </div>

  <div class="ds-form-group">
    <span class="ds-form-label">Deadline</span>
    <div class="ds-deadline-options">
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="duration" checked>
        <span>Dans</span>
        <select name="deadline_duration" class="ds-select">
          <option value="15">15 min</option>
          <option value="30">30 min</option>
          <option value="60">1 h</option>
          <option value="120">2 h</option>
          <option value="1440">24 h</option>
        </select>
      </label>
      <label class="ds-radio-label">
        <input type="radio" name="deadline_mode" value="datetime">
        <span>Date/heure précise</span>
      </label>
    </div>
    <div id="datetime-wrapper" class="ds-datetime-wrapper" style="display: none;">
      <input type="datetime-local" name="task[deadline_at]" id="task_deadline_at" class="ds-input">
    </div>
  </div>

  <div class="ds-form-group">
    <label class="ds-checkbox-label">
      <input type="checkbox" name="task[trigger_alarm]" value="1" id="task_trigger_alarm">
      <span>Déclencher une alarme sur le téléphone</span>
    </label>
    <div id="alarm-sound-options" class="ds-alarm-sound-options" style="display: none;">
      <span class="ds-form-label">Son d'alarme</span>
      <select name="task[alarm_sound]" class="ds-select">
        <option value="urgent">Alerte forte (recommandé)</option>
        <option value="default">Alarme réveil (système)</option>
      </select>
    </div>
  </div>

  <button type="submit" class="ds-btn ds-btn--primary">Créer la tâche</button>
<% end %>

<script>
(function() {
  const durationRadio = document.querySelector('input[name="deadline_mode"][value="duration"]');
  const datetimeRadio = document.querySelector('input[name="deadline_mode"][value="datetime"]');
  const datetimeWrapper = document.getElementById('datetime-wrapper');
  const durationSelect = document.querySelector('select[name="deadline_duration"]');
  const deadlineInput = document.getElementById('task_deadline_at');

  function toggleDatetime() {
    if (datetimeRadio && datetimeRadio.checked) {
      if (datetimeWrapper) datetimeWrapper.style.display = 'block';
      if (deadlineInput) deadlineInput.required = true;
      if (durationSelect) durationSelect.disabled = true;
    } else {
      if (datetimeWrapper) datetimeWrapper.style.display = 'none';
      if (deadlineInput) { deadlineInput.required = false; deadlineInput.value = ''; }
      if (durationSelect) durationSelect.disabled = false;
    }
  }

  if (durationRadio) durationRadio.addEventListener('change', toggleDatetime);
  if (datetimeRadio) datetimeRadio.addEventListener('change', toggleDatetime);
  toggleDatetime();

  const triggerAlarmCheckbox = document.getElementById('task_trigger_alarm');
  const alarmSoundOptions = document.getElementById('alarm-sound-options');
  if (triggerAlarmCheckbox && alarmSoundOptions) {
    function toggleAlarmSound() {
      alarmSoundOptions.style.display = triggerAlarmCheckbox.checked ? 'block' : 'none';
    }
    triggerAlarmCheckbox.addEventListener('change', toggleAlarmSound);
    toggleAlarmSound();
  }
})();
</script>
