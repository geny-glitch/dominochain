<% device_ratio = (@device&.screen_width.to_f / @device&.screen_height) if @device&.screen_width.to_i > 0 && @device&.screen_height.to_i > 0 %>
<% device_ratio ||= 9.0 / 16 %>

<div class="ds-page">
  <div class="ds-container">
    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <% if @device %>
      <% permissions_all_ok = @device.permissions_ok || @device.permissions_missing_list.empty? %>
    <% end %>

    <header class="ds-header">
      <%= image_tag "domino-chain-logo.png", alt: t("wallpaper.logo_alt"), class: "ds-header-logo", width: 48, height: 48 %>
      <div class="ds-header-text">
        <h1 class="ds-title wordmark">DominoChain</h1>
        <p class="ds-subtitle ds-subtitle--with-icon">
          <% if @device %>
            <button type="button" class="ds-permissions-icon ds-permissions-icon--<%= permissions_all_ok ? 'ok' : 'warning' %>" id="permissions-icon-btn" title="<%= permissions_all_ok ? t("wallpaper.permissions_ok_title") : t("wallpaper.permissions_missing_title") %>" aria-label="<%= permissions_all_ok ? t("wallpaper.permissions_ok_title") : t("wallpaper.permissions_missing_title") %>">
              <% if permissions_all_ok %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <% else %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <% end %>
            </button>
          <% end %>
        </p>
      </div>
    </header>

    <% if @device %>
      <dialog id="permissions-dialog" class="ds-dialog">
        <button type="button" class="ds-dialog-close-btn" id="permissions-dialog-close" title="<%= t("wallpaper.dialog_close") %>" aria-label="<%= t("wallpaper.dialog_close") %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="ds-dialog-content">
          <% if permissions_all_ok %>
            <p class="ds-dialog-text"><%= t("wallpaper.permissions_ok_lead") %></p>
            <ul class="ds-permissions-checklist">
              <% Device::PERMISSION_LABELS.each_value do |label| %>
                <li class="ds-permissions-checklist-item ds-permissions-checklist-item--ok"><span class="ds-permissions-check">✓</span> <%= label %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="ds-dialog-text"><%= t("wallpaper.permissions_missing_lead") %></p>
            <ul class="ds-permissions-checklist">
              <% missing_list = @device.permissions_missing_list %>
              <% Device::PERMISSION_LABELS.each do |key, label| %>
                <% ok = !missing_list.include?(key) %>
                <li class="ds-permissions-checklist-item ds-permissions-checklist-item--<%= ok ? 'ok' : 'missing' %>">
                  <span class="ds-permissions-check"><%= ok ? '✓' : '✗' %></span> <%= label %>
                </li>
              <% end %>
            </ul>
            <div class="ds-dialog-actions">
              <%= button_to t("wallpaper.grant_permissions_notify"), wallpaper_grant_permissions_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-btn ds-btn--primary ds-btn--sm" %>
            </div>
          <% end %>
        </div>
      </dialog>
    <% end %>

    <% if @device %>
      <%# 3 CTA carrés %>
      <div class="ds-boss-cta-grid">
        <%= button_to wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-cta-card", form: { class: "ds-boss-cta-form" } do %>
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/><path d="M16 8l4-4"/></svg>
          <span class="ds-boss-cta-label"><%= t("wallpaper.cta_screenshot") %></span>
        <% end %>
        <%= link_to wallpaper_upload_new_path(@nickname, device_id: @device_id), class: "ds-boss-cta-card" do %>
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="ds-boss-cta-label"><%= t("wallpaper.cta_wallpaper") %></span>
        <% end %>
        <button type="button" class="ds-boss-cta-card" id="task-cta-btn">
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M9 14h6"/><path d="M9 18h6"/></svg>
          <span class="ds-boss-cta-label"><%= t("wallpaper.cta_task") %></span>
        </button>
      </div>

      <%# Fond d'écran choisi | Dernière capture côte à côte %>
      <% current_application = @applications&.first %>
      <% current_wallpaper = current_application&.wallpaper %>
      <% latest_screenshot = @screenshots&.first %>
      <div class="ds-boss-preview-grid" style="--device-ratio: <%= device_ratio %>;">
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless current_wallpaper&.image&.attached? %>">
          <% if current_wallpaper&.image&.attached? %>
            <% variant = @device.screen_width.present? && @device.screen_height.present? ? current_wallpaper.variant_for(@device) : current_wallpaper.image %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag variant, alt: t("wallpaper.alt_chosen_wallpaper"), class: "ds-wallpaper-img" %>
            </div>
            <div class="ds-wallpaper-meta">
              <span><%= t("wallpaper.chosen_wallpaper_at", datetime: l(current_application.applied_at, format: :short)) %></span>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder"><%= t("wallpaper.no_wallpaper") %></p>
            <%= link_to t("wallpaper.choose_wallpaper"), wallpaper_upload_new_path(@nickname, device_id: @device_id), class: "ds-boss-preview-cta" %>
          <% end %>
        </div>
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless latest_screenshot&.image&.attached? %>">
          <% if latest_screenshot&.image&.attached? %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag latest_screenshot.image, alt: t("wallpaper.alt_latest_screenshot"), class: "ds-wallpaper-img" %>
              <a href="<%= url_for(latest_screenshot.image) %>" download="screenshot-<%= latest_screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="<%= t("wallpaper.download") %>">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
            <div class="ds-wallpaper-meta">
              <span><%= t("wallpaper.latest_screenshot_at", datetime: l(latest_screenshot.captured_at, format: :short)) %></span>
              <%= wallpaper_verification_badge(latest_screenshot) %>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder"><%= t("wallpaper.no_screenshot") %></p>
            <%= button_to t("wallpaper.take_screenshot"), wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-preview-cta ds-btn ds-btn--ghost ds-btn--sm" %>
          <% end %>
        </div>
      </div>

      <%# Historique des tâches %>
      <section class="ds-task-section" id="task-form-section">
        <h2 class="ds-section-title"><%= t("wallpaper.task_history_title") %></h2>
        <details id="task-form-details" class="ds-task-form-details">
          <summary class="ds-task-form-summary"><%= t("wallpaper.create_task_summary") %></summary>
          <%= render "tasks/form" %>
        </details>
        <% if @tasks.any? %>
          <ul class="ds-task-list">
            <% @tasks.each do |task| %>
              <li class="ds-task-card">
                <div class="ds-task-card-info">
                  <span class="ds-task-card-name"><%= task.name %></span>
                  <div class="ds-task-card-meta">
                    <%= t("wallpaper.task_deadline", datetime: l(task.deadline_at, format: :short)) %>
                    · <span class="ds-task-status ds-task-status--<%= task.effective_status %>"><%= task.effective_status %></span>
                    <% if task.proof_pending? %>
                      · <span class="ds-task-status ds-task-status--pending"><%= t("wallpaper.proof_pending") %></span>
                    <% end %>
                  </div>
                </div>
                <div class="ds-task-card-actions">
                  <%= link_to t("wallpaper.view"), wallpaper_task_path(@nickname, task, device_id: @device_id), class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                  <% if task.expired? %>
                    <%= link_to t("wallpaper.punish"), wallpaper_task_path(@nickname, task, device_id: @device_id), class: "ds-btn ds-btn--primary ds-btn--sm" %>
                  <% end %>
                  <%= button_to wallpaper_task_destroy_path(@nickname, task, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: t("wallpaper.destroy_task_confirm") }, class: "ds-btn-icon-form" }, class: "ds-btn-icon ds-btn-icon--delete", title: t("wallpaper.delete") do %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>

      <%# Historique des screenshots %>
      <section class="ds-history">
        <h2 class="ds-section-title"><%= t("wallpaper.screenshot_history_title") %></h2>
        <% screenshots_with_images = @screenshots.select { |s| s.image.attached? } %>
        <% if screenshots_with_images.any? %>
          <div class="ds-history-expandable" data-initial="6" data-step="9" data-total="<%= screenshots_with_images.size %>">
            <div class="ds-history-grid-wrapper" id="screenshots-wrapper" style="--device-ratio: <%= device_ratio %>;">
              <div class="ds-history-grid" id="screenshots-grid">
                <% screenshots_with_images.each do |screenshot| %>
                  <div class="ds-wallpaper-card ds-history-item">
                    <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                      <%= image_tag screenshot.image, alt: t("wallpaper.screenshot_alt"), class: "ds-wallpaper-img" %>
                      <a href="<%= url_for(screenshot.image) %>" download="screenshot-<%= screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="<%= t("wallpaper.download") %>">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                      <% if current_user.admin? %>
                        <%= button_to wallpaper_destroy_screenshot_path(@nickname, screenshot.id, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: t("wallpaper.destroy_screenshot_confirm") }, class: "ds-btn-icon-form ds-btn-icon-form--overlay" }, class: "ds-btn-icon ds-btn-icon--delete ds-btn-icon--overlay", title: t("wallpaper.delete") do %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        <% end %>
                      <% end %>
                    </div>
                    <div class="ds-wallpaper-meta">
                      <span><%= screenshot.captured_at.strftime("%d/%m %H:%M") %></span>
                      <%= wallpaper_verification_badge(screenshot) %>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="ds-history-fade"></div>
            </div>
            <button type="button" class="ds-history-more" id="screenshots-more"><%= t("wallpaper.see_more") %></button>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;"><%= t("wallpaper.no_screenshots_yet") %></p>
        <% end %>
      </section>

      <%# Historique des fonds d'écran choisis %>
      <section class="ds-history">
        <h2 class="ds-section-title"><%= t("wallpaper.wallpaper_history_title") %></h2>
        <% applications_with_images = @applications.select { |a| a.wallpaper.image.attached? } %>
        <% if applications_with_images.any? %>
          <div class="ds-history-header">
            <button type="button" id="download-all-btn" class="ds-btn ds-btn--ghost ds-btn--sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              <%= t("wallpaper.download_all") %>
            </button>
          </div>
          <div class="ds-history-expandable" data-initial="6" data-step="9" data-total="<%= applications_with_images.size %>">
            <div class="ds-history-grid-wrapper" id="wallpapers-wrapper" style="--device-ratio: <%= device_ratio %>;">
              <div class="ds-history-grid" id="wallpapers-grid">
                <% applications_with_images.each_with_index do |application, index| %>
                  <% wallpaper = application.wallpaper %>
                  <% variant = @device.screen_width.present? && @device.screen_height.present? ? wallpaper.variant_for(@device) : wallpaper.image %>
                  <% download_url = url_for(variant) %>
                  <% is_current = index == 0 %>
                  <div class="ds-wallpaper-card wallpaper-card ds-history-item" data-download-url="<%= download_url %>" data-filename="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg">
                    <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                      <%= image_tag variant, alt: "", class: "ds-wallpaper-img" %>
                      <a href="<%= download_url %>" download="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg" class="ds-download-icon" title="<%= t("wallpaper.download") %>">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                      <%= button_to wallpaper_destroy_application_path(@nickname, application.id, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: t("wallpaper.remove_wallpaper_history_confirm") }, class: "ds-btn-icon-form ds-btn-icon-form--overlay" }, class: "ds-btn-icon ds-btn-icon--delete ds-btn-icon--overlay", title: t("wallpaper.delete") do %>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                      <% end %>
                    </div>
                    <div class="ds-wallpaper-meta">
                      <span><%= application.applied_at.strftime("%d/%m %H:%M") %></span>
                      <% if wallpaper.first_downloaded_at %>
                        <span class="ds-badge">✓</span>
                      <% end %>
                    </div>
                    <% unless is_current %>
                      <div class="ds-wallpaper-actions">
                        <%= button_to t("wallpaper.set_as_current"), wallpaper_set_current_path(@nickname, wallpaper.id, device_id: @device_id), method: :post, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="ds-history-fade"></div>
            </div>
            <button type="button" class="ds-history-more" id="wallpapers-more"><%= t("wallpaper.see_more") %></button>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;"><%= t("wallpaper.no_wallpapers_yet") %></p>
        <% end %>
      </section>

      <details class="ds-debug-section">
        <summary class="ds-debug-summary"><%= t("wallpaper.devices_debug") %></summary>
        <div class="ds-debug-content">
          <ul class="ds-debug-device-list">
            <% @devices.order(created_at: :desc).each do |d| %>
              <li class="ds-debug-device-item <%= 'ds-debug-device-item--current' if d.id == @device.id %>">
                <span class="ds-debug-device-info">
                  <span class="ds-device-name"><%= d.display_name %></span>
                  <% if d.name.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-device-id"><%= d.device_id %></span>
                  <% end %>
                  <% if d.screen_width.present? && d.screen_height.present? %>
                    <span class="ds-sep">·</span>
                    <span><%= d.screen_width %>×<%= d.screen_height %></span>
                  <% end %>
                  <% if d.fcm_token.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--on"><%= t("wallpaper.push_on") %></span>
                  <% else %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--off"><%= t("wallpaper.push_off") %></span>
                  <% end %>
                  <% if d.id == @device.id %>
                    <span class="ds-debug-badge"><%= t("wallpaper.device_active") %></span>
                  <% end %>
                </span>
                <%= button_to wallpaper_destroy_device_path(@nickname, d.device_id), method: :delete, form: { data: { turbo_confirm: t("wallpaper.destroy_device_confirm") }, class: "ds-btn-icon-form" }, class: "ds-btn-icon ds-btn-icon--delete", title: t("wallpaper.delete") do %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </details>
    <% else %>
      <p class="ds-error"><%= t("wallpaper.no_device") %></p>
    <% end %>
  </div>
</div>
<script>
  (function() {
    const permissionsIconBtn = document.getElementById('permissions-icon-btn');
    const permissionsDialog = document.getElementById('permissions-dialog');
    const permissionsDialogClose = document.getElementById('permissions-dialog-close');
    if (permissionsIconBtn && permissionsDialog) {
      permissionsIconBtn.addEventListener('click', function() { permissionsDialog.showModal(); });
    }
    if (permissionsDialog) {
      permissionsDialog.addEventListener('click', function(e) {
        if (e.target === permissionsDialog) permissionsDialog.close();
      });
      if (permissionsDialogClose) {
        permissionsDialogClose.addEventListener('click', function() { permissionsDialog.close(); });
      }
    }

    const taskCtaBtn = document.getElementById('task-cta-btn');
    const taskFormDetails = document.getElementById('task-form-details');
    if (taskCtaBtn && taskFormDetails) {
      taskCtaBtn.addEventListener('click', function() {
        taskFormDetails.open = true;
        taskFormDetails.scrollIntoView({ behavior: 'smooth' });
      });
    }

    const downloadAllBtn = document.getElementById('download-all-btn');
    if (downloadAllBtn) {
      downloadAllBtn.addEventListener('click', function() {
        document.querySelectorAll('.wallpaper-card').forEach(function(card, i) {
          setTimeout(function() {
            const a = document.createElement('a');
            a.href = card.dataset.downloadUrl;
            a.download = card.dataset.filename || 'wallpaper.jpg';
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 300);
        });
      });
    }

    function initHistoryExpandable(expandable) {
      const wrapper = expandable.querySelector('.ds-history-grid-wrapper');
      const grid = expandable.querySelector('.ds-history-grid');
      const moreBtn = expandable.querySelector('.ds-history-more');
      const fade = expandable.querySelector('.ds-history-fade');
      if (!wrapper || !grid || !moreBtn) return;
      const items = grid.querySelectorAll('.ds-history-item');
      const total = items.length;
      const initial = parseInt(expandable.dataset.initial || 6, 10);
      const step = parseInt(expandable.dataset.step || 9, 10);
      if (total <= initial) {
        moreBtn.classList.add('ds-history-more--hidden');
        if (fade) fade.style.display = 'none';
        return;
      }
      if (fade) fade.style.display = 'none';
      let visibleCount = initial;
      function updateHeight() {
        if (visibleCount >= total) {
          wrapper.style.maxHeight = '';
          wrapper.classList.add('ds-history-grid-wrapper--expanded');
          moreBtn.classList.add('ds-history-more--hidden');
        } else {
          const nextItem = items[visibleCount];
          wrapper.style.maxHeight = (nextItem ? nextItem.offsetTop : wrapper.scrollHeight) + 'px';
        }
      }
      updateHeight();
      moreBtn.addEventListener('click', function() {
        visibleCount = Math.min(visibleCount + step, total);
        updateHeight();
      });
    }
    document.querySelectorAll('.ds-history-expandable').forEach(initHistoryExpandable);
  })();
</script>
