<% device_ratio = (@device&.screen_width.to_f / @device&.screen_height) if @device&.screen_width.to_i > 0 && @device&.screen_height.to_i > 0 %>
<% device_ratio ||= 9.0 / 16 %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
<% end %>

<div class="ds-page">
  <div class="ds-container">
    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <% if @device %>
      <% permissions_all_ok = @device.permissions_ok || @device.permissions_missing_list.empty? %>
    <% end %>

    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <div class="ds-header-text">
        <h1 class="ds-title">OTB</h1>
        <p class="ds-subtitle ds-subtitle--with-icon">
          Own their backgrounds
          <% if @device %>
            <button type="button" class="ds-permissions-icon ds-permissions-icon--<%= permissions_all_ok ? 'ok' : 'warning' %>" id="permissions-icon-btn" title="<%= permissions_all_ok ? 'Autorisations OK' : 'Autorisations manquantes' %>" aria-label="<%= permissions_all_ok ? 'Autorisations OK' : 'Autorisations manquantes' %>">
              <% if permissions_all_ok %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <% else %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <% end %>
            </button>
          <% end %>
        </p>
      </div>
    </header>

    <% if @device %>
      <dialog id="permissions-dialog" class="ds-dialog">
        <button type="button" class="ds-dialog-close-btn" id="permissions-dialog-close" title="Fermer" aria-label="Fermer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="ds-dialog-content">
          <% if permissions_all_ok %>
            <p class="ds-dialog-text">Les autorisations sont correctement configurées. L'app fonctionnera correctement.</p>
            <ul class="ds-permissions-checklist">
              <% Device::PERMISSION_LABELS.each_value do |label| %>
                <li class="ds-permissions-checklist-item ds-permissions-checklist-item--ok"><span class="ds-permissions-check">✓</span> <%= label %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="ds-dialog-text">Il manque certaines autorisations sur le téléphone du beta. Sans elles, les captures d'écran et les notifications peuvent ne pas fonctionner.</p>
            <ul class="ds-permissions-checklist">
              <% missing_list = @device.permissions_missing_list %>
              <% Device::PERMISSION_LABELS.each do |key, label| %>
                <% ok = !missing_list.include?(key) %>
                <li class="ds-permissions-checklist-item ds-permissions-checklist-item--<%= ok ? 'ok' : 'missing' %>">
                  <span class="ds-permissions-check"><%= ok ? '✓' : '✗' %></span> <%= label %>
                </li>
              <% end %>
            </ul>
            <div class="ds-dialog-actions">
              <%= button_to "Envoyer une notification au beta", wallpaper_grant_permissions_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-btn ds-btn--primary ds-btn--sm" %>
            </div>
          <% end %>
        </div>
      </dialog>
    <% end %>

    <% if @device %>
      <%# 3 CTA carrés %>
      <div class="ds-boss-cta-grid">
        <%= button_to wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-cta-card", form: { class: "ds-boss-cta-form" } do %>
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/><path d="M16 8l4-4"/></svg>
          <span class="ds-boss-cta-label">Screenshot</span>
        <% end %>
        <label for="image-input" class="ds-boss-cta-card">
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="ds-boss-cta-label">Fond d'écran</span>
        </label>
        <button type="button" class="ds-boss-cta-card" id="task-cta-btn">
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M9 14h6"/><path d="M9 18h6"/></svg>
          <span class="ds-boss-cta-label">Tâche</span>
        </button>
      </div>

      <%# Upload form (file input déclenché par le CTA Fond d'écran) %>
      <%= form_with url: wallpaper_upload_submit_path(@nickname, device_id: @device_id), method: :post, local: true, multipart: true, id: "upload-form", class: "ds-form" do |f| %>
        <%= f.file_field :image, accept: "image/*", id: "image-input", style: "display: none" %>
      <% end %>

      <%# Modal plein écran : crop + edit %>
      <div id="editor-modal" class="ds-editor-modal" style="display: none;">
        <button type="button" id="editor-modal-close" class="ds-editor-modal-close" title="Fermer" aria-label="Fermer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>

        <div id="crop-container" class="ds-editor-modal-step">
          <p class="ds-editor-step-label">Recadrez (ratio écran)</p>
          <div id="crop-wrapper" class="ds-editor-crop-wrapper">
            <img id="crop-img" src="" alt="Crop" />
          </div>
          <div class="ds-editor-actions">
            <button type="button" id="change-image-btn" class="ds-btn ds-btn--secondary">Changer</button>
            <button type="button" id="suivant-btn" class="ds-btn ds-btn--primary">Suivant →</button>
          </div>
        </div>

        <div id="edit-container" class="ds-editor-modal-step" style="display: none;">
          <div class="ds-editor-toolbar">
            <button type="button" id="tool-text" class="ds-tool-btn ds-tool-btn--active" title="Écrire du texte">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
              Texte
            </button>
            <button type="button" id="tool-pixelate" class="ds-tool-btn" title="Pixeliser (brush)">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Pixeliser
            </button>
            <button type="button" id="tool-undo" class="ds-tool-btn" title="Annuler">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
              Annuler
            </button>
          </div>
          <div id="text-options" class="ds-editor-options-row">
            <label class="ds-editor-option-label" title="Couleur">
              <input type="color" id="text-color" value="#ffffff" class="ds-editor-color-input">
            </label>
            <label class="ds-editor-option-label">
              <input type="range" id="text-size" min="16" max="200" value="100" step="4" class="ds-editor-range">
              <span id="text-size-display" class="ds-editor-value">100px</span>
            </label>
          </div>
          <div id="pixelate-options" class="ds-editor-options-row" style="display: none;">
            <label class="ds-editor-option-label">
              Taille brush
              <input type="range" id="brush-size" min="20" max="200" value="60" step="10" class="ds-editor-range">
              <span id="brush-size-display" class="ds-editor-value">60</span>
            </label>
            <label class="ds-editor-option-label">
              Taille pixels
              <input type="range" id="pixel-size" min="4" max="32" value="12" step="2" class="ds-editor-range">
              <span id="pixel-size-display" class="ds-editor-value">12</span>
            </label>
          </div>
          <p id="editor-hint" class="ds-editor-step-label">Cliquez pour écrire, ou glissez un texte pour le déplacer</p>
          <div class="ds-editor-canvas-wrapper" id="canvas-wrapper">
            <canvas id="edit-canvas"></canvas>
            <div id="floating-text-wrapper" class="ds-editor-floating-text-wrapper" style="display:none;">
              <div id="floating-text-input" class="ds-editor-floating-text" contenteditable="true" spellcheck="false"></div>
              <button type="button" id="text-delete-btn" class="ds-editor-text-delete-btn" title="Supprimer">×</button>
            </div>
          </div>
          <div class="ds-editor-actions">
            <button type="button" id="edit-back-btn" class="ds-btn ds-btn--secondary">← Recadrer</button>
            <button type="button" id="edit-submit-btn" class="ds-btn ds-btn--primary">Envoyer</button>
          </div>
        </div>
      </div>

      <%# Fond d'écran choisi | Dernière capture côte à côte %>
      <% current_application = @applications&.first %>
      <% current_wallpaper = current_application&.wallpaper %>
      <% latest_screenshot = @screenshots&.first %>
      <div class="ds-boss-preview-grid" style="--device-ratio: <%= device_ratio %>;">
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless current_wallpaper&.image&.attached? %>">
          <% if current_wallpaper&.image&.attached? %>
            <% variant = @device.screen_width.present? && @device.screen_height.present? ? current_wallpaper.variant_for(@device) : current_wallpaper.image %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag variant, alt: "Fond d'écran actuel", class: "ds-wallpaper-img" %>
            </div>
            <div class="ds-wallpaper-meta">
              <span>Fond d'écran choisi · <%= current_application.applied_at.strftime("%d/%m %H:%M") %></span>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder">Aucun fond d'écran</p>
            <label for="image-input" class="ds-boss-preview-cta">Choisir un fond d'écran</label>
          <% end %>
        </div>
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless latest_screenshot&.image&.attached? %>">
          <% if latest_screenshot&.image&.attached? %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag latest_screenshot.image, alt: "Dernière capture", class: "ds-wallpaper-img" %>
              <a href="<%= url_for(latest_screenshot.image) %>" download="screenshot-<%= latest_screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="Télécharger">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
            <div class="ds-wallpaper-meta">
              <span>Dernière capture · <%= latest_screenshot.captured_at.strftime("%d/%m %H:%M") %></span>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder">Aucune capture</p>
            <%= button_to "Prendre un screenshot", wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-preview-cta ds-btn ds-btn--ghost ds-btn--sm" %>
          <% end %>
        </div>
      </div>

      <%# Historique des tâches %>
      <section class="ds-task-section" id="task-form-section">
        <h2 class="ds-section-title">Historique des tâches</h2>
        <details id="task-form-details" class="ds-task-form-details">
          <summary class="ds-task-form-summary">Créer une tâche</summary>
          <%= render "tasks/form" %>
        </details>
        <% if @tasks.any? %>
          <ul class="ds-task-list">
            <% @tasks.each do |task| %>
              <li class="ds-task-card">
                <div class="ds-task-card-info">
                  <span class="ds-task-card-name"><%= task.name %></span>
                  <div class="ds-task-card-meta">
                    Deadline: <%= task.deadline_at.strftime("%d/%m %H:%M") %>
                    · <span class="ds-task-status ds-task-status--<%= task.status %>"><%= task.status %></span>
                    <% if task.proof_pending? %>
                      · <span class="ds-task-status ds-task-status--pending">Preuve en attente</span>
                    <% end %>
                  </div>
                </div>
                <div class="ds-task-card-actions">
                  <%= link_to "Voir", wallpaper_task_path(@nickname, task, device_id: @device_id), class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                  <%= button_to wallpaper_task_destroy_path(@nickname, task, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: "Supprimer cette tâche ?" }, class: "ds-btn-icon-form" }, class: "ds-btn-icon ds-btn-icon--delete", title: "Supprimer" do %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>

      <%# Historique des screenshots %>
      <section class="ds-history">
        <h2 class="ds-section-title">Historique des screenshots</h2>
        <% screenshots_with_images = @screenshots.select { |s| s.image.attached? } %>
        <% if screenshots_with_images.any? %>
          <div class="ds-history-expandable" data-initial="6" data-step="9" data-total="<%= screenshots_with_images.size %>">
            <div class="ds-history-grid-wrapper" id="screenshots-wrapper" style="--device-ratio: <%= device_ratio %>;">
              <div class="ds-history-grid" id="screenshots-grid">
                <% screenshots_with_images.each do |screenshot| %>
                  <div class="ds-wallpaper-card ds-history-item">
                    <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                      <%= image_tag screenshot.image, alt: "Screenshot", class: "ds-wallpaper-img" %>
                      <a href="<%= url_for(screenshot.image) %>" download="screenshot-<%= screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="Télécharger">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                      <% if current_user.admin? %>
                        <%= button_to wallpaper_destroy_screenshot_path(@nickname, screenshot.id, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: "Supprimer ce screenshot ?" }, class: "ds-btn-icon-form ds-btn-icon-form--overlay" }, class: "ds-btn-icon ds-btn-icon--delete ds-btn-icon--overlay", title: "Supprimer" do %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        <% end %>
                      <% end %>
                    </div>
                    <div class="ds-wallpaper-meta">
                      <span><%= screenshot.captured_at.strftime("%d/%m %H:%M") %></span>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="ds-history-fade"></div>
            </div>
            <button type="button" class="ds-history-more" id="screenshots-more">Voir plus</button>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;">Aucun screenshot pour le moment.</p>
        <% end %>
      </section>

      <%# Historique des fonds d'écran choisis %>
      <section class="ds-history">
        <h2 class="ds-section-title">Historique des fonds d'écran</h2>
        <% applications_with_images = @applications.select { |a| a.wallpaper.image.attached? } %>
        <% if applications_with_images.any? %>
          <div class="ds-history-header">
            <button type="button" id="download-all-btn" class="ds-btn ds-btn--ghost ds-btn--sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Tout télécharger
            </button>
          </div>
          <div class="ds-history-expandable" data-initial="6" data-step="9" data-total="<%= applications_with_images.size %>">
            <div class="ds-history-grid-wrapper" id="wallpapers-wrapper" style="--device-ratio: <%= device_ratio %>;">
              <div class="ds-history-grid" id="wallpapers-grid">
                <% applications_with_images.each_with_index do |application, index| %>
                  <% wallpaper = application.wallpaper %>
                  <% variant = @device.screen_width.present? && @device.screen_height.present? ? wallpaper.variant_for(@device) : wallpaper.image %>
                  <% download_url = url_for(variant) %>
                  <% is_current = index == 0 %>
                  <div class="ds-wallpaper-card wallpaper-card ds-history-item" data-download-url="<%= download_url %>" data-filename="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg">
                    <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                      <%= image_tag variant, alt: "", class: "ds-wallpaper-img" %>
                      <a href="<%= download_url %>" download="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg" class="ds-download-icon" title="Télécharger">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                      <%= button_to wallpaper_destroy_application_path(@nickname, application.id, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: "Retirer cette entrée de l'historique ?" }, class: "ds-btn-icon-form ds-btn-icon-form--overlay" }, class: "ds-btn-icon ds-btn-icon--delete ds-btn-icon--overlay", title: "Supprimer" do %>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                      <% end %>
                    </div>
                    <div class="ds-wallpaper-meta">
                      <span><%= application.applied_at.strftime("%d/%m %H:%M") %></span>
                      <% if wallpaper.first_downloaded_at %>
                        <span class="ds-badge">✓</span>
                      <% end %>
                    </div>
                    <% unless is_current %>
                      <div class="ds-wallpaper-actions">
                        <%= button_to "Définir comme actuel", wallpaper_set_current_path(@nickname, wallpaper.id, device_id: @device_id), method: :post, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="ds-history-fade"></div>
            </div>
            <button type="button" class="ds-history-more" id="wallpapers-more">Voir plus</button>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;">Aucun fond d'écran pour le moment.</p>
        <% end %>
      </section>

      <details class="ds-debug-section">
        <summary class="ds-debug-summary">Devices (debug)</summary>
        <div class="ds-debug-content">
          <ul class="ds-debug-device-list">
            <% @devices.order(created_at: :desc).each do |d| %>
              <li class="ds-debug-device-item <%= 'ds-debug-device-item--current' if d.id == @device.id %>">
                <span class="ds-debug-device-info">
                  <span class="ds-device-name"><%= d.display_name %></span>
                  <% if d.name.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-device-id"><%= d.device_id %></span>
                  <% end %>
                  <% if d.screen_width.present? && d.screen_height.present? %>
                    <span class="ds-sep">·</span>
                    <span><%= d.screen_width %>×<%= d.screen_height %></span>
                  <% end %>
                  <% if d.fcm_token.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--on">Push</span>
                  <% else %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--off">Push off</span>
                  <% end %>
                  <% if d.id == @device.id %>
                    <span class="ds-debug-badge">actif</span>
                  <% end %>
                </span>
                <%= button_to wallpaper_destroy_device_path(@nickname, d.device_id), method: :delete, form: { data: { turbo_confirm: "Supprimer ce device ? Tous les wallpapers associés seront perdus." }, class: "ds-btn-icon-form" }, class: "ds-btn-icon ds-btn-icon--delete", title: "Supprimer" do %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </details>
    <% else %>
      <p class="ds-error">Aucun device enregistré. Ouvre l'app pour t'enregistrer.</p>
    <% end %>
  </div>
</div>
<script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  (function() {
    const screenW = <%= @device&.screen_width || 0 %>;
    const screenH = <%= @device&.screen_height || 0 %>;
    const aspectRatio = (screenW > 0 && screenH > 0) ? screenW / screenH : 9 / 16;
    const uploadUrl = '<%= wallpaper_upload_submit_path(@nickname, device_id: @device_id) %>';

    const input          = document.getElementById('image-input');
    const form           = document.getElementById('upload-form');
    const editorModal    = document.getElementById('editor-modal');
    const modalClose     = document.getElementById('editor-modal-close');
    const cropContainer  = document.getElementById('crop-container');
    const editContainer  = document.getElementById('edit-container');
    const cropImg        = document.getElementById('crop-img');
    const changeImageBtn = document.getElementById('change-image-btn');
    const suivantBtn     = document.getElementById('suivant-btn');

    let cropper = null;

    function initCropper() {
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImg, {
        aspectRatio: aspectRatio,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        restore: false
      });
    }

    function showCrop(file) {
      const reader = new FileReader();
      reader.onload = function() {
        cropImg.src = reader.result;
        editContainer.style.display = 'none';
        cropContainer.style.display = 'block';
        editorModal.style.display = 'flex';
        cropImg.onload = function() { initCropper(); };
      };
      reader.readAsDataURL(file);
    }

    function closeModal() {
      if (cropper) { cropper.destroy(); cropper = null; }
      cropImg.src = '';
      cropContainer.style.display = 'none';
      editContainer.style.display = 'none';
      editorModal.style.display = 'none';
      input.value = '';
    }

    if (input) {
      input.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        showCrop(file);
      });
    }

    if (changeImageBtn) changeImageBtn.addEventListener('click', function() { input.click(); });
    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (editorModal) {
      editorModal.addEventListener('click', function(e) {
        if (e.target === editorModal) closeModal();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && editorModal.style.display === 'flex') {
          closeModal();
        }
      });
    }

    if (suivantBtn) {
      suivantBtn.addEventListener('click', function() {
        if (!cropper) return;
        const croppedCanvas = cropper.getCroppedCanvas();
        if (!croppedCanvas) return;
        initEditStep(croppedCanvas);
      });
    }

    // ── STEP 2 : EDIT ──────────────────────────────────────────────────────────

    const editCanvas      = document.getElementById('edit-canvas');
    const canvasWrapper   = document.getElementById('canvas-wrapper');
    const editBackBtn     = document.getElementById('edit-back-btn');
    const editSubmitBtn   = document.getElementById('edit-submit-btn');
    const toolTextBtn     = document.getElementById('tool-text');
    const toolPixelateBtn = document.getElementById('tool-pixelate');
    const toolUndoBtn     = document.getElementById('tool-undo');
    const textOptions     = document.getElementById('text-options');
    const pixelateOptions = document.getElementById('pixelate-options');
    const textColorInput  = document.getElementById('text-color');
    const textSizeInput   = document.getElementById('text-size');
    const textSizeDisplay = document.getElementById('text-size-display');
    const brushSizeInput  = document.getElementById('brush-size');
    const brushSizeDisplay = document.getElementById('brush-size-display');
    const pixelSizeInput  = document.getElementById('pixel-size');
    const pixelSizeDisplay = document.getElementById('pixel-size-display');
    const floatingInput   = document.getElementById('floating-text-input');
    const floatingWrapper = document.getElementById('floating-text-wrapper');
    const textDeleteBtn   = document.getElementById('text-delete-btn');
    const editorHint      = document.getElementById('editor-hint');

    let editCtx = null;
    let imageLayer = null;
    let texts = [];
    let currentTool = 'text';
    let undoStack = [];
    let pendingCanvasX = 0, pendingCanvasY = 0;
    let draggingTextIndex = -1;
    let dragOffsetX = 0, dragOffsetY = 0;
    let editingTextIndex = -1;
    let potentialDrag = null;
    let isBrushDrawing = false;
    let lastBrushX = -1, lastBrushY = -1;
    let skipNextTouchEndForNewText = false;

    const HINTS = {
      text:     'Cliquez pour écrire, ou glissez un texte pour le déplacer. Clic sur un texte = modifier.',
      pixelate: 'Glissez sur la photo pour pixeliser'
    };

    function getCSSToCanvasScale() {
      const r = editCanvas.getBoundingClientRect();
      return { x: editCanvas.width / r.width, y: editCanvas.height / r.height };
    }

    function clientToCanvas(clientX, clientY) {
      const rect = editCanvas.getBoundingClientRect();
      const scale = getCSSToCanvasScale();
      return {
        x: (clientX - rect.left) * scale.x,
        y: (clientY - rect.top) * scale.y
      };
    }

    function saveUndoState() {
      if (!imageLayer || !editCtx) return;
      const imgCopy = editCtx.createImageData(imageLayer);
      imgCopy.data.set(imageLayer.data);
      undoStack.push({ imageData: imgCopy, texts: JSON.parse(JSON.stringify(texts)) });
      if (undoStack.length > 20) undoStack.shift();
    }

    function setTool(tool) {
      currentTool = tool;
      toolTextBtn.classList.toggle('ds-tool-btn--active', tool === 'text');
      toolPixelateBtn.classList.toggle('ds-tool-btn--active', tool === 'pixelate');
      textOptions.style.display = tool === 'text' ? '' : 'none';
      pixelateOptions.style.display = tool === 'pixelate' ? '' : 'none';
      if (editorHint) editorHint.textContent = HINTS[tool] || '';
      cancelText();
    }

    function initEditStep(croppedCanvas) {
      editCanvas.width  = croppedCanvas.width;
      editCanvas.height = croppedCanvas.height;
      editCtx = editCanvas.getContext('2d');
      editCtx.drawImage(croppedCanvas, 0, 0);
      imageLayer = editCtx.getImageData(0, 0, editCanvas.width, editCanvas.height);
      texts = [];
      undoStack = [];
      cropContainer.style.display = 'none';
      editContainer.style.display = 'block';
      setTool('text');
      render();
    }

    function render() {
      if (!editCtx || !imageLayer) return;
      editCtx.putImageData(imageLayer, 0, 0);
      const font = 'Inter, -apple-system, sans-serif';
      texts.forEach(function(t, i) {
        if (i === editingTextIndex) return;
        editCtx.font         = `bold ${t.fontSize}px ${font}`;
        editCtx.fillStyle    = t.color;
        editCtx.textAlign    = 'center';
        editCtx.textBaseline = 'middle';
        editCtx.shadowColor  = 'rgba(0,0,0,0.8)';
        editCtx.shadowBlur   = Math.max(3, t.fontSize * 0.15);
        editCtx.fillText(t.text, t.x, t.y);
        editCtx.textAlign    = 'left';
        editCtx.textBaseline = 'top';
        editCtx.shadowBlur   = 0;
      });
    }

    function hitTestText(cx, cy) {
      if (!editCtx) return -1;
      const font = 'Inter, -apple-system, sans-serif';
      for (let i = texts.length - 1; i >= 0; i--) {
        const t = texts[i];
        editCtx.font = `bold ${t.fontSize}px ${font}`;
        const w = editCtx.measureText(t.text).width;
        const h = t.fontSize * 1.2;
        const left = t.x - w / 2;
        const top = t.y - h / 2;
        if (cx >= left && cx <= left + w && cy >= top && cy <= top + h) return i;
      }
      return -1;
    }

    // ── Text tool ──────────────────────────────────────────────────────────────

    function showFloatingInput(cssX, cssY, canvasX, canvasY, textIndex) {
      editingTextIndex = textIndex !== undefined ? textIndex : -1;
      pendingCanvasX = canvasX;
      pendingCanvasY = canvasY;
      const scale = getCSSToCanvasScale();
      let displaySize, color;
      if (editingTextIndex >= 0) {
        const t = texts[editingTextIndex];
        displaySize = t.fontSize / scale.x;
        color = t.color;
        floatingInput.textContent = t.text;
        if (textDeleteBtn) textDeleteBtn.style.display = '';
      } else {
        displaySize = parseInt(textSizeInput.value) / scale.x;
        color = textColorInput.value;
        floatingInput.textContent = '';
        if (textDeleteBtn) textDeleteBtn.style.display = 'none';
      }
      floatingWrapper.style.left   = cssX + 'px';
      floatingWrapper.style.top    = cssY + 'px';
      floatingInput.style.fontSize = displaySize + 'px';
      floatingInput.style.color    = color;
      floatingWrapper.style.display = 'block';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          floatingInput.focus({ preventScroll: true });
          const range = document.createRange();
          range.selectNodeContents(floatingInput);
          range.collapse(editingTextIndex >= 0);
          const sel = window.getSelection();
          if (sel) { sel.removeAllRanges(); sel.addRange(range); }
        });
      });
    }

    function commitText() {
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      const text = (floatingInput.textContent || '').trim();
      const wasEditing = editingTextIndex >= 0;
      const idx = editingTextIndex;
      floatingWrapper.style.display = 'none';
      floatingInput.textContent = '';
      editingTextIndex = -1;
      if (wasEditing) {
        saveUndoState();
        if (!text) {
          texts.splice(idx, 1);
        } else {
          texts[idx].text = text;
        }
      } else {
        if (!text) return;
        saveUndoState();
        texts.push({
          text: text,
          x: pendingCanvasX,
          y: pendingCanvasY,
          fontSize: parseInt(textSizeInput.value),
          color: textColorInput.value
        });
      }
      render();
    }

    function cancelText() {
      if (!floatingWrapper) return;
      floatingWrapper.style.display = 'none';
      floatingInput.textContent = '';
      editingTextIndex = -1;
    }

    function deleteCurrentText() {
      if (editingTextIndex < 0) return;
      saveUndoState();
      texts.splice(editingTextIndex, 1);
      editingTextIndex = -1;
      floatingWrapper.style.display = 'none';
      floatingInput.textContent = '';
      render();
    }

    if (floatingInput) {
      floatingInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter')  { e.preventDefault(); commitText(); }
        if (e.key === 'Escape') { e.preventDefault(); e.stopPropagation(); cancelText(); }
      });
      floatingInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text/plain');
        document.execCommand('insertText', false, text);
      });
    }
    if (textDeleteBtn) {
      textDeleteBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        deleteCurrentText();
      });
    }

    if (textSizeInput && textSizeDisplay) {
      textSizeInput.addEventListener('input', function() {
        textSizeDisplay.textContent = this.value + 'px';
        if (floatingWrapper && floatingWrapper.style.display === 'block' && editingTextIndex < 0) {
          const scale = getCSSToCanvasScale();
          floatingInput.style.fontSize = (parseInt(this.value) / scale.x) + 'px';
        }
      });
    }

    if (brushSizeInput && brushSizeDisplay) {
      brushSizeInput.addEventListener('input', function() {
        brushSizeDisplay.textContent = this.value;
      });
    }
    if (pixelSizeInput && pixelSizeDisplay) {
      pixelSizeInput.addEventListener('input', function() {
        pixelSizeDisplay.textContent = this.value;
      });
    }

    // ── Pixelate brush ──────────────────────────────────────────────────────────

    function pixelateRegionInImageData(data, x, y, w, h, blockSize) {
      const wd = data.width;
      const ht = data.height;
      const d = data.data;
      x = Math.max(0, Math.round(x));
      y = Math.max(0, Math.round(y));
      w = Math.min(Math.round(w), wd - x);
      h = Math.min(Math.round(h), ht - y);
      if (w <= 0 || h <= 0) return;
      blockSize = Math.max(2, blockSize);
      for (let py = 0; py < h; py += blockSize) {
        for (let px = 0; px < w; px += blockSize) {
          const gx = x + px;
          const gy = y + py;
          const i = (gy * wd + gx) * 4;
          const r = d[i], g = d[i+1], b = d[i+2], a = d[i+3];
          for (let by = 0; by < blockSize && py + by < h; by++) {
            for (let bx = 0; bx < blockSize && px + bx < w; bx++) {
              const idx = ((y + py + by) * wd + (x + px + bx)) * 4;
              d[idx] = r; d[idx+1] = g; d[idx+2] = b; d[idx+3] = a;
            }
          }
        }
      }
    }

    function applyBrushAt(canvasX, canvasY) {
      const brushSize = parseInt(brushSizeInput.value) || 60;
      const pixelSize = parseInt(pixelSizeInput.value) || 12;
      const half = brushSize / 2;
      const x = Math.max(0, canvasX - half);
      const y = Math.max(0, canvasY - half);
      const w = Math.min(brushSize, editCanvas.width - x);
      const h = Math.min(brushSize, editCanvas.height - y);
      if (w <= 0 || h <= 0) return;
      pixelateRegionInImageData(imageLayer, x, y, w, h, pixelSize);
    }

    function handleBrushDown(clientX, clientY) {
      const pt = clientToCanvas(clientX, clientY);
      saveUndoState();
      isBrushDrawing = true;
      lastBrushX = pt.x;
      lastBrushY = pt.y;
      applyBrushAt(pt.x, pt.y);
      render();
    }

    function handleBrushMove(clientX, clientY) {
      if (!isBrushDrawing) return;
      const pt = clientToCanvas(clientX, clientY);
      const step = parseInt(brushSizeInput.value) * 0.3;
      const dist = Math.hypot(pt.x - lastBrushX, pt.y - lastBrushY);
      if (dist >= step) {
        applyBrushAt(pt.x, pt.y);
        lastBrushX = pt.x;
        lastBrushY = pt.y;
        render();
      }
    }

    function handleBrushUp() {
      isBrushDrawing = false;
    }

    // ── Canvas events ───────────────────────────────────────────────────────────

    function handleCanvasMouseDown(e) {
      if (floatingWrapper && floatingWrapper.style.display === 'block') {
        cancelText();
        return;
      }
      const wrapperRect = canvasWrapper.getBoundingClientRect();
      const pt = clientToCanvas(e.clientX, e.clientY);
      if (currentTool === 'text') {
        const hit = hitTestText(pt.x, pt.y);
        if (hit >= 0) {
          potentialDrag = { index: hit, startX: pt.x, startY: pt.y };
        } else {
          e.preventDefault();
          commitText();
          showFloatingInput(
            e.clientX - wrapperRect.left,
            e.clientY - wrapperRect.top,
            pt.x, pt.y
          );
        }
      } else if (currentTool === 'pixelate') {
        handleBrushDown(e.clientX, e.clientY);
      }
    }

    function handleCanvasMouseMove(e) {
      if (currentTool === 'pixelate') {
        handleBrushMove(e.clientX, e.clientY);
      } else if (currentTool === 'text') {
        if (potentialDrag) {
          const pt = clientToCanvas(e.clientX, e.clientY);
          const dist = Math.hypot(pt.x - potentialDrag.startX, pt.y - potentialDrag.startY);
          if (dist > 6) {
            saveUndoState();
            draggingTextIndex = potentialDrag.index;
            dragOffsetX = pt.x - texts[potentialDrag.index].x;
            dragOffsetY = pt.y - texts[potentialDrag.index].y;
            potentialDrag = null;
          }
        } else if (draggingTextIndex >= 0) {
          const pt = clientToCanvas(e.clientX, e.clientY);
          texts[draggingTextIndex].x = pt.x - dragOffsetX;
          texts[draggingTextIndex].y = pt.y - dragOffsetY;
          render();
        }
      }
    }

    function handleCanvasMouseUp(e) {
      if (currentTool === 'pixelate') {
        handleBrushUp();
      } else if (currentTool === 'text') {
        if (draggingTextIndex >= 0) {
          draggingTextIndex = -1;
        } else if (potentialDrag) {
          const wrapperRect = canvasWrapper.getBoundingClientRect();
          const canvasRect = editCanvas.getBoundingClientRect();
          const scale = getCSSToCanvasScale();
          const t = texts[potentialDrag.index];
          const cssX = (canvasRect.left - wrapperRect.left) + t.x / scale.x;
          const cssY = (canvasRect.top - wrapperRect.top) + t.y / scale.y;
          showFloatingInput(cssX, cssY, t.x, t.y, potentialDrag.index);
          potentialDrag = null;
          render();
        }
      }
    }

    if (editCanvas) {
      editCanvas.addEventListener('mousedown', handleCanvasMouseDown);
      editCanvas.addEventListener('touchstart', function(e) {
        const t = e.touches[0];
        const ev = { clientX: t.clientX, clientY: t.clientY };
        if (floatingWrapper && floatingWrapper.style.display === 'block') {
          e.preventDefault();
          cancelText();
          skipNextTouchEndForNewText = true;
          return;
        }
        skipNextTouchEndForNewText = false;
        if (currentTool === 'pixelate') {
          e.preventDefault();
          handleCanvasMouseDown(ev);
        } else if (currentTool === 'text') {
          const pt = clientToCanvas(t.clientX, t.clientY);
          const hit = hitTestText(pt.x, pt.y);
          if (hit >= 0) {
            e.preventDefault();
            potentialDrag = { index: hit, startX: pt.x, startY: pt.y };
          }
        }
      }, { passive: false });

      editCanvas.addEventListener('touchmove', function(e) {
        if (currentTool === 'pixelate' || draggingTextIndex >= 0 || potentialDrag) e.preventDefault();
        const t = e.touches[0];
        handleCanvasMouseMove({ clientX: t.clientX, clientY: t.clientY });
      }, { passive: false });

      editCanvas.addEventListener('touchend', function(e) {
        if (currentTool === 'pixelate' || draggingTextIndex >= 0 || potentialDrag) e.preventDefault();
        const t = e.changedTouches[0];
        if (currentTool === 'text') {
          if (draggingTextIndex >= 0 || potentialDrag) {
            handleCanvasMouseUp(e);
          } else if (skipNextTouchEndForNewText) {
            skipNextTouchEndForNewText = false;
          } else {
            const wrapperRect = canvasWrapper.getBoundingClientRect();
            const pt = clientToCanvas(t.clientX, t.clientY);
            commitText();
            showFloatingInput(t.clientX - wrapperRect.left, t.clientY - wrapperRect.top, pt.x, pt.y);
          }
        } else {
          handleCanvasMouseUp(e);
        }
      }, { passive: false });
    }

    window.addEventListener('mousemove', handleCanvasMouseMove);
    window.addEventListener('mouseup', handleCanvasMouseUp);

    function handleClickOutsideFloating(e) {
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      if (floatingWrapper.contains(e.target)) return;
      cancelText();
      e.stopPropagation();
    }

    document.addEventListener('mousedown', function(e) {
      if (!editContainer || editContainer.style.display !== 'block') return;
      handleClickOutsideFloating(e);
    }, true);
    document.addEventListener('touchstart', function(e) {
      if (!editContainer || editContainer.style.display !== 'block') return;
      if (!floatingWrapper || floatingWrapper.style.display !== 'block') return;
      if (floatingWrapper.contains(e.target)) return;
      cancelText();
      skipNextTouchEndForNewText = true;
    }, { passive: true, capture: true });

    // ── Toolbar & actions ───────────────────────────────────────────────────────

    if (toolTextBtn)     toolTextBtn.addEventListener('click', function() { setTool('text'); });
    if (toolPixelateBtn) toolPixelateBtn.addEventListener('click', function() { setTool('pixelate'); });

    if (toolUndoBtn) {
      toolUndoBtn.addEventListener('click', function() {
        cancelText();
        if (undoStack.length > 0 && imageLayer && editCtx) {
          const s = undoStack.pop();
          imageLayer.data.set(s.imageData.data);
          texts = s.texts;
          render();
        }
      });
    }

    if (editBackBtn) {
      editBackBtn.addEventListener('click', function() {
        cancelText();
        editContainer.style.display = 'none';
        cropContainer.style.display = 'block';
      });
    }

    if (editSubmitBtn) {
      editSubmitBtn.addEventListener('click', function() {
        commitText();
        if (!editCanvas || !editCanvas.width || !editCtx) return;
        editSubmitBtn.disabled    = true;
        editSubmitBtn.textContent = 'Envoi...';
        editCanvas.toBlob(function(blob) {
          const formData = new FormData();
          formData.append('image', blob, 'wallpaper.jpg');
          const token = form.querySelector('input[name="authenticity_token"]')?.value;
          if (token) formData.append('authenticity_token', token);
          fetch(uploadUrl, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            headers: { 'X-CSRF-Token': token || '', 'Accept': 'text/html' },
            redirect: 'follow'
          }).then(function(res) {
            if (res.ok || res.redirected) {
              window.location.href = res.url;
            } else {
              editSubmitBtn.disabled    = false;
              editSubmitBtn.textContent = 'Envoyer';
              alert('Erreur lors de l\'upload.');
            }
          }).catch(function() {
            editSubmitBtn.disabled    = false;
            editSubmitBtn.textContent = 'Envoyer';
            alert('Erreur lors de l\'upload.');
          });
        }, 'image/jpeg', 0.9);
      });
    }

    // ── Permissions dialog ────────────────────────────────────────────────────

    const permissionsIconBtn   = document.getElementById('permissions-icon-btn');
    const permissionsDialog    = document.getElementById('permissions-dialog');
    const permissionsDialogClose = document.getElementById('permissions-dialog-close');
    if (permissionsIconBtn && permissionsDialog) {
      permissionsIconBtn.addEventListener('click', function() { permissionsDialog.showModal(); });
    }
    if (permissionsDialog) {
      permissionsDialog.addEventListener('click', function(e) {
        if (e.target === permissionsDialog) permissionsDialog.close();
      });
      if (permissionsDialogClose) {
        permissionsDialogClose.addEventListener('click', function() { permissionsDialog.close(); });
      }
    }

    // ── Task CTA ──────────────────────────────────────────────────────────────

    const taskCtaBtn     = document.getElementById('task-cta-btn');
    const taskFormDetails = document.getElementById('task-form-details');
    if (taskCtaBtn && taskFormDetails) {
      taskCtaBtn.addEventListener('click', function() {
        taskFormDetails.open = true;
        taskFormDetails.scrollIntoView({ behavior: 'smooth' });
      });
    }

    // ── Download all ──────────────────────────────────────────────────────────

    const downloadAllBtn = document.getElementById('download-all-btn');
    if (downloadAllBtn) {
      downloadAllBtn.addEventListener('click', function() {
        document.querySelectorAll('.wallpaper-card').forEach(function(card, i) {
          setTimeout(function() {
            const a = document.createElement('a');
            a.href = card.dataset.downloadUrl;
            a.download = card.dataset.filename || 'wallpaper.jpg';
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 300);
        });
      });
    }

    // ── History expandable ────────────────────────────────────────────────────

    function initHistoryExpandable(expandable) {
      const wrapper = expandable.querySelector('.ds-history-grid-wrapper');
      const grid    = expandable.querySelector('.ds-history-grid');
      const moreBtn = expandable.querySelector('.ds-history-more');
      const fade    = expandable.querySelector('.ds-history-fade');
      if (!wrapper || !grid || !moreBtn) return;
      const items   = grid.querySelectorAll('.ds-history-item');
      const total   = items.length;
      const initial = parseInt(expandable.dataset.initial || 6, 10);
      const step    = parseInt(expandable.dataset.step    || 9, 10);
      if (total <= initial) {
        moreBtn.classList.add('ds-history-more--hidden');
        if (fade) fade.style.display = 'none';
        return;
      }
      if (fade) fade.style.display = 'none';
      let visibleCount = initial;
      function updateHeight() {
        if (visibleCount >= total) {
          wrapper.style.maxHeight = '';
          wrapper.classList.add('ds-history-grid-wrapper--expanded');
          moreBtn.classList.add('ds-history-more--hidden');
        } else {
          const nextItem = items[visibleCount];
          wrapper.style.maxHeight = (nextItem ? nextItem.offsetTop : wrapper.scrollHeight) + 'px';
        }
      }
      updateHeight();
      moreBtn.addEventListener('click', function() {
        visibleCount = Math.min(visibleCount + step, total);
        updateHeight();
      });
    }

    document.querySelectorAll('.ds-history-expandable').forEach(initHistoryExpandable);
  })();
</script>
