<div style="max-width: 480px; margin: 2rem auto; padding: 2rem; font-family: system-ui, sans-serif;">
  <% if flash[:notice] %>
    <p style="padding: 0.75rem; background: #d4edda; color: #155724; border-radius: 4px; margin-bottom: 1rem;"><%= flash[:notice] %></p>
  <% end %>
  <% if flash[:alert] %>
    <p style="padding: 0.75rem; background: #f8d7da; color: #721c24; border-radius: 4px; margin-bottom: 1rem;"><%= flash[:alert] %></p>
  <% end %>
  <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Set Wallpaper</h1>
  <p style="color: #666; margin-bottom: 1.5rem;">
    Upload an image to set it as your device wallpaper.
  </p>

  <% if @device %>
    <p style="font-size: 0.875rem; color: #888; margin-bottom: 1rem;">
      Device: <code><%= @device_id %></code>
      <% if @device.screen_width.present? && @device.screen_height.present? %>
        · Écran: <%= @device.screen_width %>×<%= @device.screen_height %>
      <% end %>
      <% if @device.fcm_token.present? %>
        · <span style="color: #28a745;">Push activé</span>
      <% else %>
        · <span style="color: #dc3545;">Push non configuré</span> (ouvre l’app pour enregistrer le token)
      <% end %>
    </p>

    <%= form_with url: wallpaper_upload_submit_path(@device_id), method: :post, local: true, multipart: true, id: "upload-form" do |f| %>
      <div style="margin-bottom: 1rem;">
        <div id="file-input-wrapper" style="margin-bottom: 0.5rem;">
          <%= f.file_field :image, accept: "image/*", style: "display: block;", id: "image-input" %>
        </div>
        <div id="crop-container" style="display: none; margin-top: 0.5rem;">
          <p style="font-size: 0.75rem; color: #666; margin-bottom: 0.25rem;">Recadrez l'image (ratio écran)</p>
          <div id="crop-wrapper" style="max-height: 400px; background: #000;">
            <img id="crop-img" src="" alt="Crop" style="max-width: 100%; display: block;" />
          </div>
          <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem;">
            <button type="button" id="change-image-btn" style="padding: 0.5rem 1rem; background: #666; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 0.875rem;">Changer d'image</button>
            <%= f.submit "Upload", id: "upload-btn", style: "padding: 0.5rem 1rem; background: #000; color: #fff; border: none; border-radius: 4px; cursor: pointer;" %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @wallpapers.any? %>
      <h2 style="font-size: 1.1rem; margin: 2rem 0 1rem;">Historique des wallpapers</h2>
      <div style="margin-bottom: 0.75rem;">
        <button type="button" id="download-all-btn" class="download-all-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Télécharger tout
        </button>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.75rem;" id="wallpapers-grid">
        <% @wallpapers.each_with_index do |wallpaper, i| %>
          <% next unless wallpaper.image.attached? %>
          <% variant = @device.screen_width.present? && @device.screen_height.present? ? wallpaper.variant_for(@device) : wallpaper.image %>
          <% download_url = url_for(variant) %>
          <div style="border: 1px solid #ddd; border-radius: 4px; overflow: hidden;" class="wallpaper-card" data-download-url="<%= download_url %>" data-filename="wallpaper-<%= wallpaper.created_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg">
            <div style="position: relative;">
              <%= image_tag variant, style: "width: 100%; height: 80px; object-fit: cover; display: block;" %>
              <a href="<%= download_url %>" download="wallpaper-<%= wallpaper.created_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg" class="download-icon" title="Télécharger">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
            <div style="padding: 0.25rem 0.5rem; font-size: 0.7rem; color: #666;">
              <%= wallpaper.created_at.strftime("%d/%m %H:%M") %>
              <% if wallpaper.first_downloaded_at %>
                <br><span style="color: #28a745;">✓ Téléchargé</span>
              <% end %>
            </div>
            <%= button_to "Supprimer", wallpaper_destroy_path(@device_id, wallpaper.id), method: :delete, form: { data: { turbo_confirm: "Supprimer ce wallpaper ?" } }, class: "delete-btn" %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p style="color: #c00;">
      Device not found. Please open the app first to register your device.
    </p>
  <% end %>
</div>

<style>
  .delete-btn { width: 100%; padding: 0.25rem; font-size: 0.7rem; background: #dc3545; color: white; border: none; cursor: pointer; }
  .download-all-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem; background: #000; color: #fff; border: none; border-radius: 4px;
    font-size: 0.875rem; cursor: pointer; font-family: inherit;
  }
  .download-all-btn:hover { background: #333; }
  .download-icon {
    position: absolute; top: 4px; right: 4px;
    display: flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; background: rgba(0,0,0,0.6); color: #fff;
    border-radius: 4px; text-decoration: none; transition: background 0.2s;
  }
  .download-icon:hover { background: rgba(0,0,0,0.85); color: #fff; }
</style>
<link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
<script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  (function() {
    const screenW = <%= @device&.screen_width || 0 %>;
    const screenH = <%= @device&.screen_height || 0 %>;
    const aspectRatio = (screenW > 0 && screenH > 0) ? screenW / screenH : 9 / 16;
    const uploadUrl = '<%= wallpaper_upload_submit_path(@device_id) %>';

    const input = document.getElementById('image-input');
    const fileWrapper = document.getElementById('file-input-wrapper');
    const cropContainer = document.getElementById('crop-container');
    const cropImg = document.getElementById('crop-img');
    const cropWrapper = document.getElementById('crop-wrapper');
    const changeImageBtn = document.getElementById('change-image-btn');
    const uploadBtn = document.getElementById('upload-btn');
    const form = document.getElementById('upload-form');

    let cropper = null;
    let currentFile = null;

    function initCropper() {
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImg, {
        aspectRatio: aspectRatio,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        restore: false
      });
    }

    function showCrop(file) {
      currentFile = file;
      const reader = new FileReader();
      reader.onload = function() {
        cropImg.src = reader.result;
        fileWrapper.style.display = 'none';
        cropContainer.style.display = 'block';
        cropImg.onload = function() {
          initCropper();
        };
      };
      reader.readAsDataURL(file);
    }

    function resetCrop() {
      if (cropper) {
        cropper.destroy();
        cropper = null;
      }
      currentFile = null;
      cropImg.src = '';
      cropContainer.style.display = 'none';
      fileWrapper.style.display = 'block';
      input.value = '';
    }

    if (input) {
      input.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        showCrop(file);
      });
    }

    if (changeImageBtn) {
      changeImageBtn.addEventListener('click', resetCrop);
    }

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!cropper || !currentFile) return;

        const canvas = cropper.getCroppedCanvas();
        canvas.toBlob(function(blob) {
          const formData = new FormData();
          formData.append('image', blob, 'wallpaper.jpg');
          const token = form.querySelector('input[name="authenticity_token"]')?.value;
          if (token) formData.append('authenticity_token', token);

          uploadBtn.disabled = true;
          uploadBtn.value = 'Envoi...';

          fetch(uploadUrl, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            headers: {
              'X-CSRF-Token': token || '',
              'Accept': 'text/html'
            },
            redirect: 'follow'
          }).then(function(res) {
            if (res.ok || res.redirected) {
              window.location.href = res.url;
            } else {
              uploadBtn.disabled = false;
              uploadBtn.value = 'Upload';
              alert('Erreur lors de l\'upload.');
            }
          }).catch(function() {
            uploadBtn.disabled = false;
            uploadBtn.value = 'Upload';
            alert('Erreur lors de l\'upload.');
          });
        }, 'image/jpeg', 0.9);
      });
    }

    const downloadAllBtn = document.getElementById('download-all-btn');
    if (downloadAllBtn) {
      downloadAllBtn.addEventListener('click', function() {
        const cards = document.querySelectorAll('.wallpaper-card');
        cards.forEach(function(card, i) {
          setTimeout(function() {
            const url = card.dataset.downloadUrl;
            const filename = card.dataset.filename || 'wallpaper.jpg';
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 300);
        });
      });
    }
  })();
</script>
