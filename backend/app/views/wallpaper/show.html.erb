<% device_ratio = (@device&.screen_width.to_f / @device&.screen_height) if @device&.screen_width.to_i > 0 && @device&.screen_height.to_i > 0 %>
<% device_ratio ||= 9.0 / 16 %>

<% content_for :head do %>
  <style>body { background: #0a0a0b; margin: 0; }</style>
<% end %>

<div class="br-page">
  <div class="br-container">
    <% if flash[:notice] %>
      <div class="br-flash br-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="br-flash br-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <header class="br-header">
      <h1 class="br-title">OTB</h1>
      <p class="br-subtitle">Own their backgrounds</p>
    </header>

    <% if @device %>
      <div class="br-device-info">
        <span class="br-device-id"><%= @device_id %></span>
        <% if @device.screen_width.present? && @device.screen_height.present? %>
          <span class="br-sep">·</span>
          <span><%= @device.screen_width %>×<%= @device.screen_height %></span>
        <% end %>
        <% if @device.fcm_token.present? %>
          <span class="br-sep">·</span>
          <span class="br-status br-status--on">Push</span>
        <% else %>
          <span class="br-sep">·</span>
          <span class="br-status br-status--off">Push off</span>
        <% end %>
      </div>

      <%= form_with url: wallpaper_upload_submit_path(@device_id), method: :post, local: true, multipart: true, id: "upload-form", class: "br-form" do |f| %>
        <div class="br-upload">
          <div id="file-input-wrapper" class="br-file-wrapper">
            <label class="br-file-label">
              <%= f.file_field :image, accept: "image/*", id: "image-input" %>
              <span class="br-file-text">Choisir une image</span>
            </label>
          </div>
          <div id="crop-container" class="br-crop-container" style="display: none;">
            <p class="br-crop-label">Recadrez (ratio écran)</p>
            <div id="crop-wrapper" class="br-crop-wrapper">
              <img id="crop-img" src="" alt="Crop" />
            </div>
            <div class="br-crop-actions">
              <button type="button" id="change-image-btn" class="br-btn br-btn--secondary">Changer</button>
              <%= f.submit "Envoyer", id: "upload-btn", class: "br-btn br-btn--primary" %>
            </div>
          </div>
        </div>
      <% end %>

      <% if @wallpapers.any? %>
        <% current_wallpaper = @wallpapers.first %>
        <% if current_wallpaper.image.attached? %>
          <% current_variant = @device.screen_width.present? && @device.screen_height.present? ? current_wallpaper.variant_for(@device) : current_wallpaper.image %>
          <section class="br-current">
            <h2 class="br-section-title">Fond actuel</h2>
            <div class="br-current-frame" style="aspect-ratio: <%= device_ratio %>;">
              <%= image_tag current_variant, alt: "Current wallpaper", class: "br-current-img" %>
            </div>
          </section>
        <% end %>

        <section class="br-history">
          <div class="br-history-header">
            <h2 class="br-section-title">Historique</h2>
            <button type="button" id="download-all-btn" class="br-btn br-btn--ghost br-btn--sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Tout télécharger
            </button>
          </div>
          <div class="br-history-grid" id="wallpapers-grid" style="--device-ratio: <%= device_ratio %>;">
            <% @wallpapers.each do |wallpaper| %>
              <% next unless wallpaper.image.attached? %>
              <% variant = @device.screen_width.present? && @device.screen_height.present? ? wallpaper.variant_for(@device) : wallpaper.image %>
              <% download_url = url_for(variant) %>
              <div class="br-wallpaper-card wallpaper-card" data-download-url="<%= download_url %>" data-filename="wallpaper-<%= wallpaper.created_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg">
                <div class="br-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                  <%= image_tag variant, alt: "", class: "br-wallpaper-img" %>
                  <a href="<%= download_url %>" download="wallpaper-<%= wallpaper.created_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg" class="br-download-icon" title="Télécharger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  </a>
                </div>
                <div class="br-wallpaper-meta">
                  <span><%= wallpaper.created_at.strftime("%d/%m %H:%M") %></span>
                  <% if wallpaper.first_downloaded_at %>
                    <span class="br-badge">✓</span>
                  <% end %>
                </div>
                <%= button_to "Supprimer", wallpaper_destroy_path(@device_id, wallpaper.id), method: :delete, form: { data: { turbo_confirm: "Supprimer ce wallpaper ?" } }, class: "br-delete-btn" %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    <% else %>
      <p class="br-error">Device not found. Ouvre l'app pour t'enregistrer.</p>
    <% end %>
  </div>
</div>

<style>
  :root {
    --br-bg: #0a0a0b;
    --br-surface: #121214;
    --br-surface-elevated: #1a1a1d;
    --br-border: #2a2a2e;
    --br-text: #e8e6e3;
    --br-text-muted: #8a8784;
    --br-amber: #e9a03f;
    --br-amber-dim: #b87d2e;
    --br-teal: #2ec4b6;
    --br-teal-dim: #1e9d92;
    --br-error: #c75c5c;
    --br-success: #4a9d7a;
  }

  .br-page {
    min-height: 100vh;
    background: var(--br-bg);
    font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--br-text);
    padding: 2rem 1rem;
  }

  .br-container {
    max-width: 420px;
    margin: 0 auto;
  }

  .br-flash {
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .br-flash--success {
    background: rgba(74, 157, 122, 0.15);
    color: var(--br-success);
    border: 1px solid rgba(74, 157, 122, 0.3);
  }
  .br-flash--error {
    background: rgba(199, 92, 92, 0.15);
    color: var(--br-error);
    border: 1px solid rgba(199, 92, 92, 0.3);
  }

  .br-header {
    margin-bottom: 1.5rem;
  }
  .br-title {
    font-size: 1.75rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    margin: 0;
    color: var(--br-text);
  }
  .br-subtitle {
    font-size: 0.8rem;
    color: var(--br-text-muted);
    margin: 0.25rem 0 0;
    letter-spacing: 0.04em;
  }

  .br-device-info {
    font-size: 0.75rem;
    color: var(--br-text-muted);
    margin-bottom: 1.5rem;
    font-family: ui-monospace, monospace;
  }
  .br-device-id { color: var(--br-teal); }
  .br-sep { margin: 0 0.35rem; opacity: 0.5; }
  .br-status--on { color: var(--br-success); }
  .br-status--off { color: var(--br-text-muted); }

  .br-file-wrapper { margin-bottom: 1rem; }
  .br-file-label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    border: 1px dashed var(--br-border);
    border-radius: 6px;
    background: var(--br-surface);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .br-file-label:hover {
    border-color: var(--br-amber-dim);
    background: var(--br-surface-elevated);
  }
  .br-file-label input[type="file"] { display: none; }
  .br-file-text { color: var(--br-text-muted); font-size: 0.875rem; }

  .br-crop-container { margin-top: 1rem; }
  .br-crop-label {
    font-size: 0.75rem;
    color: var(--br-text-muted);
    margin-bottom: 0.5rem;
  }
  .br-crop-wrapper {
    max-height: 380px;
    background: var(--br-bg);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--br-border);
  }
  .br-crop-wrapper img { max-width: 100%; display: block; }
  .br-crop-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .br-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 4px;
    font-size: 0.875rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s, color 0.2s;
  }
  .br-btn--primary {
    background: var(--br-amber);
    color: #0a0a0b;
  }
  .br-btn--primary:hover { background: var(--br-amber-dim); }
  .br-btn--secondary {
    background: var(--br-surface-elevated);
    color: var(--br-text-muted);
    border: 1px solid var(--br-border);
  }
  .br-btn--secondary:hover {
    background: var(--br-border);
    color: var(--br-text);
  }
  .br-btn--ghost {
    background: transparent;
    color: var(--br-teal);
  }
  .br-btn--ghost:hover { color: var(--br-teal-dim); }
  .br-btn--sm {
    padding: 0.35rem 0.6rem;
    font-size: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .br-current {
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }
  .br-section-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--br-text-muted);
    margin: 0 0 0.75rem;
  }
  .br-current-frame {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--br-border);
    background: var(--br-surface);
  }
  .br-current-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .br-history { margin-top: 1.5rem; }
  .br-history-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .br-history-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.75rem;
  }
  .br-wallpaper-card {
    background: var(--br-surface);
    border: 1px solid var(--br-border);
    border-radius: 6px;
    overflow: hidden;
  }
  .br-wallpaper-thumb {
    position: relative;
    overflow: hidden;
  }
  .br-wallpaper-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .br-download-icon {
    position: absolute;
    top: 4px;
    right: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: rgba(10, 10, 11, 0.75);
    color: var(--br-teal);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .br-download-icon:hover {
    background: var(--br-teal);
    color: var(--br-bg);
  }
  .br-wallpaper-meta {
    padding: 0.3rem 0.5rem;
    font-size: 0.65rem;
    color: var(--br-text-muted);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .br-badge { color: var(--br-success); }
  .br-delete-btn {
    width: 100%;
    padding: 0.3rem;
    font-size: 0.65rem;
    background: transparent;
    color: var(--br-text-muted);
    border: none;
    border-top: 1px solid var(--br-border);
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
  }
  .br-delete-btn:hover {
    color: var(--br-error);
    background: rgba(199, 92, 92, 0.1);
  }

  .br-error {
    color: var(--br-error);
    font-size: 0.875rem;
  }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
<script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  (function() {
    const screenW = <%= @device&.screen_width || 0 %>;
    const screenH = <%= @device&.screen_height || 0 %>;
    const aspectRatio = (screenW > 0 && screenH > 0) ? screenW / screenH : 9 / 16;
    const uploadUrl = '<%= wallpaper_upload_submit_path(@device_id) %>';

    const input = document.getElementById('image-input');
    const fileWrapper = document.getElementById('file-input-wrapper');
    const cropContainer = document.getElementById('crop-container');
    const cropImg = document.getElementById('crop-img');
    const changeImageBtn = document.getElementById('change-image-btn');
    const uploadBtn = document.getElementById('upload-btn');
    const form = document.getElementById('upload-form');

    let cropper = null;
    let currentFile = null;

    function initCropper() {
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImg, {
        aspectRatio: aspectRatio,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        restore: false
      });
    }

    function showCrop(file) {
      currentFile = file;
      const reader = new FileReader();
      reader.onload = function() {
        cropImg.src = reader.result;
        fileWrapper.style.display = 'none';
        cropContainer.style.display = 'block';
        cropImg.onload = function() {
          initCropper();
        };
      };
      reader.readAsDataURL(file);
    }

    function resetCrop() {
      if (cropper) {
        cropper.destroy();
        cropper = null;
      }
      currentFile = null;
      cropImg.src = '';
      cropContainer.style.display = 'none';
      fileWrapper.style.display = 'block';
      input.value = '';
    }

    if (input) {
      input.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        showCrop(file);
      });
    }

    if (changeImageBtn) {
      changeImageBtn.addEventListener('click', resetCrop);
    }

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!cropper || !currentFile) return;

        const canvas = cropper.getCroppedCanvas();
        canvas.toBlob(function(blob) {
          const formData = new FormData();
          formData.append('image', blob, 'wallpaper.jpg');
          const token = form.querySelector('input[name="authenticity_token"]')?.value;
          if (token) formData.append('authenticity_token', token);

          uploadBtn.disabled = true;
          uploadBtn.value = 'Envoi...';

          fetch(uploadUrl, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            headers: {
              'X-CSRF-Token': token || '',
              'Accept': 'text/html'
            },
            redirect: 'follow'
          }).then(function(res) {
            if (res.ok || res.redirected) {
              window.location.href = res.url;
            } else {
              uploadBtn.disabled = false;
              uploadBtn.value = 'Envoyer';
              alert('Erreur lors de l\'upload.');
            }
          }).catch(function() {
            uploadBtn.disabled = false;
            uploadBtn.value = 'Envoyer';
            alert('Erreur lors de l\'upload.');
          });
        }, 'image/jpeg', 0.9);
      });
    }

    const downloadAllBtn = document.getElementById('download-all-btn');
    if (downloadAllBtn) {
      downloadAllBtn.addEventListener('click', function() {
        const cards = document.querySelectorAll('.wallpaper-card');
        cards.forEach(function(card, i) {
          setTimeout(function() {
            const url = card.dataset.downloadUrl;
            const filename = card.dataset.filename || 'wallpaper.jpg';
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 300);
        });
      });
    }
  })();
</script>
