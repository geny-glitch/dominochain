<% device_ratio = (@device&.screen_width.to_f / @device&.screen_height) if @device&.screen_width.to_i > 0 && @device&.screen_height.to_i > 0 %>
<% device_ratio ||= 9.0 / 16 %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
<% end %>

<div class="ds-page">
  <div class="ds-container">
    <% if flash[:notice] %>
      <div class="ds-flash ds-flash--success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="ds-flash ds-flash--error"><%= flash[:alert] %></div>
    <% end %>

    <header class="ds-header">
      <%= image_tag "otb-logo.png", alt: "OTB", class: "ds-header-logo", width: 48, height: 48 %>
      <h1 class="ds-title">OTB</h1>
      <p class="ds-subtitle">Own their backgrounds</p>
    </header>

    <% if @device %>
      <%# 3 CTA carrés %>
      <div class="ds-boss-cta-grid">
        <%= button_to wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-cta-card", form: { class: "ds-boss-cta-form" } do %>
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/><path d="M16 8l4-4"/></svg>
          <span class="ds-boss-cta-label">Screenshot</span>
        <% end %>
        <label for="image-input" class="ds-boss-cta-card">
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="ds-boss-cta-label">Fond d'écran</span>
        </label>
        <button type="button" class="ds-boss-cta-card" id="task-cta-btn">
          <svg class="ds-boss-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M9 14h6"/><path d="M9 18h6"/></svg>
          <span class="ds-boss-cta-label">Tâche</span>
        </button>
      </div>

      <%# Upload form (file input déclenché par le CTA Fond d'écran) %>
      <%= form_with url: wallpaper_upload_submit_path(@nickname, device_id: @device_id), method: :post, local: true, multipart: true, id: "upload-form", class: "ds-form" do |f| %>
        <%= f.file_field :image, accept: "image/*", id: "image-input", style: "display: none" %>
        <div id="crop-container" class="ds-crop-container" style="display: none;">
          <p class="ds-crop-label">Recadrez (ratio écran)</p>
          <div id="crop-wrapper" class="ds-crop-wrapper">
            <img id="crop-img" src="" alt="Crop" />
          </div>
          <div class="ds-crop-actions">
            <button type="button" id="change-image-btn" class="ds-btn ds-btn--secondary">Changer</button>
            <%= f.submit "Envoyer", id: "upload-btn", class: "ds-btn ds-btn--primary" %>
          </div>
        </div>
      <% end %>

      <%# Fond d'écran choisi | Dernière capture côte à côte %>
      <% current_application = @applications&.first %>
      <% current_wallpaper = current_application&.wallpaper %>
      <% latest_screenshot = @screenshots&.first %>
      <div class="ds-boss-preview-grid" style="--device-ratio: <%= device_ratio %>;">
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless current_wallpaper&.image&.attached? %>">
          <% if current_wallpaper&.image&.attached? %>
            <% variant = @device.screen_width.present? && @device.screen_height.present? ? current_wallpaper.variant_for(@device) : current_wallpaper.image %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag variant, alt: "Fond d'écran actuel", class: "ds-wallpaper-img" %>
            </div>
            <div class="ds-wallpaper-meta">
              <span>Fond d'écran choisi · <%= current_application.applied_at.strftime("%d/%m %H:%M") %></span>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder">Aucun fond d'écran</p>
            <label for="image-input" class="ds-boss-preview-cta">Choisir un fond d'écran</label>
          <% end %>
        </div>
        <div class="ds-boss-preview-card <%= 'ds-boss-preview-card--empty' unless latest_screenshot&.image&.attached? %>">
          <% if latest_screenshot&.image&.attached? %>
            <div class="ds-boss-preview-thumb">
              <%= image_tag latest_screenshot.image, alt: "Dernière capture", class: "ds-wallpaper-img" %>
              <a href="<%= url_for(latest_screenshot.image) %>" download="screenshot-<%= latest_screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="Télécharger">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
            <div class="ds-wallpaper-meta">
              <span>Dernière capture · <%= latest_screenshot.captured_at.strftime("%d/%m %H:%M") %></span>
            </div>
          <% else %>
            <p class="ds-boss-preview-placeholder">Aucune capture</p>
            <%= button_to "Prendre un screenshot", wallpaper_screenshot_request_path(@nickname, device_id: @device_id), method: :post, class: "ds-boss-preview-cta ds-btn ds-btn--ghost ds-btn--sm" %>
          <% end %>
        </div>
      </div>

      <%# Historique des tâches %>
      <section class="ds-task-section" id="task-form-section">
        <h2 class="ds-section-title">Historique des tâches</h2>
        <details id="task-form-details" class="ds-task-form-details">
          <summary class="ds-task-form-summary">Créer une tâche</summary>
          <%= render "tasks/form" %>
        </details>
        <% if @tasks.any? %>
          <ul class="ds-task-list">
            <% @tasks.each do |task| %>
              <li class="ds-task-card">
                <div class="ds-task-card-info">
                  <span class="ds-task-card-name"><%= task.name %></span>
                  <div class="ds-task-card-meta">
                    Deadline: <%= task.deadline_at.strftime("%d/%m %H:%M") %>
                    · <span class="ds-task-status ds-task-status--<%= task.status %>"><%= task.status %></span>
                    <% if task.proof_pending? %>
                      · <span class="ds-task-status ds-task-status--pending">Preuve en attente</span>
                    <% end %>
                  </div>
                </div>
                <div class="ds-task-card-actions">
                  <%= link_to "Voir", wallpaper_task_path(@nickname, task, device_id: @device_id), class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                  <%= button_to "Supprimer", wallpaper_task_destroy_path(@nickname, task, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: "Supprimer cette tâche ?" } }, class: "ds-btn ds-btn--ghost ds-btn--sm ds-delete-btn" %>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>

      <%# Historique des screenshots %>
      <section class="ds-history">
        <h2 class="ds-section-title">Historique des screenshots</h2>
        <% if @screenshots.any? %>
          <div class="ds-history-grid" id="screenshots-grid" style="--device-ratio: <%= device_ratio %>;">
            <% @screenshots.each do |screenshot| %>
              <% next unless screenshot.image.attached? %>
              <div class="ds-wallpaper-card">
                <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                  <%= image_tag screenshot.image, alt: "Screenshot", class: "ds-wallpaper-img" %>
                  <a href="<%= url_for(screenshot.image) %>" download="screenshot-<%= screenshot.captured_at.strftime('%Y%m%d-%H%M') %>.jpg" class="ds-download-icon" title="Télécharger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  </a>
                </div>
                <div class="ds-wallpaper-meta">
                  <span><%= screenshot.captured_at.strftime("%d/%m %H:%M") %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;">Aucun screenshot pour le moment.</p>
        <% end %>
      </section>

      <%# Historique des fonds d'écran choisis %>
      <section class="ds-history">
        <h2 class="ds-section-title">Historique des fonds d'écran</h2>
        <% if @applications.any? %>
          <div class="ds-history-header">
            <button type="button" id="download-all-btn" class="ds-btn ds-btn--ghost ds-btn--sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Tout télécharger
            </button>
          </div>
          <div class="ds-history-grid" id="wallpapers-grid" style="--device-ratio: <%= device_ratio %>;">
            <% @applications.each_with_index do |application, index| %>
              <% wallpaper = application.wallpaper %>
              <% next unless wallpaper.image.attached? %>
              <% variant = @device.screen_width.present? && @device.screen_height.present? ? wallpaper.variant_for(@device) : wallpaper.image %>
              <% download_url = url_for(variant) %>
              <% is_current = index == 0 %>
              <div class="ds-wallpaper-card wallpaper-card" data-download-url="<%= download_url %>" data-filename="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg">
                <div class="ds-wallpaper-thumb" style="aspect-ratio: <%= device_ratio %>;">
                  <%= image_tag variant, alt: "", class: "ds-wallpaper-img" %>
                  <a href="<%= download_url %>" download="wallpaper-<%= application.applied_at.strftime('%Y%m%d-%H%M') %>-<%= wallpaper.id %>.jpg" class="ds-download-icon" title="Télécharger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  </a>
                </div>
                <div class="ds-wallpaper-meta">
                  <span><%= application.applied_at.strftime("%d/%m %H:%M") %></span>
                  <% if wallpaper.first_downloaded_at %>
                    <span class="ds-badge">✓</span>
                  <% end %>
                </div>
                <div class="ds-wallpaper-actions">
                  <% unless is_current %>
                    <%= button_to "Définir comme actuel", wallpaper_set_current_path(@nickname, wallpaper.id, device_id: @device_id), method: :post, class: "ds-btn ds-btn--secondary ds-btn--sm" %>
                  <% end %>
                  <%= button_to "Supprimer", wallpaper_destroy_application_path(@nickname, application.id, device_id: @device_id), method: :delete, form: { data: { turbo_confirm: "Retirer cette entrée de l'historique ?" } }, class: "ds-delete-btn" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="ds-text-muted" style="font-size: 0.8rem;">Aucun fond d'écran pour le moment.</p>
        <% end %>
      </section>

      <details class="ds-debug-section">
        <summary class="ds-debug-summary">Device (debug)</summary>
        <div class="ds-debug-content">
          <ul class="ds-debug-device-list">
            <% @devices.order(created_at: :desc).each do |d| %>
              <li class="ds-debug-device-item <%= 'ds-debug-device-item--current' if d.id == @device.id %>">
                <span class="ds-debug-device-info">
                  <span class="ds-device-name"><%= d.display_name %></span>
                  <% if d.name.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-device-id"><%= d.device_id %></span>
                  <% end %>
                  <% if d.screen_width.present? && d.screen_height.present? %>
                    <span class="ds-sep">·</span>
                    <span><%= d.screen_width %>×<%= d.screen_height %></span>
                  <% end %>
                  <% if d.fcm_token.present? %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--on">Push</span>
                  <% else %>
                    <span class="ds-sep">·</span>
                    <span class="ds-status ds-status--off">Push off</span>
                  <% end %>
                  <% if d.id == @device.id %>
                    <span class="ds-debug-badge">actif</span>
                  <% end %>
                </span>
                <%= button_to wallpaper_destroy_device_path(@nickname, d.device_id), method: :delete, form: { data: { turbo_confirm: "Supprimer ce device ? Tous les wallpapers associés seront perdus." }, class: "ds-btn-icon-form" }, class: "ds-btn-icon ds-btn-icon--delete", title: "Supprimer" do %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </details>
    <% else %>
      <p class="ds-error">Device not found. Ouvre l'app pour t'enregistrer.</p>
    <% end %>
  </div>
</div>
<script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  (function() {
    const screenW = <%= @device&.screen_width || 0 %>;
    const screenH = <%= @device&.screen_height || 0 %>;
    const aspectRatio = (screenW > 0 && screenH > 0) ? screenW / screenH : 9 / 16;
    const uploadUrl = '<%= wallpaper_upload_submit_path(@nickname, device_id: @device_id) %>';

    const input = document.getElementById('image-input');
    const cropContainer = document.getElementById('crop-container');
    const cropImg = document.getElementById('crop-img');
    const changeImageBtn = document.getElementById('change-image-btn');
    const uploadBtn = document.getElementById('upload-btn');
    const form = document.getElementById('upload-form');

    let cropper = null;
    let currentFile = null;

    function initCropper() {
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImg, {
        aspectRatio: aspectRatio,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        restore: false
      });
    }

    function showCrop(file) {
      currentFile = file;
      const reader = new FileReader();
      reader.onload = function() {
        cropImg.src = reader.result;
        cropContainer.style.display = 'block';
        cropImg.onload = function() {
          initCropper();
        };
      };
      reader.readAsDataURL(file);
    }

    function resetCrop() {
      if (cropper) {
        cropper.destroy();
        cropper = null;
      }
      currentFile = null;
      cropImg.src = '';
      cropContainer.style.display = 'none';
      input.value = '';
    }

    if (input) {
      input.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        showCrop(file);
      });
    }

    if (changeImageBtn) {
      changeImageBtn.addEventListener('click', resetCrop);
    }

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!cropper || !currentFile) return;

        const canvas = cropper.getCroppedCanvas();
        canvas.toBlob(function(blob) {
          const formData = new FormData();
          formData.append('image', blob, 'wallpaper.jpg');
          const token = form.querySelector('input[name="authenticity_token"]')?.value;
          if (token) formData.append('authenticity_token', token);

          uploadBtn.disabled = true;
          uploadBtn.value = 'Envoi...';

          fetch(uploadUrl, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            headers: {
              'X-CSRF-Token': token || '',
              'Accept': 'text/html'
            },
            redirect: 'follow'
          }).then(function(res) {
            if (res.ok || res.redirected) {
              window.location.href = res.url;
            } else {
              uploadBtn.disabled = false;
              uploadBtn.value = 'Envoyer';
              alert('Erreur lors de l\'upload.');
            }
          }).catch(function() {
            uploadBtn.disabled = false;
            uploadBtn.value = 'Envoyer';
            alert('Erreur lors de l\'upload.');
          });
        }, 'image/jpeg', 0.9);
      });
    }

    const taskCtaBtn = document.getElementById('task-cta-btn');
    const taskFormDetails = document.getElementById('task-form-details');
    if (taskCtaBtn && taskFormDetails) {
      taskCtaBtn.addEventListener('click', function() {
        taskFormDetails.open = true;
        taskFormDetails.scrollIntoView({ behavior: 'smooth' });
      });
    }

    const downloadAllBtn = document.getElementById('download-all-btn');
    if (downloadAllBtn) {
      downloadAllBtn.addEventListener('click', function() {
        const cards = document.querySelectorAll('.wallpaper-card');
        cards.forEach(function(card, i) {
          setTimeout(function() {
            const url = card.dataset.downloadUrl;
            const filename = card.dataset.filename || 'wallpaper.jpg';
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 300);
        });
      });
    }
  })();
</script>
