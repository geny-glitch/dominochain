<% device_ratio = (@device&.screen_width.to_f / @device&.screen_height) if @device&.screen_width.to_i > 0 && @device&.screen_height.to_i > 0 %>
<% device_ratio ||= 9.0 / 16 %>

<%= render "shared/image_editor",
  form_url: boss_wallpaper_upload_submit_path(@nickname, device_id: @device_id),
  upload_url: boss_wallpaper_upload_submit_path(@nickname, device_id: @device_id),
  redirect_url: boss_wallpaper_dashboard_path(@nickname, device_id: @device_id),
  back_path: boss_wallpaper_dashboard_path(@nickname, device_id: @device_id),
  back_label: t("wallpaper.upload.back_to_beta"),
  page_title: t("wallpaper.upload.page_title"),
  aspect_ratio: device_ratio,
  submit_mode: "wallpaper",
  i18n: {
    step_choose: t("wallpaper.upload.step_choose"),
    step_crop: t("wallpaper.upload.step_crop"),
    step_edit: t("wallpaper.upload.step_edit"),
    choose_image: t("wallpaper.upload.choose_image"),
    crop_help: t("wallpaper.upload.crop_help"),
    crop_alt: t("wallpaper.upload.crop_alt"),
    change: t("wallpaper.upload.change"),
    next: t("wallpaper.upload.next"),
    tool_pixelate: t("wallpaper.upload.tool_pixelate"),
    tool_pixelate_title: t("wallpaper.upload.tool_pixelate_title"),
    tool_text: t("wallpaper.upload.tool_text"),
    tool_text_title: t("wallpaper.upload.tool_text_title"),
    tool_undo: t("wallpaper.upload.tool_undo"),
    tool_undo_title: t("wallpaper.upload.tool_undo_title"),
    font_title: t("wallpaper.upload.font_title"),
    align_aria: t("wallpaper.upload.align_aria"),
    align_left_title: t("wallpaper.upload.align_left_title"),
    align_center_title: t("wallpaper.upload.align_center_title"),
    align_right_title: t("wallpaper.upload.align_right_title"),
    color_title: t("wallpaper.upload.color_title"),
    brush_size: t("wallpaper.upload.brush_size"),
    pixel_size: t("wallpaper.upload.pixel_size"),
    editor_hint: t("wallpaper.upload.editor_hint"),
    text_delete: t("wallpaper.upload.text_delete"),
    edit_back: t("wallpaper.upload.edit_back"),
    submit: t("wallpaper.upload.submit"),
    submitting: t("wallpaper.upload.submitting", default: "Sending..."),
    error: t("wallpaper.upload.error", default: "Upload error."),
    hint_text: t("wallpaper.upload.hint_text", default: t("wallpaper.upload.editor_hint")),
    hint_pixelate: t("wallpaper.upload.hint_pixelate", default: t("wallpaper.upload.editor_hint"))
  }
%>
